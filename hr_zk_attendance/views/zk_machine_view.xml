<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_zk_machine_form" model="ir.ui.view">
        <field name="name">zk.machine.form</field>
        <field name="model">zk.machine</field>
        <field name="arch" type="xml">
            <form string="Biometric Device">
                <header>
                    <button name="clear_attendance" type="object" string="Clear Data" class="oe_highlight"
                            icon="fa-remove " confirm="Are you sure you want to do this?"/>
                    <button name="download_attendance" type="object" string="Download Data" class="oe_highlight"
                            icon="fa-download " confirm="Are you sure you want to do this?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Machine Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="device_ip"/>
                            <field name="port_no"/>
                            <field name="address_id"/>
                        </group>
                        <group>
                            <field name="is_attendance_machine"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <button name="action_test_connection"
                            type="object" class="btn btn-secondary">
                        <i class="fa fa-fw o_button_icon fa-television"/>
                        Test Connection
                    </button>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_zk_machine_tree" model="ir.ui.view">
        <field name="name">zk.machine.tree</field>
        <field name="model">zk.machine</field>
        <field name="arch" type="xml">
            <list string="Biometric Machine">
                <field name="name"/>
                <field name="device_ip"/>
                <field name="port_no"/>
                <field name="address_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_zk_analysis_form" model="ir.ui.view">
        <field name="name">zk.machine.attendance.form</field>
        <field name="model">zk.machine.attendance</field>
        <field name="arch" type="xml">
            <form edit="false" string="Machine Analysis" create="0" delete="0">
                <header>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="machine_code"/>
                            <field name="device_id"/>
                            <field name="employee_id" string="Employee"/>
                            <field name="punching_time"/>
                            <field name="punching_date"/>
                            <field name="punch_type"/>
                            <field name="attendance_type"/>
                            <field name="atten_mode"/>
                        </group>
                        <group>
                            <field name="is_attendance_machine"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_zk_analysis_tree" model="ir.ui.view">
        <field name="name">zk.machine.attendance.tree</field>
        <field name="model">zk.machine.attendance</field>
        <field name="arch" type="xml">
            <list string="Machine Analysis" create="1" delete="0">
                <field name="machine_code"/>
                <field name="device_id"/>
                <field name="employee_id" string="Employee"/>
                <field name="punching_time"/>
                <field name="punching_date"/>
                <field name="punch_type"/>
                <field name="attendance_type" optional="hide"/>
                <field name="is_attendance_machine" optional="hide"/>
                <field name="atten_mode" optional="hide"/>
                <field name="zk_process_status"/>
            </list>
        </field>
    </record>

    <record id="zk_machine_action" model="ir.actions.act_window">
        <field name="name">Device Configuration</field>
        <field name="res_model">zk.machine</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="zk_analysis_action" model="ir.actions.act_window">
        <field name="name">Attendance Log</field>
        <field name="res_model">zk.machine.attendance</field>
        <field name="view_mode">list</field>
    </record>

    <record id="hr_employee_inherit_form_view" model="ir.ui.view">
        <field name="name">hr.employee.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='department_id']" position="after">
                    <field name="device_id"/>
                </xpath>
            </data>
        </field>
    </record>

    <record id="hr_employee_inherit_tree_view" model="ir.ui.view">
        <field name="name">hr.employee.tree</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="before">
                <field name="device_id" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="view_zk_analysis_search" model="ir.ui.view">
        <field name="name">zk.machine.attendance.search</field>
        <field name="model">zk.machine.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Attendance Logs">
                <field name="employee_id"/>
                <field name="machine_code"/>
                <field name="device_id"/>
                <filter string="Unprocessed" name="unprocessed" domain="[('zk_process_status','=','unprocessed')]"/>
                <filter string="Processed" name="processed" domain="[('zk_process_status','=','processed')]"/>
            </search>
        </field>
    </record>

    <menuitem id="zk_machine_menu" parent="hr_attendance.menu_hr_attendance_root" sequence="50"
              name="Biometric Manager"/>
    <menuitem id="zk_machine_sub_menu" parent="zk_machine_menu" name="Device Configuration" action="zk_machine_action"
              sequence="1"/>
    <menuitem id="zk_machine_sub_menu2" parent="zk_machine_menu" name="Attendance Log" action="zk_analysis_action"
              sequence="2"/>
</odoo>

