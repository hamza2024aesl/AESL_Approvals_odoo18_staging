<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <template id="report_salary_through_cheque">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="ivis_payroll_functions.packing_header_diff"/>
                    <div class="page">
                        <span align="center" style="font-color: black">
                            <h2>Salaries Through Cheque</h2>
                        </span>
                        <t t-as="rec" t-foreach="doc.get_date_name()">
                            <span align="center" style="font-color: black">
                                <h3>List of Employees Salary for
                                    <span t-esc="rec['month2']"/>
                                </h3>
                            </span>
                        </t>
                        <br/>
                        <span align="left" style="font-color: black">
                            <h4>Date
                                <span t-esc="doc.current_date"/>
                            </h4>
                        </span>
                        <table style="max-width:100%; width:100%;">
                            <thead>
                                <tr t-attf-style="page-break-inside: avoid !important;padding:5px 10px; font-weight:bold; color: black};">
                                    <td align="right"
                                        t-attf-style="width:10%; font-weight:bold;color:black;" colspan="2">
                                        <span>S No.</span>
                                    </td>
                                    <td align="center"
                                        t-attf-style="width:30%; font-weight:bold;color:black;" colspan="2">
                                        <span>Employee Name</span>
                                    </td>
                                    <td align="center"
                                        t-attf-style="width:20%; font-weight:bold;color:black;" colspan="2">
                                        <span>Designation</span>
                                    </td>
                                    <td align="center"
                                        t-attf-style="width:20%; font-weight:bold;color:black;" colspan="2">
                                        <span>Location</span>
                                    </td>
                                    <td align="right"
                                        t-attf-style="width:20%; font-weight:bold;color:black;" colspan="2">
                                        <span>Amount</span>
                                    </td>
                                </tr>
                            </thead>
                            <tbody>
                                <style>
                                    .bb td{
                                    border-bottom: 1px solid black !important;
                                    border-left: 1px solid black !important;
                                    border-right: 1px solid black !important;
                                    border-top: 1px solid black !important;
                                    padding-left:10px;
                                    }
                                    .aa td{
                                    border-top: 1px solid black !important;
                                    }
                                    img.wrap {float: left !important}
                                </style>
                                <t t-as="rec" t-foreach="doc.get_salaries_through_cheque()">
                                    <tr class="bb" style="font-size:13px; font-color: black;">
                                        <t t-as="l" t-foreach="rec['data']">
                                            <tr class="bb" style="font-size:13px; font-color: black;">
                                                <td align="right" t-attf-style="width:10%;" colspan="2">
                                                    <span t-esc="l_index + 1"/>
                                                </td>
                                                <td align="left" t-attf-style="width:30%;" colspan="2">
                                                    <span t-esc="l[0]"/>
                                                </td>
                                                <td align="left" t-attf-style="width:20%;" colspan="2">
                                                    <span t-esc="l[1]"/>
                                                </td>
                                                <td align="left" t-attf-style="width:20%;" colspan="2">
                                                    <span t-esc="l[2]"/>
                                                </td>


                                                <td align="right" t-attf-style="width:20%;" colspan="2">

                                                    <span t-esc="'{:,}'.format(l[3])"
                                                          t-esc-options='{"widget": "monetary", "display_currency": doc.current_company.currency_id}'/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tr>
                                    <tr style="font-size:13px; font-color: black;">
                                        <td class="bb" align="center" t-attf-style="width:10%;font-weight:bold;"
                                            colspan="2">
                                        </td>
                                        <td class="bb" align="center" t-attf-style="width:30%;font-weight:bold;"
                                            colspan="2">
                                        </td>
                                        <td class="bb" align="center" t-attf-style="width:20%;font-weight:bold;"
                                            colspan="2">
                                        </td>
                                        <td class="bb" align="right" t-attf-style="width:20%;font-weight:bold;"
                                            colspan="2">
                                            <p>Total Rs:</p>
                                        </td>


                                        <td class="bb" align="right" t-attf-style="width:20%;font-weight:bold;"
                                            colspan="2">
                                            <span t-esc="'{:,}'.format(rec['total'])"
                                                  t-esc-options='{"widget": "monetary", "display_currency": doc.current_company.currency_id}'/>
                                        </td>

                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <br/>
                        <br/>
                        <br/>
                        <br/>
                        <table>
                            <style>
                                .zz td{
                                border-top: 1px solid black;
                                width:220px;
                                }
                            </style>
                            <tr class="zz" style="font-size:13px; font-color: black;">
                                <td align="center"
                                    t-attf-style=" font-weight:bold;color:black;" colspan="2">Prepared By
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>