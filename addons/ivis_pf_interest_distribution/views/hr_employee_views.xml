<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="employee_pf_inherit" model="ir.ui.view">
            <field name="name">hr.employee.inherit.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="compute_funds_pf" string="Compute PF Funds" type="object" class="oe_highlight"/>
                </xpath>
                <xpath expr="//notebook/page[@name='hr_settings']" position="after">
                    <page name="provident_fund" string="Provident Funds" groups="hr.group_hr_user">
                        <group>
                            <label for="apply_provident_fund" string="Apply Provident Fund"/>
                            <field name="apply_provident_fund" string="Apply Provident Fund"/>
                            <group string="Provident Funds" name="provident_funds" invisible="not apply_provident_fund">
                                <field name="exclude_pf_interest" string="Exclude Interest"/>
                                <field name="employee_contribution"/>
                                <field name="employer_contribution"/>
                                <field name="interest"/>
                                <field name="total"/>
                            </group>
                            <group string="Opening Provident Funds" invisible="not apply_provident_fund">
                                <field name="pf_employee" readonly="1"/>
                                <field name="pf_employer" readonly="1"/>
                                <field name="pf_interest" readonly="1"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>