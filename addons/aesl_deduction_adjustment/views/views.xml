<odoo>
    <data>
        <record model="ir.actions.server" id="get_process_deductions">
            <field name="name">Process Deductions</field>
            <field name="model_id" ref="model_hr_contract"/>
            <field name="binding_model_id" ref="model_hr_contract"/>
            <field name="state">code</field>
            <field name="code">
                model.process_deductions()
            </field>
        </record>

        <record id="inherit_contract" model="ir.ui.view">
            <field name="model">hr.contract</field>
            <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='top_info_right']/field[@name='structure_type_id']"
                       position="inside">
                    <field name="registration_num"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
