<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="view_my_change_request_list" model="ir.ui.view">
            <field name="name">My.Change.Request.list</field>
            <field name="model">my.change.request</field>
            <field name="arch" type="xml">
                <list string="Change Requests">
                    <field name="name"/>
                    <field name="reason"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <record id="view_my_change_request_view" model="ir.ui.view">
            <field name="name">view_request_form</field>
            <field name="model">my.change.request</field>
            <field name="arch" type="xml">
                <form string="Change Request" version="8.0">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,first,second,done,rejected"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name" invisible="1"/>
                            <field name="manager" invisible="1"/>
                            <field name="my_manager" invisible="1"/>
                            <field name="attendance_id" readonly="1"/>
                            <field name="reason" required="1" readonly="state in ['first', 'second', 'done']"/>
                            <field name="description" readonly="state in ['done', 'rejected']"/>
                            <field name="new_check_in" required="1" readonly="state in ['done']"/>
                            <field name="new_check_out" required="1" readonly="state in ['done']"/>
                            <field name="new_shift" required="1" readonly="state in ['done']"/>
                        </group>
                        <footer>
                            <button name='generate_request' string='Submit' type='object'
                                    invisible="state in ['first', 'second', 'done']" class="oe_highlight"/>
                            <span invisible="state in ['first', 'second', 'done', 'rejected']">OR</span>
                            <button name='save_request' string='Save' type='object'
                                    invisible="state in ['first', 'second', 'done', 'rejected']" class="oe_highlight"/>
                            <button name='vlidate_request_manager' string='Validate' type='object' class="oe_highlight"
                                    invisible="my_manager == False or state in ['new', 'draft', 'second', 'done', 'rejected']"/>
                            <button name='reject_request_manager' string='REJECT' type='object'
                                    invisible="my_manager == False or state in ['new', 'draft', 'second', 'done', 'rejected']"
                                    class="btn btn-danger"/>
                            <button name='vlidate_request_hr' string='Validate' type='object'
                                    groups="hr.group_hr_manager" class="oe_highlight"
                                    invisible="state in ['new', 'draft', 'first', 'done', 'rejected']"/>
                            <button name='reject_request_hr' string='REJECT' type='object' groups="hr.group_hr_manager"
                                    invisible="state in ['new', 'draft', 'first', 'done', 'rejected']"
                                    class="btn btn-danger"/>
                        </footer>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"
                               groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_resource_calendar_attendance_list" model="ir.ui.view">
            <field name="name">resource.calendar.attendance.list</field>
            <field name="model">resource.calendar.attendance</field>
            <field name="arch" type="xml">
                <list string="Working Time" editable="top">
                    <field name="name"/>
                    <field name="dayofweek"/>
                    <field name="hour_from"/>
                    <field name="hour_to"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </list>
            </field>
        </record>

        <record id="view_resource_calendar_attendance_form" model="ir.ui.view">
            <field name="name">resource.calendar.attendance.form</field>
            <field name="model">resource.calendar.attendance</field>
            <field name="arch" type="xml">
                <form string="Working Time">
                    <group>
                        <field name="name"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="dayofweek"/>
                        <label for="hour_from" string="Hours"/>
                        <div>
                            <field name="hour_from" class="oe_inline"/>
                            -
                            <field name="hour_to" class="oe_inline"/>
                        </div>
                    </group>
                </form>
            </field>
        </record>

        <record id="change_request_action" model="ir.actions.act_window">
            <field name="name">Change Requests</field>
            <field name="res_model">my.change.request</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="change_request_action_menu"
                  action="change_request_action"
                  parent="hr_attendance.menu_hr_attendance_root"
                  name="Change Requests"
                  sequence="21"
                  groups="hr_attendance.group_hr_attendance_manager,hr_attendance.group_hr_attendance_own_reader,hr_attendance.group_hr_attendance_officer"/>
    </data>
</odoo>