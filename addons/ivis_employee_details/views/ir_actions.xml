<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="action_program_ga" model="ir.actions.act_window">
        <field name="name">Final Settlement Batch</field>
        <field name="res_model">hr.payslip.run</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('final_settlement', '=', True)]</field>
        <field name="context">{'default_final_settlement':True}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create a payslip!</p>
        </field>
    </record>

    <record id="action_program" model="ir.actions.act_window">
        <field name="name">Final Settlement Payslip</field>
        <field name="res_model">hr.payslip</field>
        <field name="domain">[('settlement_payslip', '=', True)]</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">Create a payslip!</p>
        </field>
    </record>

    <record id="hr_payroll.action_hr_payslip_run_tree" model="ir.actions.act_window">
        <field name="domain">[('final_settlement', '=', False)]</field>
    </record>

    <record id="act_program_tree_view" model="ir.actions.act_window.view">
        <field eval="1" name="sequence"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="ivis_employee_details.hr_view_payslip_settlement"/>
        <field name="act_window_id" ref="action_program_ga"/>
    </record>

    <record id="act_program_form_view" model="ir.actions.act_window.view">
        <field eval="2" name="sequence"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="ivis_employee_details.hr_payslip_run_form"/>
        <field name="act_window_id" ref="action_program_ga"/>
    </record>

    <menuitem id="menu_hr_payslip_settlement"
              name="Final Settlement Payslip"
              parent="hr_payroll.menu_report_payroll"
              groups="hr.group_hr_manager"/>

    <menuitem id="menu_slip"
              name="Menu 1"
              action="action_program"
              parent="menu_hr_payslip_settlement"
              groups="hr.group_hr_manager"
              sequence="1"/>

    <menuitem id="menu_settle"
              name="Menu 2"
              action="action_program_ga"
              parent="menu_hr_payslip_settlement"/>
</odoo>