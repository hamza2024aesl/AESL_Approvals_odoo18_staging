<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_hr_payslip_generate_new" model="ir.ui.view">
        <field name="name">hr_payslip_generate</field>
        <field name="model">hr.payslip.employees</field>
        <field name="arch" type="xml">
            <form string="Payslips">
                <header>
                    <button icon="fa-cogs" string="Generate" name="compute_sheet" type="object" class="oe_highlight"/>
                </header>
                <group>
                    <span colspan="4" nolabel="1">This wizard will generate payslips for all the employee(s) with their
                        resignation approved .
                    </span>
                </group>
            </form>
        </field>
    </record>

    <record id="action_payslip_generate_new" model="ir.actions.act_window">
        <field name="name">Generate Payslips</field>
        <field name="res_model">hr.payslip.employees</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_hr_payslip_generate_new"/>
        <field name="target">new</field>
    </record>
</odoo>