        <!--                ['|',-->
        <!--                ('increment_raise_id.employee_id.user_id', '=', user.id),-->
        <!--                ('increment_raise_id.employee_id', 'child_of', [user.employee_id.id])-->
        <!--                ]-->
        <!--            </field>-->
        <!--        </record>-->

    </data>
</odoo>
