<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="mail_template_confirm_appraisals_manager" model="mail.template">
            <field name="name">Hr Appraisal: Confirm Appraisal to Manager</field>
            <field name="model_id" ref="aesl_appraisal_system.model_appraisal_system"/>
            <field name="subject">${object.employee_id.name}: Confirm Appraisal</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;">
                        Dear ${ctx.get('employee_to_name', 'employee')},
                        <br/>
                        <br/>
                        Please confirm the requested appraisal.
                        <br/>
                        <br/>
                        Thank you!
                        <br/>
                        <br/>
                        % if ctx.get('recipient_users'):
                        <p style="margin: 16px 0px 16px 0px;">
                            <a href="${ctx['url']}"
                               style="background-color:#875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px;">
                                View Appraisal
                            </a>
                        </p>
                        % endif
                        <br/>
                        <br/>
                        <tr>
                            <td style="padding:15px 20px 10px 20px;">${(object.signature or '')| safe}</td>
                        </tr>
                    </p>
                </div>
            </field>
            <field name="template_fs">${(object.name or '').replace('/','_')}</field>
            <field name="lang">${object.lang}</field>
            <field name="auto_delete" eval="True"/>
        </record>

