<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="view_manager_summary_report_wizard" model="ir.ui.view">
        <field name="name">view.manager.summary.wizard</field>
        <field name="model">manager.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Employee Report">
                <group>
                    <field name="employee_id" readonly="1"/>
                </group>
                <footer>
                    <button string="Print" type="object" name="print_report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_print_manager_summary_report_wizard" model="ir.actions.act_window">
        <field name="name">Manager Summary Report Wizard</field>
        <field name="res_model">manager.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_appraisal_summary_report"
              name="Appraisal System"
              sequence="10"/>

    <menuitem name="Summarize Report"
              id="menu_appraisal_manager_summary_report"
              parent="menu_appraisal_summary_report"
              action="aesl_appraisal_system.action_print_manager_summary_report_wizard"
              sequence="11"/>
</odoo>
