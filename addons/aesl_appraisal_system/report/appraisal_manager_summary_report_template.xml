<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <template id="appraisal_manager_summary_layout_header">
            <t t-call="aesl_appraisal_system.appraisal_manager_summary_header"/>
            <t t-raw="0"/>
        </template>

        <template id="appraisal_manager_summary_header">
            <div class="header">
                <strong>
                    <h3 class="text-center">Allied Engineering &amp; Service Pvt. Ltd.</h3>
                </strong>
                <h3 class="text-center">Manager's Employee summary Report</h3>
            </div>
        </template>

        <template id="template_appraisal_manager_summary_report">
            <t t-call="web.basic_layout">
                <t t-call="aesl_appraisal_system.appraisal_manager_summary_layout_header"/>
                <div class="page" style="page-break-before:always;">
                    <div style="width:100%;">
                        <table style="width:100%; border:1px solid black;">
                            <thead style="text-align:center;">
                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th style="border:1px solid black;" colspan="5">Existing</th>
                                    <th style="border:1px solid black;" colspan="5">Recommended</th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                </tr>
                                <tr>
                                    <th style="border:1px solid black;" rowspan="2">S.NO.</th>
                                    <th style="border:1px solid black;" rowspan="2" colspan="2">Employee Name</th>
                                    <th style="border:1px solid black;">Employee No.</th>
                                    <th style="border:1px solid black;" rowspan="2" colspan="2">Salary</th>
                                    <th style="border:1px solid black;">Grade</th>
                                    <th style="border:1px solid black;" colspan="2">Designation</th>
                                    <th style="border:1px solid black;">Increment</th>
                                    <th style="border:1px solid black;">Salary</th>
                                    <th style="border:1px solid black;">Grade</th>
                                    <th style="border:1px solid black;" colspan="2">Designation</th>
                                    <th style="border:1px solid black;">Percentage</th>
                                    <th style="border:1px solid black;" colspan="2">State</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="i" t-value="1"/>
                                <t t-set="total_salary" t-value="0"/>
                                <t t-set="total_recomm_salary" t-value="0"/>
                                <t t-set="total_recomm_salary1" t-value="0"/>
                                <t t-set="total_recomm_salary_percentage" t-value="0"/>
                                <t t-foreach="records" t-as="line">
                                    <tr>
                                        <td style="border:1px solid black; text-align:center;">
                                            <span t-esc="i"/>
                                        </td>
                                        <td style="border:1px solid black;" colspan="2">
                                            <a t-att-href="line['url']" target="_blank">
                                                <span t-esc="line['emp_name']"/>
                                            </a>
                                        </td>

                                        <td style="border:1px solid black;  text-align:center;">
                                            <span t-esc="line['emp_no']"/>
                                        </td>
                                        <td style="border:1px solid black;" colspan="2">
                                            <span t-esc="line['curr_salary']"/>
                                            <t t-set="total_salary" t-value="line['curr_salary']+total_salary"/>
                                        </td>
                                        <td style="border:1px solid black;  text-align:center;">
                                            <span t-esc="line['curr_grade']"/>
                                        </td>
                                        <td style="border:1px solid black;" colspan="2">
                                            <span t-esc="line['curr_designation']"/>
                                        </td>
                                        <td style="border:1px solid black;">
                                            <span t-esc="line['recomm_raise_amount']"/>
                                            <t t-set="total_recomm_salary1"
                                               t-value="line['recomm_raise_amount']+total_recomm_salary1"/>
                                        </td>

                                        <td style="border:1px solid black;">
                                            <span t-esc="line['recomm_salary']"/>
                                            <t t-set="total_recomm_salary"
                                               t-value="line['recomm_salary'] + total_recomm_salary"/>
                                        </td>
                                        <td style="border:1px solid black;  text-align:center;">
                                            <span t-esc="line['recomm_grade']"/>
                                        </td>
                                        <td style="border:1px solid black;" colspan="2">
                                            <span t-esc="line['recomm_designation']"/>
                                        </td>
                                        <td style="border:1px solid black;  text-align:center;">
                                            <span t-esc="'{:.1f}'.format(line['percentage'])"/>%
                                            <t t-set="total_recomm_salary_percentage"
                                               t-value="line['percentage'] + total_recomm_salary_percentage"/>
                                        </td>
                                        <td style="border:1px solid black;  text-align:center;" colspan="2">
                                            <span t-esc="line['doc_state']"/>
                                        </td>
                                    </tr>
                                    <t t-set="i" t-value="i+1"/>
                                </t>
                                <tr>
                                    <td style="border:1px solid black;" colspan="4">
                                        <center>
                                            <b>Total</b>
                                        </center>
                                    </td>
                                    <td style="border:1px solid black;" colspan="2">
                                        <b>
                                            <span t-esc="total_salary"/>
                                        </b>
                                    </td>
                                    <td style="border:1px solid black;">
                                    </td>
                                    <td style="border:1px solid black;" colspan="2">
                                    </td>
                                    <td style="border:1px solid black;">
                                        <b>
                                            <span t-esc="total_recomm_salary1"/>
                                        </b>
                                    </td>
                                    <td style="border:1px solid black;">
                                        <b>
                                            <span t-esc="total_recomm_salary"/>
                                        </b>
                                    </td>
                                    <td style="border:1px solid black;">
                                    </td>
                                    <td style="border:1px solid black;" colspan="2">
                                    </td>
                                    <td style="border:1px solid black; text-align:center;">
                                        <b>
                                            <span t-esc="'{:.1f}'.format(((total_recomm_salary - total_salary)/total_salary)*100)"/>
                                        </b>
                                        %
                                    </td>
                                    <td style="border:1px solid black;" colspan="2"></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </t>
        </template>
    </data>
</odoo>