<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <template id="payslip_list_view_portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1" style="margin-right:auto">Payslips</h3>
                <div class="btn-group ms-auto payslip-groupby-container">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Group By
                    </button>
                    <div class="dropdown-menu p-3">
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-payslip" type="checkbox" value="month"
                                   id="groupByMonth"/>
                            <label class="form-check-label" for="groupByMonth">Month</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-payslip" type="checkbox" value="year"
                                   id="groupByYear"/>
                            <label class="form-check-label" for="groupByYear">Year</label>
                        </div>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                </t>
            </div>
            <br/>
            <t t-if="not payslips">
                <p class="alert alert-warning">There are currently no payslips.</p>
            </t>
            <t t-call="portal.portal_table">
                <t t-if="payslips">
                    <thead>
                        <th>Payslip Number</th>
                        <th>Employee</th>
                        <th>Batch Name</th>
                        <th class="text-right">Net Wage</th>
                        <th class="text-center">Status</th>
                        <th/>
                    </thead>
                    <tbody>
                        <t t-foreach="grouped_payslips.items()" t-as="group" t-if="grouped_payslips">
                            <tr class="bg-light">
                                <td colspan="11">
                                    <button class="btn btn-link btn-sm payslip-expand-btn"
                                            t-att-data-group-id="group[0]">
                                        <i class="fa fa-plus payslip-expand-icon"/>
                                    </button>
                                    <strong>
                                        <t t-if="group_by == 'month'">
                                            Month:
                                            <t t-out="group[0]"/>
                                        </t>
                                        <t t-elif="group_by == 'year'">
                                            Year:
                                            <t t-out="group[0]"/>
                                        </t>
                                    </strong>
                                </td>
                            </tr>
                            <t t-foreach="sorted(group[1], key=lambda p: p.payslip_run_id.id, reverse=True)"
                               t-as="payslip">
                                <tr t-attf-data-group-id="{{group[0]}}" class="payslip-group-row"
                                    style="display: none;">
                                    <td style="padding-left: 25px;">
                                        <span t-out="payslip.number"/>
                                    </td>
                                    <td>
                                        <t t-out="payslip.employee_id.name"/>
                                    </td>
                                    <td>
                                        <t t-out="payslip.payslip_run_id.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-if="payslip.net_wage == 0" t-out="payslip.net_wage"
                                              t-options='{"widget": "monetary", "display_currency": payslip.currency_id}'
                                              style="color:red"/>
                                        <span t-else="" t-out="payslip.net_wage"
                                              t-options='{"widget": "monetary", "display_currency": payslip.currency_id}'/>
                                    </td>
                                    <td class="text-center">
                                        <span style="color:rgb(23, 162, 184); font-style:italic">
                                            <t t-out="payslip.state"/>
                                        </span>
                                    </td>
                                    <td class="text-right">
                                        <a t-attf-href="/my/payslips/view/{{payslip.id}}" title="Open Payslip"
                                           aria-label="Open Payslip" class="btn btn-sm btn-primary" role="button">
                                            <i class="fa fa-arrow-circle-right"/>
                                            <span class='d-none d-md-inline'>Open Payslip</span>
                                        </a>
                                    </td>
                                </tr>
                            </t>
                        </t>

                        <t t-foreach="sorted(payslips, key=lambda p: p.payslip_run_id.id, reverse=True)" t-as="payslip"
                           t-if="payslips and not grouped_payslips">
                            <tr>
                                <td>
                                    <span t-out="payslip.number"/>
                                </td>
                                <td>
                                    <t t-out="payslip.employee_id.name"/>
                                </td>
                                <td>
                                    <t t-out="payslip.payslip_run_id.name"/>
                                </td>
                                <td class="text-right">
                                    <span t-if="payslip.net_wage == 0" t-out="payslip.net_wage"
                                          t-options='{"widget": "monetary", "display_currency": payslip.currency_id}'
                                          style="color:red"/>
                                    <span t-else="" t-out="payslip.net_wage"
                                          t-options='{"widget": "monetary", "display_currency": payslip.currency_id}'/>
                                </td>
                                <td class="text-center">
                                    <span style="color:rgb(23, 162, 184); font-style:italic">
                                        <t t-out="payslip.state"/>
                                    </span>
                                </td>
                                <td class="text-right">
                                    <a t-attf-href="/my/payslips/view/{{payslip.id}}" title="Open Payslip"
                                       aria-label="Open Payslip" class="btn btn-sm btn-primary" role="button">
                                        <i class="fa fa-arrow-circle-right"/>
                                        <span class='d-none d-md-inline'>Open Payslip</span>
                                    </a>
                                </td>
                                <!--                                <td class="text-right">-->
                                <!--                                    <t>-->
                                <!--                                        <span t-if="payslip.state == 'done'"-->
                                <!--                                              class="badge rounded-pill text-bg-success w80">-->
                                <!--                                            <i class="fa fa-fw fa-check" aria-label="Done" title="Done"-->
                                <!--                                               role="img"/>-->
                                <!--                                            <span class="d-none d-md-inline">Done</span>-->
                                <!--                                        </span>-->
                                <!--                                        <span t-if="payslip.state == 'verify'"-->
                                <!--                                              class="badge rounded-pill text-bg-warning w80">-->
                                <!--                                            <i class="fa fa-fw fa-clock-o" aria-label="Waiting" title="Waiting"-->
                                <!--                                               role="img"/>-->
                                <!--                                            <span class="d-none d-md-inline">Waiting</span>-->
                                <!--                                        </span>-->
                                <!--                                        <span t-if="payslip.state == 'draft'"-->
                                <!--                                              class="badge rounded-pill text-bg-info w80">-->
                                <!--                                            <i class="fa fa-fw fa-arrow-circle-right" aria-label="Draft"-->
                                <!--                                               title="Draft" role="img"/>-->
                                <!--                                            <span class="d-none d-md-inline">Draft</span>-->
                                <!--                                        </span>-->
                                <!--                                        <span t-if="payslip.state == 'cancel'"-->
                                <!--                                              class="badge rounded-pill text-bg-danger w80">-->
                                <!--                                            <i class="fa fa-fw fa-remove" aria-label="Rejected" title="Rejected"-->
                                <!--                                               role="img"/>-->
                                <!--                                            <span class="d-none d-md-inline">Rejected</span>-->
                                <!--                                        </span>-->
                                <!--                                        <span t-if="payslip.state == 'paid'"-->
                                <!--                                              class="badge rounded-pill text-bg-primary w80">-->
                                <!--                                            <i class="fa fa-fw fa-check" aria-label="Paid" title="Paid"-->
                                <!--                                               role="img"/>-->
                                <!--                                            <span class="d-none d-md-inline">Paid</span>-->
                                <!--                                        </span>-->
                                <!--                                    </t>-->
                                <!--                                </td>-->
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </t>
    </template>

