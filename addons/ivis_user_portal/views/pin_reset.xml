<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="reset_pin_template" inherit_id="portal.side_content">
        <xpath expr="//a[contains(@href, '/my/account')]" position="attributes">
            <attribute name="class">d-none</attribute>
        </xpath>
        <xpath expr="//a[@href='/my/account']" position="after">
            <br/>
            <a role="button" href="#" data-bs-toggle="modal" data-bs-target="#reset_pin_modal" t-if="allow_pin_change">
                <i class="fa fa-key"></i>
                Reset PIN
            </a>

            <div class="modal fade" id="reset_pin_modal" tabindex="-1" aria-labelledby="reset_pin_modal_title"
                 aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="reset_pin_modal_title">Reset PIN</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="reset_pin_form" method="post" action="/change_pin">
                                <div class="row o_portal_details">
                                    <div>
                                        <div class="row">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="current_pin">
                                                    Current PIN
                                                </label>
                                                <input
                                                        type="password"
                                                        id="current_pin_id"
                                                        name="current_pin"
                                                        t-attf-class="form-control description-input"
                                                        placeholder="Current PIN"
                                                        maxlength="4"
                                                />
                                            </div>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="new_pin">
                                                    New PIN
                                                </label>
                                                <input
                                                        type="password"
                                                        id="new_pin_id"
                                                        name="new_pin"
                                                        t-attf-class="form-control description-input"
                                                        placeholder="New PIN"
                                                        maxlength="4"
                                                />
                                            </div>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="confirm_pin">
                                                    Confirm PIN
                                                </label>
                                                <input
                                                        type="password"
                                                        id="confirm_pin_id"
                                                        name="confirm_pin"
                                                        t-attf-class="form-control description-input"
                                                        placeholder="Confirm PIN"
                                                        maxlength="4"
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" form="reset_pin_form" class="btn btn-primary">
                                Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>