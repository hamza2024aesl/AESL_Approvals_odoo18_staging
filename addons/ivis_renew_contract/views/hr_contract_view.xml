<odoo>
    <record id="hr_contract_list_view_inherit" model="ir.ui.view">
        <field name="name">hr.contract.view.tree</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_payroll.hr_contract_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button
                        name="action_process_fiscal_end_date"
                        type="object"
                        string="New Fiscal Contract"
                        class="oe_highlight"
                        display="always"/>
                </header>
            </xpath>
        </field>
    </record>
</odoo>
