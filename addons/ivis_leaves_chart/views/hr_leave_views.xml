<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="timeoff_inherited_request_form" model="ir.ui.view">
            <field name="name">Time Off Inherited Request Form</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <field name="hr_leave_lines_id" options="{'no_create': True, 'no_open': True}" nolabel="1" required="1">
                        <list class="o_list_view_table" delete="0" force_save="1" string="Family Mamber Lines">
                            <field name="leave_type" force_save="1"/>
                            <field name="available_leave" force_save="1"/>
                            <field name="availed_leave" force_save="1"/>
                            <field name="balance_leave" force_save="1"/>
                        </list>
                    </field>
                </xpath>
            </field>
        </record>

        <record id="timeoff_inherited_form" model="ir.ui.view">
            <field name="name">Time Off Inherited Form</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('o_hr_leave_column') and hasclass('col_right')]" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>