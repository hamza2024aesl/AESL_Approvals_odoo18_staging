<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="approval_request_view_form_inherit" model="ir.ui.view">
        <field name="name">approval.request.view.form.inherit</field>
        <field name="model">approval.request</field>
        <field name="inherit_id" ref="approvals.approval_request_view_form"/>
        <field name="arch" type="xml">
            <!-- Hide standard groups -->
            <xpath expr="//group[@name='request_main']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='request_details']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//notebook" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            
            <!-- Category is kept visible as it's mandatory -->
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="required">1</attribute>
            </xpath>

            <!-- Positioning custom sections BEFORE the notebook -->
            <xpath expr="//notebook" position="before">
                <!-- 1. Employee Section -->
                <group name="employee_section_exclusive" string="Employee Section" class="mt-2" col="2">
                    <group>
                        <field name="category_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="employee_id" required="1" options="{'no_create': True}"/>
                        <field name="employee_reg_no"/>
                        <field name="employee_location_id"/>
                    </group>
                    <group>
                        <field name="employee_department_id"/>
                        <field name="employee_cnic"/>
                        <field name="employee_dob"/>
                        <field name="employee_designation_id"/>
                        <field name="employee_mobile"/>
                    </group>
                </group>

                <!-- 1.5 Period Section (Using Standard Odoo Fields to avoid validation errors) -->
                <group name="period_section" string="Period Section" class="mt-3">
                    <group>
                        <field name="date_start" string="Date From" required="1"/>
                    </group>
                    <group>
                        <field name="date_end" string="Date To" required="1"/>
                    </group>
                    <field name="time_off_id" invisible="not time_off_id"/>
                </group>

                <!-- 2. Travel Section -->
                <group name="travel_section" string="Travel Section" class="mt-3">
                    <field name="travel_mode" widget="radio" options="{'horizontal': True}"/>
                    <field name="travel_request_type" widget="radio" options="{'horizontal': True}"/>
                </group>

                <!-- 3. Note Section -->
                <group string="Important Notes" class="mt-3">
                    <div class="alert alert-warning" style="color: #856404; background-color: #fff3cd; border: 1px solid #ffeeba; border-left: 5px solid #ffc107; padding: 15px;">
                        <ul class="mb-0">
                            <li>1) If travel advance is required in T.C. this requisition must reach the Finance Department at least 72 hours in advance.</li>
                            <li>2) Admin Department will normally require 3 days notice to arrange tickets.</li>
                        </ul>
                    </div>
                </group>

                <!-- 4. Administration Section -->
                <group name="administration_section" string="Administration Section" class="mt-3">
                    <field name="admin_remarks"/>
                </group>
                
                <hr class="mt-4 mb-4" style="border-top: 1px solid #dee2e6;"/>
            </xpath>
        </field>
    </record>
</odoo>
