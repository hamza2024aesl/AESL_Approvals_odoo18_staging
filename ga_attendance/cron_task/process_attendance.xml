        <record model="ir.cron" id="fetch_attendance_ga_pyzk">
            <field name="name">Attendance: Fetch New</field>
            <field name="priority" eval="2"/>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 12:00:00')"/>
            <field name="state">code</field>
            <field name="model_id" ref="model_machine_data"/>
            <field name="code">model._CRON_fetch_attendance()</field>
        </record>

        <record model="ir.cron" id="process_attendance_ga">
            <field name="name">Attendance: Process</field>
            <field name="priority" eval="2"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 14:00:00')"/>
            <field name="state">code</field>
            <field name="model_id" ref="model_hr_attendance"/>
            <field name="code">model.process_attendance_ga()</field>
        </record>
    </data>
</odoo>