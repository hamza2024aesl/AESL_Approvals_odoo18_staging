<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="holidays_schedule_list" model="ir.ui.view">
        <field name="name">holidays.schedule.list</field>
        <field name="model">holidays.schedule</field>
        <field name="arch" type="xml">
            <list string="Holidays Schedule" editable="bottom" decoration-muted="passed == True">
                <field name="name" required="1"/>
                <field name="date" required="1"/>
                <field name="recurring"/>
                <field name="passed" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_holidays_schedule" model="ir.actions.act_window">
        <field name="name">Holidays Schedule</field>
        <field name="res_model">holidays.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_ga_holidays_schedule"
              name="Holidays Schedule"
              parent="hr_attendance.menu_hr_attendance_root"
              sequence="22"
              action="action_holidays_schedule"
              groups="hr_attendance.group_hr_attendance_own_reader,hr_attendance.group_hr_attendance_officer"/>
</odoo>