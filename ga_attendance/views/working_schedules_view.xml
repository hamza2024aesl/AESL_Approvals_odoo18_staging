<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="hr_workingschedules_inherited_view" model="ir.ui.view">
            <field name="name">Inherited view of working schedules</field>
            <field name="model">resource.calendar</field>
            <field name="inherit_id" ref="resource.resource_calendar_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="compensatory_hours" widget="float_time"/>
                    <field name="shift"/>
                    <field name="missed_in_out_duration" widget="float_time"/>
                    <field name="overtime_start" widget="float_time"/>
                    <field name="exclude" string="Exclude this duration?"/>
                </xpath>
                <xpath expr="//field[@name='attendance_ids']" position="before">
                    <group string='In Policy'>
                        <field name='in_policy_id' nolabel='1'>
                            <list editable='bottom'>
                                <field name="time_from" widget="float_time"/>
                                <field name="time_to" widget="float_time"/>
                                <field name="status"/>
                                <field name="action"/>
                            </list>
                        </field>
                    </group>
                    <group string='Out Policy'>
                        <field name='out_policy_id' nolabel='1'>
                            <list editable='bottom'>
                                <field name="time_from" widget="float_time"/>
                                <field name="time_to" widget="float_time"/>
                                <field name="status"/>
                                <field name="action"/>
                            </list>
                        </field>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>