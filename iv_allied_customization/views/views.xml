<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record model="ir.ui.view" id="iv_allied_customization.list">
            <field name="name">iv_allied_customization list</field>
            <field name="model">iv_allied_customization.iv_allied_customization</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="value"/>
                    <field name="value2"/>
                </list>
            </field>
        </record>

        <record id="view_hr_payslip_run_inherit" model="ir.ui.view">
            <field name="name">hr.payslip.run.inherit.form</field>
            <field name="model">hr.payslip.run</field>
            <field name="inherit_id" ref="hr_payroll_account.hr_payslip_run_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_draft']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
            </field>
        </record>

        <record model="ir.actions.act_window" id="iv_allied_customization.action_window">
            <field name="name">iv_allied_customization window</field>
            <field name="res_model">iv_allied_customization.iv_allied_customization</field>
            <field name="view_mode">list,form</field>
        </record>

        <record model="ir.actions.server" id="iv_allied_customization.action_server">
            <field name="name">iv_allied_customization server</field>
            <field name="model_id" ref="model_iv_allied_customization_iv_allied_customization"/>
            <field name="state">code</field>
            <field name="code">
                action = {
                "type": "ir.actions.act_window",
                "view_mode": "list,form",
                "res_model": model._name,
                }
            </field>
        </record>

        <menuitem name="iv_allied_customization" id="iv_allied_customization.menu_root"/>
        <menuitem name="Menu 1" id="iv_allied_customization.menu_1" parent="iv_allied_customization.menu_root"/>
        <menuitem name="Menu 2" id="iv_allied_customization.menu_2" parent="iv_allied_customization.menu_root"/>
        <menuitem name="List" id="iv_allied_customization.menu_1_list" parent="iv_allied_customization.menu_1" action="iv_allied_customization.action_window"/>
        <menuitem name="Server to list" id="iv_allied_customization" parent="iv_allied_customization.menu_2" action="iv_allied_customization.action_server"/>
    </data>
</odoo>