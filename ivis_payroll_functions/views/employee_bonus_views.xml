<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="list_employee_new_form" model="ir.ui.view">
            <field name="name">employee.bonus.view</field>
            <field name="model">employee.bonus</field>
            <field name="arch" type="xml">
                <form string="Employee Bonus" editable="bottom">
                    <sheet>
                        <group>
                            <group>
                                <field name="employee_code"/>
                                <field name="employee_id" width="50%"/>
                                <field name="bonus_amount" width="25%"/>
                                <field name="date_effective" width="25%" string="Date"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                    </div>
                </form>
            </field>
        </record>

        <record id="list_employee_new" model="ir.ui.view">
            <field name="name">employee.bonus.view</field>
            <field name="model">employee.bonus</field>
            <field name="arch" type="xml">
                <list string="Employee Bonus">
                    <field name="employee_id" width="50%"/>
                    <field name="bonus_amount" width="25%"/>
                    <field name="date_effective" width="25%" string="Date"/>
                </list>
            </field>
        </record>

        <record id="action_employee_new" model="ir.actions.act_window">
            <field name="name">Bonus</field>
            <field name="res_model">employee.bonus</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

        <menuitem id="bonus_screen_id" name="Bonus" parent="hr.menu_hr_root"
                  sequence="16" action="action_employee_new" groups="hr.group_hr_manager"/>
    </data>
</odoo>