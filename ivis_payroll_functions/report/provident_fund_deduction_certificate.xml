<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <template id="report_provident_fund_deduction_certificate">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-foreach="doc.payslip_amount_PF()" t-as="pf">
                        <span align="left" style="font-color: black">
                            <h4>Date :-
                                <span t-esc="doc.current_date"/>
                            </h4>
                        </span>
                        <t t-call="ivis_payroll_functions.packing_header_diff"/>
                        <div class="page" style="page-break-after: always;">
                            <span align="center" style="font-color: black;  font-size: 11px;">
                                <br></br>
                                <h1>PROVIDENT FUND DEDUCTION CERTIFICATE</h1>
                            </span>
                            <br></br>
                            <p style="font-size:17px;">This is certifies that Rs.<span
                                    t-esc="'{:,.2f}'.format(pf['total'])"/>/- have been deducted and deposited in the
                                Provident Fund account from the salary of
                                <span t-esc="pf['name']"/>
                                @ 10% of basic towards the contribution of Employees Provident Fund During the period
                                <span t-esc="doc.get_fiscal_date_start()"/>
                                to<span t-esc="doc.get_fiscal_date_end()"/>.
                            </p>
                            <br></br>
                            <h4>For
                                <span t-esc="doc.current_company.name.upper()"/>
                            </h4>
                            <br></br>
                            <br></br>
                            <table>
                                <tr style="font-size:17px; font-color: black;">
                                    <td align="center">
                                        <span t-esc="pf['position']"/>
                                    </td>
                                </tr>
                                <tr style="font-size:15px; font-color: black;">
                                    <td align="center"
                                        t-attf-style=" border-top: 1px solid black;width:220px; font-weight:bold;color:black;"
                                        colspan="2">CHIEF ACCOUNTANT
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>