<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="payslip_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h4 class="text-center" style="text-transform:uppercase;">Pay Slip</h4>
                        <h5 class="text-center">
                            <span style="text-transform:uppercase;">For the month of</span>
                            <span t-field="o.date_to" t-options='{"format":"MMMM yyyy"}'
                                  style="text-transform:uppercase;"/>

                        </h5>
                        <style>
                            td{
                            padding:5px !important;
                            }
                        </style>
                        <div class="row">

                            <t t-set="gross_pay_allowances" t-value="0"/>
                            <t t-set="total_deductions" t-value="0"/>
                            <t t-set="total" t-value="0"/>
                        </div>
                        <table class="table table-condensed table-bordered" style="font-size:12px;">
                            <tr>
                                <td>
                                    <span class="fa fa-list"/>
                                    <strong>Registration Number</strong>
                                </td>
                                <td>
                                    <t t-if="o.id">
                                        <span t-esc="o.employee_id.registration_number"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-map-marker"/>
                                    <strong>Location</strong>
                                </td>
                                <td colspan="3">
                                    <t t-if="o.employee_id.work_location_id">
                                        <div t-esc="o.employee_id.work_location_id.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-user"/>
                                    <strong>Name</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id">
                                        <span t-esc="o.employee_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-tag"/>
                                    <strong>CNIC No.</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.identification_id">
                                        <span t-esc="o.employee_id.identification_id"/>
                                    </t>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-building"/>
                                    <strong>Department</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.department_id.name">
                                        <span t-esc="o.employee_id.department_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-google-wallet"/>
                                    <strong>Bank</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.bank_account_id.bank_id.name">
                                        <span t-esc="o.employee_id.bank_account_id.bank_id.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-user-secret"/>
                                    <strong>Designation</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.job_id">
                                        <span t-esc="o.employee_id.job_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-money"/>
                                    <strong>Bank Account</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.bank_account_id.acc_number">
                                        <span t-esc="o.employee_id.bank_account_id.acc_number"/>
                                    </t>
                                </td>
                            </tr>

                            <tr t-foreach="o.rule_by_code(o.id,'AGROSS')" t-as="line">
                                <td>
                                    <span class="fa fa-calendar"/>
                                    <strong>Joining Date</strong>
                                </td>
                                <td>
                                    <t t-if="o.contract_id.date_start">
                                        <span t-field="o.contract_id.date_start"
                                              t-options='{"format":"dd/MM/yyyy"}'/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-street-view"/>
                                    <strong>Gross</strong>
                                </td>
                                <td>
                                    <!--                                    <span t-esc="'{:,}'.format(round(o.employee_id.contract_id.wage))"/>-->
                                    <span t-esc="'{:,}'.format(line['total'])"
                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>

                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-university"/>
                                    <strong>Grade</strong>
                                </td>
                                <td>
                                    <span t-esc="o.employee_id.contract_id.x_studio_grade"/>
                                </td>
                                <td>
                                </td>
                                <td>
                                </td>
                            </tr>
                        </table>
                        <div class="row" style="font-size:12px;">
                            <div class="col-6">
                                <t t-if="o.payslip(o.id,'Basic')">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <t t-if="o.payslip(o.id,'Basic')">
                                                    <td class="text-left" style="font-size:15px;">
                                                        <strong>Allowances</strong>
                                                    </td>
                                                    <td class="text-right" style="font-size:15px;">
                                                        <strong>Amount</strong>
                                                    </td>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.payslip(o.id,'Basic')" t-as="line">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(line['total'])"
                                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-if="o.payslip(o.id,'Basic Allowances')">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <t t-if="o.payslip(o.id,'Basic Allowances')">
                                                    <td style="font-size:15px;">
                                                        <strong>Basic Allowances</strong>
                                                    </td>
                                                    <td></td>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.payslip(o.id,'Basic Allowances')" t-as="line">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(line['total'])"
                                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <t t-if="o.payslip(o.id,'Gross')">
                                    <table class="table table-condensed">
                                        <thead>
                                            <tr>
                                                <t t-if="o.payslip(o.id,'Gross')">
                                                    <td style="font-size:15px;">
                                                        <strong>Gross</strong>
                                                    </td>
                                                    <td></td>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.payslip(o.id,'Gross')" t-as="line">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <!-- below code commented intenionally, purpose is to get value only from last iteration of loop-->
                                                <!--                                                <t t-set="gross_pay_allowances"-->
                                                <!--                                                    t-value="gross_pay_allowances+line['total']"/>-->
                                                <t t-set="gross_pay_allowances"
                                                   t-value="line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(round(line['total']))"
                                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <table class="table table-condensed">
                                    <thead>
                                        <tr>
                                            <t t-if="o.payslip(o.id,'Allowance')">
                                                <td style="font-size:15px;">
                                                    <strong>Special Allowances</strong>
                                                </td>
                                                <td></td>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'Allowance')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="gross_pay_allowances"
                                               t-value="gross_pay_allowances+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"
                                                      t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-condensed">
                                    <thead>
                                        <tr>
                                            <t t-if="o.payslip(o.id,'Deduction')">
                                                <td style="font-size:15px;">
                                                    <strong>Deductions</strong>
                                                </td>
                                                <td class="text-right" style="font-size:15px;">
                                                    <strong>Amount</strong>
                                                </td>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'Deduction')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"
                                                      t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'Total')" t-as="line">
                                            <t t-if="line['name']=='PF Loan'">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(line['total'])"
                                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </t>
                                        </tr>
                                    </tbody>
                                </table>
                                <table class="table table-condensed">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Total Deductions</strong>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,.2f}'.format(total_deductions)"
                                                      t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                    </thead>
                                </table>
                                <table class="table table-condensed">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Other Details</strong>
                                            </td>
                                            <td class="text-right" style="font-size:15px;">
                                                <strong>Amount</strong>
                                            </td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'Other')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"
                                                      t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row" style="font-size:12px;">
                            <div class="col-6">
                                <table class="table table-condensed">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Gross Pay and Allowances</strong>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(round(gross_pay_allowances))"
                                                      t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Net Pay (Rs)</strong>
                                            </td>
                                            <t t-foreach="o.payslip(o.id,'Net')" t-as="line">
                                                <t t-set="total" t-value="total+line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(-1 * round(line['total']))"
                                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                                                </td>
                                            </t>
                                        </tr>
                                    </thead>
                                </table>

                                <table class="table table-condensed">
                                    <tbody>
                                        <tr>
                                            <td colspan="2">
                                                <i>
                                                    <span t-esc="o.company_id.currency_id.amount_to_text(round(-1 * total))"/>
                                                </i>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6" style="font-size:12px;" t-if="int(o.employee_id.contract_id.x_studio_grade) &lt; 14">
                                <p style="font-size:15px;">
                                    <strong>LWP (Details)</strong>
                                </p>
                                <table class="table table-sm table-condensed">
                                    <thead>
                                        <tr>
                                            <th class="text-left">Date</th>
                                            <th class="text-right">Days</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.get_allied_lwp_days()" t-as="att">
                                            <tr>
                                                <td class="text-left">
                                                    <t t-esc="att['date']"/>
                                                </td>
                                                <td class="text-right">
                                                    <t t-esc="att['amt']"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <br/>
                        <small style="font-size:12px;">
                            <b>Note: This is a computer generated document, does not require signatures.</b>
                        </small>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="internal_layout_inherit" inherit_id="web.internal_layout">
        <xpath expr="//div[@class='header']" position="replace">
            <div class="header">
                <t t-if='res_company.name in "YourCompany"'>
                    <div class="row" style="margin-top:20px;">
                        <table style="width:100%;margin-bottom:20px;">
                            <tr>
                                <td style="width:25%;">
                                    <img t-att-src="'/ga_riztech_customization/static/description/RizLogo.png'"
                                         style="width:70%;height:30%;"/>
                                </td>
                                <td style="text-align:right;">
                                    <img t-att-src="'/ga_riztech_customization/static/description/address.png'"
                                         style="width:80%;height:15%;"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
                <t t-if="not res_company.name in  'YourCompany'">
                    <div class="o_boxed_header">
                        <div class="row mb8">
                            <div class="col-4">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" alt="Logo"/>
                            </div>
                            <div class="text-center">
                                <h4 class="mt0" t-field="res_company.report_header"/>
                                <div name="company_address">
                                    <span class="company_address" style="font-size:20px"
                                          t-field="res_company.partner_id"
                                          t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;], &quot;no_marker&quot;: true}"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>
        </xpath>
    </template>
</odoo>