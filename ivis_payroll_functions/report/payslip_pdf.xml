<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="payslip_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h4 class="text-center" style="text-transform:uppercase;">Pay Slip</h4>
                        <h5 class="text-center">
                            <span style="text-transform:uppercase;">For the month of</span>
                            <span t-field="o.date_to" t-options='{"format":"MMMM yyyy"}'
                                  style="text-transform:uppercase;"/>

                        </h5>
                        <style>
                            td{
                            padding:5px !important;
                            }
                            .text-right {
                            text-align: right;
                            }
                        </style>
                        <div class="row">

                            <t t-set="gross_pay_allowances" t-value="0"/>
                            <t t-set="total_deductions" t-value="0"/>
                            <t t-set="total" t-value="0"/>
                        </div>
                        <table class="table table-condensed table-bordered"
                               style="font-size:12px;border: 1px solid #d8dadd;">
                            <tr>
                                <td>
                                    <span class="fa fa-list"/>
                                    <strong>Registration Number</strong>
                                </td>
                                <td>
                                    <t t-if="o.id">
                                        <span t-esc="o.employee_id.identification_id"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-map-marker"/>
                                    <strong>Location</strong>
                                </td>
                                <td colspan="3">
                                    <t t-if="o.employee_id.work_location_id">
                                        <div t-esc="o.employee_id.work_location_id.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-user"/>
                                    <strong>Name</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id">
                                        <span t-esc="o.employee_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-tag"/>
                                    <strong>CNIC No.</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.ssnid">
                                        <span t-esc="o.employee_id.ssnid"/>
                                    </t>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-building"/>
                                    <strong>Department</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.department_id.name">
                                        <span t-esc="o.employee_id.department_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-google-wallet"/>
                                    <strong>Bank</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.bank_account_id.bank_id.name">
                                        <span t-esc="o.employee_id.bank_account_id.bank_id.name"/>
                                    </t>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-user-secret"/>
                                    <strong>Designation</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.job_id">
                                        <span t-esc="o.employee_id.job_id.name"/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-money"/>
                                    <strong>Bank Account</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.bank_account_id.acc_number">
                                        <span t-esc="o.employee_id.bank_account_id.acc_number"/>
                                    </t>
                                </td>
                            </tr>

                            <tr t-foreach="o.rule_by_code(o.id,'MONTHLY_SALARY')" t-as="line">
                                <td>
                                    <span class="fa fa-calendar"/>
                                    <strong>Joining Date</strong>
                                </td>
                                <td>
                                    <t t-if="o.employee_id.first_contract_date">
                                        <span t-field="o.employee_id.first_contract_date"
                                              t-options='{"format":"dd/MM/yyyy"}'/>
                                    </t>
                                </td>
                                <td>
                                    <span class="fa fa-street-view"/>
                                    <strong>Gross</strong>
                                </td>
                                <td>
                                    <!--                                    <span t-esc="'{:,}'.format(line['total'])"-->
                                    <!--                                          t-esc-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>-->
                                    <span t-esc="'{:,}'.format(line['total'])"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <span class="fa fa-university"/>
                                    <strong>Grade</strong>
                                </td>
                                <td>
                                    <span t-esc="o.employee_id.contract_id.x_studio_grade"/>
                                </td>
                                <td>
                                </td>
                                <td>
                                </td>
                            </tr>
                        </table>
                        <div class="row" style="font-size:12px;">
                            <div class="col-6" style="padding-right:1rem;">
                                <t t-if="o.payslip(o.id,'BASIC')">
                                    <table class="table table-condensed table-bordered table-striped"
                                           style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                        <thead>
                                            <tr>
                                                <t t-if="o.payslip(o.id,'BASIC')">
                                                    <td class="text-left" style="font-size:15px;">
                                                        <strong>Allowances</strong>
                                                    </td>
                                                    <td class="text-right" style="font-size:15px;">
                                                        <strong>Amount</strong>
                                                    </td>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.payslip(o.id,'BASIC')" t-as="line">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(line['total'])"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <t t-if="o.payslip(o.id,'TOTAL_ALLOWANCES')">
                                                <td style="font-size:15px;">
                                                    <strong>Basic Allowances</strong>
                                                </td>
                                                <td></td>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'CONVENYANCE_ALW')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'HOUSE_RENT')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'UTILITY')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <t t-if="o.payslip(o.id,'MONTHLY_SALARY')">
                                    <table class="table table-condensed table-bordered table-striped"
                                           style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                        <thead>
                                            <tr>
                                                <t t-if="o.payslip(o.id,'MONTHLY_SALARY')">
                                                    <td style="font-size:15px;">
                                                        <strong>Gross</strong>
                                                    </td>
                                                    <td></td>
                                                </t>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="o.payslip(o.id,'MONTHLY_SALARY')" t-as="line">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <t t-set="gross_pay_allowances"
                                                   t-value="line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(round(line['total']))"/>
                                                </td>
                                            </tr>
                                            <tr t-foreach="o.payslip(o.id,'GROSS')" t-as="line"
                                                style="border-top: 1px solid #d8dadd;">
                                                <td>
                                                    <span t-esc="line['name']"/>
                                                </td>
                                                <t t-set="gross_pay_allowances"
                                                   t-value="line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(round(line['total']))"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <t t-if="o.payslip(o.id,'BONUS')">
                                                <td style="font-size:15px;">
                                                    <strong>Special Allowances</strong>
                                                </td>
                                                <td></td>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'BONUS')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="gross_pay_allowances"
                                               t-value="gross_pay_allowances+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6" style="padding-left:1rem;">
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <t t-if="o.payslip(o.id,'TOTAL_DEDUCTION')">
                                                <td style="font-size:15px;">
                                                    <strong>Deductions</strong>
                                                </td>
                                                <td class="text-right" style="font-size:15px;">
                                                    <strong>Amount</strong>
                                                </td>
                                            </t>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'OTHER_DEDUCTION_NON_TAXABLE')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'CANTEEN')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'CLOAN')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PF_EMPLOYEE')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'CURRENT_INCOME_TAX')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PFLOAN_TOTAL')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <t t-set="total_deductions" t-value="total_deductions+line['total']"/>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Total Deductions</strong>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,.2f}'.format(total_deductions)"/>
                                            </td>
                                        </tr>
                                    </thead>
                                </table>
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Other Details</strong>
                                            </td>
                                            <td class="text-right" style="font-size:15px;">
                                                <strong>Amount</strong>
                                            </td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="o.payslip(o.id,'LWPA')" t-as="line">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'OTHER_PAYMENTS_TAXABLE')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PFLB')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PFLPB')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PFWIB')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(line['total'])"/>
                                            </td>
                                        </tr>
                                        <tr t-foreach="o.payslip(o.id,'PFBAL')" t-as="line"
                                            style="border-top: 1px solid #d8dadd;">
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,.2f}'.format(line['total'])"/>
                                            </td>
                                        </tr>
<!--                                        <tr style="border-top: 1px solid #d8dadd;">-->
<!--                                            <td>-->
<!--                                                PF Balance-->
<!--                                            </td>-->
<!--                                            <td class="text-right">-->
<!--                                                &lt;!&ndash;                                                <span t-esc="('{:,.2f}'.format(o.employee_id.total + o.employee_id.pf_employee + o.employee_id.pf_employer + o.employee_id.pf_interest)) or 0"/>&ndash;&gt;-->
<!--                                                <span t-esc="('{:,.2f}'.format(o.get_pf_balance_as_of()))"/>-->
<!--                                            </td>-->
<!--                                        </tr>-->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div class="row" style="font-size:12px;">
                            <div class="col-6" style="padding-right:1rem;">
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Gross Pay and Allowances</strong>
                                            </td>
                                            <td class="text-right">
                                                <span t-esc="'{:,}'.format(round(gross_pay_allowances))"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-size:15px;">
                                                <strong>Net Pay (Rs)</strong>
                                            </td>
                                            <t t-foreach="o.payslip(o.id,'NET')" t-as="line">
                                                <t t-set="total" t-value="total+line['total']"/>
                                                <td class="text-right">
                                                    <span t-esc="'{:,}'.format(round(line['total']))"/>
                                                </td>
                                            </t>
                                        </tr>
                                    </thead>
                                </table>

                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <tbody>
                                        <tr>
                                            <td colspan="2">
                                                <i>
                                                    <span t-esc="o.company_id.currency_id.amount_to_text(round(total))"/>
                                                </i>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-6" style="font-size:12px;padding-left:1rem; "
                                 t-if="int(o.employee_id.contract_id.x_studio_grade) &lt; 14">
                                <p style="font-size:15px;">
                                    <strong>LWP (Details)</strong>
                                </p>
                                <table class="table table-condensed table-bordered table-striped"
                                       style="border: 1px solid white;border-top: 1px solid #d8dadd;">
                                    <thead>
                                        <tr>
                                            <th class="text-left">Date</th>
                                            <th class="text-right">Days</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.get_allied_lwp_days()" t-as="att">
                                            <tr>
                                                <td class="text-left">
                                                    <t t-esc="att['date']"/>
                                                </td>
                                                <td class="text-right">
                                                    <t t-esc="att['amt']"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <br/>
                        <small style="font-size:12px;">
                            <b>Note: This is a computer generated document, does not require signatures.</b>
                        </small>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>