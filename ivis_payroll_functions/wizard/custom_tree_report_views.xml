<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="custom_report_list_view" model="ir.ui.view">
        <field name="name">List View</field>
        <field name="model">custom.tree.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="department_id"/>
                <field name="employee_code"/>
                <field name="employee_id"/>
                <field name="gross_pay"/>
                <field name="opening_pfund"/>
                <field name="current_pfund"/>
                <field name="interest"/>
                <field name="pfund_till_date"/>
                <field name="emplr_pfund"/>
                <field name="total_pfund"/>
            </list>
        </field>
    </record>

    <record id="custom_report_view" model="ir.actions.act_window">
        <field name="name">Report Tree</field>
        <field name="res_model">custom.tree.report</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>