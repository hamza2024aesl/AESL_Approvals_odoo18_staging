<?xml version="1.0" encoding="utf-8" ?>
<templates>
   <t t-name="ivis_import_async.PartnerListScreen" t-inherit="ImportDataSidepanel" t-inherit-mode="extension">
        <xpath expr="//CheckBox[last()]" position="after">
            <CheckBox id="use_queue"
                      value="props.options.use_queue"
                      onChange.bind="isChecked => this.props.onOptionChanged('use_queue', isChecked)">
                Import in the background
            </CheckBox>
        </xpath>
    </t>
</templates>