<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="view_higher_management_report_wizard" model="ir.ui.view">
        <field name="name">view.higher_management.wizard</field>
        <field name="model">higher.management.wizard</field>
        <field name="arch" type="xml">
            <form string="Higher Management">
                <group>
                    <field name="location_id" invisible="all_dept == True"/>
                    <field name="all_dept" string="Check All Region"/>
                    <field name="department_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button string="Print" name="print_higher_management" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_print_higher_management_wizard_report_wizard" model="ir.actions.act_window">
        <field name="name">Higher Management Report Wizard</field>
        <field name="res_model">higher.management.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem name="Executive Summart"
              id="menu_appraisal_higher_management_wizard_report"
              parent="menu_appraisal_summary_report"
              action="aesl_appraisal_system.action_print_higher_management_wizard_report_wizard"
              sequence="10"/>
</odoo>
