<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="aesl_appraisal_system_root" model="ir.module.category">
        <field name="name">Appraisals Group</field>
    </record>


    <record id="group_user_appraisals_1" model="res.groups">
        <field name="name">User Appraisals</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>
    <record id="group_manageby_appraisals" model="res.groups">
        <field name="name">ManagedBy Appraisal</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>


    <record id="group_setting_appraisals_2" model="res.groups">
        <field name="name">Setting Appraisals</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>
    <!-- Define your user groups here -->
    <record id="group_hr_manager_appraisal_3" model="res.groups">
        <field name="name">HR Appraisal</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>
    <record id="group_md_appraisal_4" model="res.groups">
        <field name="name">MD Appraisal</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>
    <record id="group_exec_appraisal_4" model="res.groups">
        <field name="name">Executive Appraisal</field>
        <field name="category_id" ref="aesl_appraisal_system_root"/>
    </record>


    <data noupdate="1">
        <record id="appraisal_system_all_rule" model="ir.rule">
            <field name="name">All Appraisal</field>
            <field name="model_id" ref="model_appraisal_system"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('aesl_appraisal_system.group_user_appraisals_1'))]"/>
        </record>

        <record id="appraisal_system_emp_rule" model="ir.rule">
            <field name="name">Employee Appraisal</field>
            <field name="model_id" ref="model_appraisal_system"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), '&amp;',
                ('employee_id.parent_id', '!=', False), ('employee_id.parent_id', '=', user.employee_id.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="appraisal_system_manager_rule" model="ir.rule">
            <field name="name">Manager Appraisal</field>
            <field name="model_id" ref="model_appraisal_system"/>
            <field name="domain_force">[('appraisal_approver_id', '=', user.id)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>


