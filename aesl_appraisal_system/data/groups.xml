        <!-- Multi - Company Rules -->
        <record model="ir.rule" id="appraisal_system_comp_rule">
            <field name="name">Appraisal multi-company</field>
            <field name="model_id" ref="model_appraisal_system"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
