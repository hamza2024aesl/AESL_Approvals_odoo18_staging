<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record model="ir.ui.view" id="view_appraisal_system_tree">
            <field name="name">view.appraisal.system.tree</field>
            <field name="model">appraisal.system</field>
            <field name="arch" type="xml">
                <list string="Appraisal" sample="1" import="0" export_xlsx="0" create="0" delete="0">
                    <field name="employee_id" string="Name" widget="many2one_avatar_employee"/>
                    <field name="date_close" widget="remaining_days" invisible="state in ['done', 'cancel']"/>
                    <field name="registration_number" readonly="1"/>
                    <field name="job_id" readonly="1"/>
                    <field name="manager_ids" widget="many2many_tags" readonly="1" invisible="1"/>
                    <field name="emp_type" readonly="1" invisible="1"/>
                    <field name="appointment_date" invisible="1"/>
                    <field name="state" widget="badge" decoration-info="state in ('new','pending')"
                           decoration-success="state == 'done'" invisible="1"/>
                    <field name="grade" readonly="1"/>
                    <field name="gross_salary" readonly="1"/>
                    <field name="recommend_raise_amount" readonly="1"/>
                    <field name="recommend_grades" readonly="1"/>
                    <field name="recommend_designation_id" readonly="1"/>
                    <field name="increase_percentage" readonly="1"/>
                    <field name="doc_state" widget="badge" decoration-info="doc_state == 'draft'"
                           decoration-danger="doc_state == 'revert'" decoration-warning="doc_state == 'publish'"
                           decoration-success="doc_state == 'done'" decoration-primary="doc_state == 'save'"/>
                </list>
            </field>
        </record>

        <record id="view_appraisal_system_searchs" model="ir.ui.view">
            <field name="name">view.appraisal.system.searchs</field>
            <field name="model">appraisal.system</field>
            <field name="arch" type="xml">
                <search string="Search Appraisal">
                    <field name="employee_id"/>
                    <field name="name"/>
                    <field name="manager_ids"/>
                    <field name="registration_number"/>
                    <field name="date_close"/>
                    <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <group expand='0' string='Group by...'>
                        <filter string='Employee' name="employee" icon="fa-user" domain="[]"
                                context="{'group_by': 'employee_id'}"/>
                        <filter name="groupby_state" context="{'group_by': 'state'}"/>
                    </group>
                    <searchpanel>
                        <field name="company_id" groups="base.group_multi_company" icon="fa-building"/>
                        <field name="department_id" icon="fa-users"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <record id="view_appraisal_system_form" model="ir.ui.view">
            <field name="name">view.appraisal.system.form</field>
            <field name="model">appraisal.system</field>
            <field name="arch" type="xml">
                <form create="0" delete="0">
                    <header>
                        <button name="action_hr_confirm" string="HR Confirm" type="object"
                                groups="aesl_appraisal_system.group_hr_manager_appraisal_3" class="oe_highlight"
                                invisible="state != 'draft'"/>
                        <button name="action_confirm2" string="Submit" type="object" class="oe_highlight"
                                invisible="state != 'pending'"/>
                        <button name="action_confirm3" string="Submit" type="object" class="oe_highlight"
                                invisible="state != 'pending2'"/>
                        <button name="action_confirm4" string="Submit" type="object"
                                groups="aesl_appraisal_system.group_exec_appraisal_4" class="oe_highlight"
                                invisible="state != 'pending4'"/>
                        <button name="action_confirm" string="Submit" type="object" class="oe_highlight"
                                invisible="state != 'new'"/>
                        <button name="action_done" string="Done" type="object"
                                groups="aesl_appraisal_system.group_md_appraisal_4"
                                invisible="state != 'pending3'"/>
                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state != 'pending'"/>
                        <button name="action_reset_back" string="Revert Back" type="object" class="oe_highlight"
                                invisible="state in ('draft', 'new', 'done', 'cancel')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,new,done" readonly="1"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="appraisal_type" invisible="state != 'draft'"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="employee_id" required="appraisal_type == 'employee'"
                                       invisible="appraisal_type != 'employee'" readonly="state != 'draft'"/>
                                <field name="departments" required="appraisal_type == 'department'"
                                       invisible="appraisal_type != 'department'" readonly="state != 'draft'"/>
                                <field name="mode_company_id" string="Company"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"
                                       required="appraisal_type == 'company'" invisible="appraisal_type != 'company'"
                                       readonly="state != 'draft'"/>
                                <field name="manager_ids" widget="many2many_tags" invisible="1"
                                       options="{'color_field': 'color'}"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="grade" readonly="1"/>
                                <field name="education" readonly="1"/>
                                <field name="appointment_date" readonly="1"/>
                                <field name="birthday" readonly="1"/>
                                <field name="gross_salary" readonly="0"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="emp_type" invisible="1"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="is_manager" invisible="0"/>
                                <field name="is_hr_confirm" invisible="0"/>
                                <field name="is_exec_state" invisible="0"/>
                                <field name="last_state" invisible="0"/>
                            </group>
                            <group>
                                <field name="appraisal_approver_id" invisible="1"/>
                                <field name="company_id" readonly="1" invisible="1"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="registration_number" readonly="1"/>
                                <field name="job_id" readonly="1"/>
                                <field name="department_id" readonly="1"/>
                                <field name="dept_abbreviation" widget="radio"/>
                                <field name="personal_file_number" invisible="1"
                                       groups="aesl_appraisal_system.group_hr_manager_appraisal_3"/>
                                <field name="cl_count" readonly="1"/>
                                <field name="sl_count" readonly="1"/>
                                <field name="earned_leaves_balance" readonly="1"/>
                                <field name="is_md_state" invisible="0"/>
                                <field name="is_manager2" invisible="0"/>
                                <field name="is_manager3" invisible="0"/>
                                <field name="appraisal_last_approver_id" invisible="1"/>
                                <field name="doc_state" invisible="1"/>
                                <field name="x_css" force_save="1" nolabel="1" invisible="0"/>
                            </group>
                        </group>

                        <h5><b>Remarks:</b>(Work Independently, Analytic, Troubleshooting, Motivation, Technical)
                        </h5>
                        <field name="remarks" nolabel="1"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                               readonly="state != 'new'"/>
                        <field name="remarks_2" invisible="is_manager != True" readonly="state != 'pending'" nolabel="1"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"/>
                        <field name="remarks_3" nolabel="1"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                               invisible="is_manager2 != True" readonly="state != 'pending2'"/>
                        <field name="remarks_4" nolabel="1"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                               invisible="is_exec_state != True" readonly="state != 'pending4'"/>
                        <field name="remarks_5" nolabel="1" style="border-bottom: 1px solid #000 !important;"
                               invisible="is_exec_state != True" readonly="state != 'pending3'"/>
                        <group>
                            <field name="recomm_increment" readonly="1" invisible="state != 'done'"/>
                        </group>
                        <h5>
                            <b>Future Prospects:</b>
                        </h5>
                        <field name="future_project"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                               readonly="state != 'new'"/>
                        <group>
                            <field name="recomm_increment_lines_id" widget="one2many_list" nolabel="1"
                                   readonly="state == 'draft'">
                                <list class="o_list_view_table" string="Recommend Raise Lines" editable="top"
                                      delete="1">
                                    <field name="increment_raise_id" invisible="1"/>
                                    <field name="check_access_team_id" invisible="1"/>
                                    <field name="increment_raise_amount" style="width: 30vw; text-align: right;"
                                           readonly="check_access_team_id == False"/>
                                    <field name="recomm_desigantion_id" readonly="check_access_team_id == False"
                                           style="width: 30vw; text-align: left;"/>
                                    <field name="recomm_grades" readonly="check_access_team_id == False"
                                           style="width: 10vw; text-align: center;"/>
                                    <field name="increment_raise_by" style="width: 15wv; text-align: left;"
                                           readonly="1"/>
                                    <field name="incremented_date" style="width: 15vw; text-align: left;" readonly="1"/>
                                    <field name="state" invisible="0"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_appraisal_system_kanban" model="ir.ui.view">
            <field name="name">appraisal.system.kanban</field>
            <field name="model">appraisal.system</field>
            <field name="arch" type="xml">
                <kanban quick_create="false" class="o_hr_employee_kanban" sample="1"
                        create="0" delete="0">
                    <field name="state"/>
                    <field name="manager_ids"/>
                    <progressbar field="activity_state"
                                 colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click o_kanban_record_has_image_fill o_kanban_card_appraisal">
                                <field name="image_128" widget="image" class="o_kanban_image_fill_left"
                                       options="{'zoom': true, 'zoom_delay': 1000, 'background': true, 'preventClicks': false}"/>
                                <div class="ribbon ribbon-top-right" invisible="state != 'done'">
                                    <span class="bg-success">Done</span>
                                </div>
                                <div class="ribbon ribbon-top-right" invisible="state != 'pending'">
                                    <span class="bg-info">Ready</span>
                                </div>
                                <div class="ribbon ribbon-top-right" invisible="state != 'cancel'">
                                    <span class="bg-secondary">Canceled</span>
                                </div>
                                <div class="o_dropdown_kanban dropdown" groups="base.group_user">
                                    <a class="dropdown-toggle o-no-caret btn" role="button" data-toggle="dropdown"
                                       href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                        <span class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <t t-if="widget.deletable">
                                            <a type="delete" class="dropdown-item" role="menuitem">Delete</a>
                                        </t>
                                    </div>
                                </div>
                                <div class="oe_kanban_details">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="employee_id"/>
                                            </strong>
                                        </div>
                                    </div>
                                    <field name="department_id"/>
                                    <div class="o_kanban_inline_block">
                                        <t t-if="record.date_close.raw_value and record.date_close.raw_value &lt; (new Date())"
                                           t-set="red">oe_kanban_text_red
                                        </t>
                                        <span t-attf-class="#{red}">
                                            <field name="date_close"/>
                                        </span>
                                        <span t-attf-class="#{red}">
                                            <field name="manager_ids"/>
                                        </span>
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left"/>
                                    <div class="oe_kanban_bottom_right mt-auto d-flex justify-content-between align-items-end">
                                        <t t-foreach="record.manager_ids.raw_value" t-as="employee">
                                            <img class="oe_kanban_avatar o_appraisal_manager"
                                                 t-att-src="kanban_image('hr.employee', 'image_128', employee)"
                                                 t-att-title="employee.value" t-att-alt="employee.value"
                                                 t-att-data-id="employee"/>
                                        </t>
                                    </div>
                                </div>
                                <div class="oe_clear"></div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_view_appraisal_system">
            <field name="name">Appraisal System</field>
            <field name="res_model">appraisal.system</field>
            <field name="view_mode">kanban,list,form</field>
            <field name="context">{'group_by': ['state', 'appraisal_approver_id']}</field>
        </record>

        <menuitem name="Appraisals" id="menu_appraisal_system_root"
                  web_icon="aesl_appraisal_system,static/description/icon.png"/>
        <menuitem name="Appraisals" id="menu_appraisal_system_sub" parent="menu_appraisal_system_root"
                  action="aesl_appraisal_system.action_view_appraisal_system"/>
        <menuitem name="Finalize Appraisal" id="menu_appraisal_system_finalize" parent="menu_appraisal_system_root"/>

