    <record id="paperformat_manager_report_summary" model="report.paperformat">
        <field name="name">Manager Report Summary</field>
        <field name="default" eval="True"/>
        <field name="format">custom</field>
        <field name="page_height">297</field>
        <field name="page_width">210</field>
        <field name="orientation">Landscape</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">23</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">20</field>
        <field name="dpi">90</field>
    </record>

    <record id="appraisal_system_manager_summary_report_pdf" model="ir.actions.report">
        <field name="name">Manager Summary Report</field>
        <field name="model">appraisal.system</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">aesl_appraisal_system.template_appraisal_manager_summary_report</field>
        <field name="report_file">aesl_appraisal_system.template_appraisal_manager_summary_report</field>
        <field name="paperformat_id" ref="aesl_appraisal_system.paperformat_manager_report_summary"/>
        <field name="binding_model_id" ref="model_appraisal_system"/>
        <field name="binding_type">report</field>
    </record>

    <record id="appraisal_system_manager_all_summary_report_pdf" model="ir.actions.report">
