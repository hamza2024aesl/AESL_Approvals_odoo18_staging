<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_user_appraisal_group_by" model="ir.ui.view">
        <field name="name">user.appraisal.group.by</field>
        <field name="model">appraisal.group.by</field>
        <field name="arch" type="xml">
            <form>
                <field name="mode" invisible="1"/>

                <group>
                    <field name="department_id" invisible="mode != 'department'"/>
                    <field name="company_id" invisible="mode != 'company'"/>
                    <field name="appraisal_batch_id" />

                </group>

                <footer>
                    <button name="action_confirm"
                            string="Proceed"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>

            </form>

        </field>
    </record>
</odoo>
