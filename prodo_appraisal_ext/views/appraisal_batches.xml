<odoo>
    <data>
    <record id="appraisal_batches_filter" model="ir.ui.view">
        <field name="name">appraisal.batches.search</field>
        <field name="model">appraisal.batches</field>
        <field name="arch" type="xml">
            <search string="Search Payslip Batches">
                <field name="name" string="Payslip Batches"/>
            </search>
        </field>
    </record>

    <record id="appraisal_batches_list" model="ir.ui.view">
        <field name="name">appraisal.batches.list</field>
        <field name="model">appraisal.batches</field>
        <field name="arch" type="xml">
            <list string="Payslips Batches">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
            </list>
        </field>
    </record>

    <record id="appraisal_batches_form" model="ir.ui.view">
        <field name="name">appraisal.batches.form</field>
        <field name="model">appraisal.batches</field>
        <field name="arch" type="xml">
            <form string="Payslips Batches">
            <sheet>
                <label for="name" class="oe_edit_only"/>
                <h1>
                    <field name="name"/>
                </h1>
                <group col="4">
                    <label for="date_start" string="Period"/>
                     <div>
                           <field name="date_start" class="oe_inline"/> - <field name="date_end" class="oe_inline"/>
                     </div>
                </group>

            </sheet>
            </form>
        </field>
    </record>

    <record id="action_appraisal_batches" model="ir.actions.act_window">
        <field name="name">Batches</field>
        <field name="res_model">appraisal.batches</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem action="action_appraisal_batches" name="Batches" id="menu_appraisal_batches"
              parent="hr_appraisal.menu_hr_appraisal_root"/>
    </data>
</odoo>
