<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="hr_appriasal_form_customization" model="ir.ui.view">
            <field name="name">hr.appraisal.form.customization</field>
            <field name="model">hr.appraisal</field>
            <field name="inherit_id" ref="hr_appraisal.view_hr_appraisal_form"/>
            <field name="arch" type="xml">

                <!-- REPLACE HEADER -->
                <xpath expr="//header" position="replace">
                    <header>

                        <!-- HR STARTS WORKFLOW -->
                        <button name="action_hr_confirm"
                                string="HR Confirm"
                                type="object"
                                class="oe_highlight"
                                invisible="state != 'draft'"/>
<!--                        groups="prodo_appraisal_ext.group_hr_manager_appraisal_3"-->

                        <!-- MANAGER SUBMIT (Dynamic manager flow) -->
                        <button name="action_manager_submit"
                                string="Submit"
                                type="object"
                                class="oe_highlight"
                                invisible="
                                state != 'new' or state != 'pending'"/>

                        <!-- MD APPROVAL -->
                        <button name="action_md_submit"
                                string="MD Approve"
                                type="object"
                                class="oe_highlight"
                                invisible="
                                state != 'md'"/>
                        <button name="action_hr_published"
                                string="Published Appraisal"
                                type="object"
                                class="oe_highlight"
                                invisible="
                                state != 'done'"/>


                        <!-- CANCEL BUTTON (Optional) -->
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                invisible="state == 'done'"/>

                        <!-- STATUS BAR -->
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,new,pending,executive,md,done,published"
                               readonly="1"/>

                        <!--                        <field name="doc_state" widget="statusbar"-->
                        <!--                               statusbar_visible="draft,save,done,revert,publish"-->
                        <!--                               readonly="1"/>-->

                    </header>
                </xpath>

                <!-- Rest of your XML remains same -->

                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="readonly"></attribute>
                </xpath>
                <xpath expr="//field[@name='manager_ids']" position="before">
                    <field name="appraisal_type"/>
                    <field name="appraisal_batch_id"/>
                </xpath>

                <xpath expr="//field[@name='appraisal_template_id']" position="after">
                    <field name="doc_state" readonly="1"/>
                </xpath>

                <xpath expr="//page[@name='private_note']" position="after">
                    <page name="appraisal_approvals" string="Appraisal Approvals">

                        <!-- REMARKS -->
                        <group string="Remarks">
                            <!--                            <field name="remarks"-->
                            <!--                                   readonly="current_approver_id != uid"-->
                            <!--                                   nolabel="1"-->
                            <!--                                   style="border-bottom: 1px solid #000; width:100%;"/>-->
                            <field name="appraisal_remarks" readonly="1">
                                <list readonly="1">
                                    <field name="create_date"/>
                                    <field name="create_uid"/>
                                    <field name="remark_text"/>
                                </list>
                            </field>
                        </group>


                        <!-- INCREMENT -->
                        <group string="Increase Recommendation">
                            <group>
                                <field name="recomm_increment"
                                       readonly="1"
                                       invisible="state != 'done'"
                                       string="Increase Recommended"/>
                            </group>
                        </group>

                        <!-- FUTURE PROSPECT -->
                        <group string="Future Prospects">
                            <field name="future_project"
                                   readonly="is_first_manager == False"
                                   nolabel="1"
                                   style="border-bottom: 1px solid #000; width:100%;"/>
                        </group>
                        <group string="Revert Remarks">
                            <field name="revert_remarks"
                                   readonly="1"
                                   nolabel="1"
                                   style="border-bottom: 1px solid #000; width:100%;"/>
                        </group>

                        <separator string="Increment Details"/>

                        <!-- Increment Lines Table -->
                        <field name="recomm_increment_lines_id"
                               widget="one2many_list"
                               nolabel="1"
                              readonly="1">

                            <list string="Recommend Raise Lines" editable="top" delete="0">
                                <field name="increment_raise_id" invisible="1"/>
                                <field name="check_access_team_id" invisible="1"/>
                                <field name="increment_raise_amount" string="Raise Amount"
                                       readonly="check_access_team_id == True"/>
                                <field name="recomm_desigantion_id" string="Designation"
                                       readonly="check_access_team_id == False"/>
                                <field name="recomm_grades" string="Grade" readonly="check_access_team_id == False"/>
                                <field name="increment_raise_by" readonly="1" string="Approved By"/>
                                <field name="incremented_date" readonly="1" string="Date"/>
                                <field name="state" invisible="1"/>
                            </list>

                        </field>

                    </page>
                </xpath>

                <xpath expr="//field[@name='assessment_note']" position="before">
                    <field name="registration_number"/>
                    <field name="appointment_date"/>
                    <field name="sl_count" readonly="1"/>
                    <field name="cl_count" readonly="1"/>
                    <field name="pl_count" readonly="1"/>
                    <field name="earned_leaves_balance"/>
                    <field name="gross_salary"/>
                    <field name="increase_percentage" readonly="1"/>
                </xpath>

            </field>
        </record>

        <record id="hr_appraisal_published_action" model="ir.actions.server">
            <field name="name">Publish/Increment Appraisal</field>
            <field name="model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">action = records.action_hr_published()</field>
        </record>

        <record id="hr_appraisal_assigned_batch" model="ir.actions.server">
            <field name="name">Assigned Batch</field>
            <field name="model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">action = records.action_hr_assigned_batch()</field>
        </record>

        <record id="hr_appraisal_hr_confirm" model="ir.actions.server">
            <field name="name">HR Confirm</field>
            <field name="model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_model_id" ref="hr_appraisal.model_hr_appraisal"/>
            <field name="binding_view_types">list,form</field>
            <field name="state">code</field>
            <field name="code">action = records.action_hr_confirm()</field>
        </record>
    </data>
</odoo>

