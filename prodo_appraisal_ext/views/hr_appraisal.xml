<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="hr_appriasal_form_customization" model="ir.ui.view">
            <field name="name">hr.appraisal.form.customization</field>
            <field name="model">hr.appraisal</field>
            <field name="inherit_id" ref="hr_appraisal.view_hr_appraisal_form"/>
            <field name="arch" type="xml">

                <!-- REPLACE HEADER -->
                <xpath expr="//header" position="replace">
                    <header>

                        <!-- HR STARTS WORKFLOW -->
                        <button name="action_hr_confirm"
                                string="HR Confirm"
                                type="object"
                                class="oe_highlight"
                                groups="prodo_appraisal_ext.group_hr_manager_appraisal_3"
                                invisible="state != 'draft'"/>

                        <!-- MANAGER SUBMIT (Dynamic manager flow) -->
                        <button name="action_manager_submit"
                                string="Submit"
                                type="object"
                                class="oe_highlight"
                                invisible="
                                state != 'new' or state != 'pending'"/>

                        <!-- MD APPROVAL -->
                        <button name="action_md_submit"
                                string="MD Approve"
                                type="object"
                                class="oe_highlight"
                                invisible="
                                state != 'md'"/>

                        <!-- CANCEL BUTTON (Optional) -->
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                invisible="state == 'done'"/>

                        <!-- STATUS BAR -->
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,new,pending,md,done"
                               readonly="1"/>
                    </header>
                </xpath>

                <!-- Rest of your XML remains same -->

                <xpath expr="//field[@name='manager_ids']" position="before">
                    <field name="appraisal_type"/>
                    <field name="appraisal_batch_id"/>
                </xpath>

                <xpath expr="//page[@name='private_note']" position="after">
                    <page name='appraisal_approvals' string="Appraisal Approvals">

                        <group>
                            <h5>
                                <b>Remarks:</b>
                            </h5>
                            <field name="remarks"
                                   readonly="current_approver_id != uid"
                                   style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                            />
                        </group>

                        <span>
                            <b>Increase Recommended?</b>
                        </span>
                        <field name="recomm_increment" readonly="1" invisible="state != 'done'"/>

                        <h5>
                            <b>Future Prospects:</b>
                        </h5>
                        <field name="future_project"
                               style="border-bottom: 1px solid #000 !important; margin-bottom:15px;"
                               readonly="is_first_manager == False"/>

                        <!--                        <field name="to_confirmation"-->
                        <!--                               invisible="emp_type != 'probation'"-->
                        <!--                               attrs="{'readonly':[('state','!=','draft')]}"/>-->

                        <!-- Increment Lines Table -->
                        <field name="recomm_increment_lines_id" widget="one2many_list" nolabel="1"
                               readonly="state == 'draft' or state == 'done'">
                            <list string="Recommend Raise Lines" editable="top" delete="0">
                                <field name="increment_raise_id" invisible="1"/>
                                <field name="increment_raise_amount"/>
                                <field name="recomm_desigantion_id"/>
                                <field name="recomm_grades"/>
                                <field name="increment_raise_by" readonly="1"/>
                                <field name="incremented_date" readonly="1"/>
                                <field name="state" invisible="1"/>
                            </list>
                        </field>

                    </page>
                </xpath>

                <xpath expr="//field[@name='assessment_note']" position="before">
                    <field name="registration_number"/>
                    <field name="appointment_date"/>
                    <field name="sl_count" readonly="1"/>
                    <field name="cl_count" readonly="1"/>
                    <field name="pl_count" readonly="1"/>
                    <field name="earned_leaves_balance"/>
                    <field name="gross_salary"/>
                    <field name="increase_percentage" readonly="1"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>

