<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="hr_employee_inherit_tree_view" model="ir.ui.view">
            <field name="name">hr.employee.tree - inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="before">
                    <field name="identification_id" optional="show"/>
                </field>
            </field>
        </record>

        <record id="employee_location" model="ir.ui.view">
            <field name="name">hr.employee.inherit</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <!--                <xpath expr="//notebook/page[@name='hr_settings']" position="after">-->
                <!--                    <page name= "fund_eobi" string="EOBI" groups="hr.group_hr_user">-->
                <!--                        <group string="EOBI" name="EOBI">-->
                <!--                            <field name="payslip_eobi" nolabel="1" readonly="1">-->
                <!--                                <list editable="bottom">-->
                <!--                                    <field name="month"/>-->
                <!--                                    <field name="rules"/>-->
                <!--                                    <field name="ruleName"/>-->
                <!--                                    <field name="code"/>-->
                <!--                                    <field name="total" sum="Sum of all funds"/>-->
                <!--                                </list>-->
                <!--                            </field>-->
                <!--                        </group>-->
                <!--                    </page>-->
                <!--                </xpath>-->
                <xpath expr="//header" position="inside">
                    <button name="compute_funds" string="Compute Funds" type="object" class="oe_highlight"
                            invisible="1"/>
                </xpath>

                <!--Pages-->
                <xpath expr="//page[@name='personal_information']" position="after">
                    <page string="Insurance"
                          groups="hr.group_hr_manager">
                        <group>
                            <group string="Company Percentage">
                                <field name="company_percent"/>
                            </group>
                            <group string="Salary Deductions">
                                <field name="salary_deduct_per_month" string='Salary Deduction Per Month'/>
                                <field name="salary_deduct_per_year" string='Salary Deduction Per Year'/>
                            </group>
                        </group>
                        <field name="insurance_ids">
                            <list string="Insurance" editable="bottom"
                                  class="new4_class">
                                <field name="policy_num" width="20px"/>
                                <field name="policy_type" options="{'no_open': True, 'no_create': True}"/>
                                <field name="policy_coverage" width="20px"/>
                                <field name="issue_date" width="20px"/>
                                <field name="expiry_date" width="20px"/>
                                <field name="policy_amount" width="20px" string='Policy Amount'/>
                                <field name="description" width="20px"/>
                            </list>
                            <form string="Insurance">
                                <group name="main">
                                    <separator string="Policy Detail" colspan="4"/>
                                    <field name="policy_num"/>
                                    <field name="policy_type"/>
                                    <field name="policy_coverage"/>
                                    <field name="policy_amount"/>
                                    <separator string="Dates" colspan="4"/>
                                    <field name="issue_date"/>
                                    <field name="expiry_date"/>
                                    <separator string="Description" colspan="4"/>
                                    <field name="description" colspan="4" nolabel="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>

                <!--Groups-->
                <xpath expr='//page[@name="personal_information"]/group' position="inside">
                    <group string="Birth Information" name="birth_info">
                        <field name="gender"/>
                        <field name="birthday"/>
                        <field name="age_at_today"/>
                        <field name="disabled" string="Disability"/>
                        <field name="disability_type" invisible="not disabled"/>
                        <field name="place_of_birth" groups="hr.group_hr_user"/>
                        <field name="country_of_birth" groups="hr.group_hr_user"/>
                        <field name="blood_group"/>
                    </group>
                </xpath>
                <xpath expr="//page[@name='personal_information']" position="inside">
                    <group string="Family Members">
                        <field name="fam_member_ids" nolabel="1">
                            <list string="Family Members" editable="bottom" class="new_class">
                                <field name="name" width="25px"/>
                                <field name="gender" width="8px"/>
                                <field name="relation" width="15px"/>
                                <field name="telephone_fam" width="20px"/>
                                <field name="date_of_birth" width="22px"/>
                                <field name="age_till_today" width="28px" optional="hide"/>
                                <field name="fam_cnic" width="23px"/>
                                <field name="fam_cnic_expiry" width="22px" optional="hide"/>
                                <field name="next_kin" width="20px" optional="hide"/>
                                <field name="is_insured" width="5px"/>
                                <field name="is_emergency" width="5px"/>
                            </list>
                        </field>
                    </group>
                </xpath>

                <xpath expr="//page[@name='personal_information']//separator[@name='has_work_permit']"
                       position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='visa_no']" position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='permit_no']" position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='visa_expire']" position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='work_permit_expiration_date']"
                       position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='work_permit_name']" position="replace"/>
                <xpath expr="//page[@name='personal_information']//field[@name='has_work_permit']" position="replace"/>

                <!--Fields-->
                <xpath expr="//field[@name='mobile_phone']" position="after">
                    <field name="x_studio_grade"/>
                </xpath>
                <xpath expr='//field[@name="work_email"]' position="before">
                    <field name="identification_id" string="Employee Code"/>
                </xpath>
                <xpath expr='//page[@name="hr_settings"]//field[@name="employee_type"]' position="after">
                    <field name="appointment_date"/>
                    <field name="confirmation_date"/>
                    <field name="resignation_date"/>
                    <field name="exit_date"/>
                    <field name="leave_reason" invisible="exit_date == False"/>
                    <field name="leave_type" invisible="exit_date == False"/>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group/field[@name="identification_id"]'
                       position="after">
                    <field name="cnic_expiry"/>
                    <field name="ntn"/>
                    <field name="Is_commit_crime" string='Crime Ever Convicted'/>
                </xpath>
                <xpath expr="//field[@name='marital']" position="after">
                    <field name="caste" string="Cast"/>
                    <field name="religion"/>
                </xpath>
                <xpath expr='//page[@name="personal_information"]//field[@name="private_email"]' position="before">
                    <field name="x_studio_personal_file_number"/>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group/field[@name="country_id"]'
                       position="after">
                    <field name="other_nationality" string="Other Nationality"/>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group/field[@name="passport_id"]'
                       position="after">
                    <field name="passport_expiry"/>
                </xpath>
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="x_studio_field_uRb4K"/>
                </xpath>
                <xpath expr="//field[@name='country_id']" position="after">
                    <field name="domicile_city" options="{'no_open': True, 'no_create': True}"/>
                </xpath>

                <!--Attributes-->
                <xpath expr='//page[@name="personal_information"]/group/group/field[@name="identification_id"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//field[@name="ssnid"]' position="attributes">
                    <attribute name="string">CNIC</attribute>
                </xpath>
                <!--                <xpath expr='//page[@name="personal_information"]/group/group[4]' position="attributes">-->
                <!--                    <attribute name="invisible">1</attribute>-->
                <!--                </xpath>-->
                <xpath expr='//page[@name="personal_information"]/group/group[3]' position="attributes">
                    <attribute name="string">Family Status</attribute>
                    <attribute name="name">family</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[3]/separator' position="replace"/>
                <xpath expr='//page[@name="personal_information"]/group/group[3]/field[@name="emergency_contact"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[3]/field[@name="emergency_phone"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]' position="attributes">
                    <attribute name="string">Personal Info</attribute>
                </xpath>
                <xpath expr='//page[@name="public"]' position="attributes">
                    <attribute name="string">Public Info</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[2]//field[@name="gender"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[2]//field[@name="birthday"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[2]//field[@name="place_of_birth"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr='//page[@name="personal_information"]/group/group[2]//field[@name="country_of_birth"]'
                       position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>

                <notebook position="inside">
                    <page string="Letters" groups="base.group_user,hr.group_hr_user">
                        <field name="letter_ids">
                            <list string="Letters" editable="bottom" class="new3_class">
                                <field name="letter_no"/>
                                <field name="name" string="Title"/>
                                <field name="issue_date" string="Issue Date"/>
                                <field name="documents" string="Attachment"/>
                            </list>

                            <form string="Letter">
                                <group>
                                    <field name="name" string="Title"/>
                                    <field name="issue_date" string="Issue date"/>
                                    <field name="documents" string="Attachment"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </notebook>
            </field>
        </record>

        <record id="custom_hr_employee_view_form" model="ir.ui.view">
            <field name="name">custom.hr.employee.view.form</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr_payroll.payroll_hr_employee_view_form"/>
            <field name="priority" eval="110"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='payroll_group']/field[@name='disabled']" position="replace"/>
                <!--                <xpath expr="//group[@name='payroll_group']/field[@name='registration_number']" position="replace"/>-->
                <xpath expr="//group[@name='payroll_group']" position="inside">
                    <field name="eobi_number"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>