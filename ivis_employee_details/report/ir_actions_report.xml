<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="report_employee_profile" model="ir.actions.report">
            <field name="name">Employee Profile</field>
            <field name="model">hr.employee</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ivis_employee_details.employee_profile_report</field>
            <field name="report_file">ivis_employee_details.employee_profile_report</field>
            <field name="binding_model_id" ref="hr.model_hr_employee"/>
            <field name="binding_type">report</field>
        </record>

        <record id="report_employee_final_settlement" model="ir.actions.report">
            <field name="name">Final Settlement Payslip</field>
            <field name="model">hr.payslip</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">ivis_employee.employee_final_settlement_report</field>
            <field name="report_file">ivis_employee.employee_final_settlement_report</field>
            <field name="binding_model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="paperformat_euro_low_margin"/>
        </record>
    </data>
</odoo>