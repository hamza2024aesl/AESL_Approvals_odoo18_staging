<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <template id="employee_profile_report">
            <t t-call='web.html_container'>
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <h5>
                            Personal Information
                        </h5>
                        <table style="border: 1px solid black; width:100%; padding:20px; ">
                            <tr>
                                <td>
                                    <span>Employee Name</span>
                                </td>
                                <td>
                                    <t t-esc="o.name"/>
                                </td>
                                <td>
                                    <span>Emp # for GP</span>
                                </td>
                                <td>
                                    <t t-esc="o.identification_id"/>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    <span>Gender</span>
                                </td>
                                <td>
                                    <t t-esc="o.gender"/>
                                </td>
                                <td>
                                    <span>Date Of Birth</span>
                                </td>
                                <td>
                                    <t t-esc="o.birthday"/>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    <span>CNIC</span>
                                </td>
                                <td>
                                    <t t-esc="o.ssnid"/>
                                </td>
                                <td>
                                    <span>CNIC Expiry</span>
                                </td>
                                <td>
                                    <t t-esc="o.cnic_expiry"/>
                                </td>


                            </tr>
                            <tr>
                                <td>
                                    <span>Spouse</span>
                                </td>
                                <td>
                                    <t t-esc="o.getRelativeName('wife')"/>
                                </td>
                                <td>
                                    <span>Spouse's Birth Date</span>
                                </td>
                                <td>
                                    <t t-esc="o.getSuposeDOB()"/>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    <span>Father's Name</span>
                                </td>
                                <td>
                                    <t t-esc="o.getRelativeName('father')"/>
                                </td>
                                <td>
                                    <span>Blood Group</span>
                                </td>
                                <td>
                                    <t t-esc="o.blood_group"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    N. Tax No.
                                </td>
                                <td>
                                    <t t-esc="o.ntn"/>
                                </td>
                                <td>
                                    Phone No.
                                </td>
                                <td>
                                    <t t-esc="o.work_phone"/>
                                </td>

                            </tr>
                            <tr>
                                <td>
                                    Email
                                </td>
                                <td>
                                    <t t-esc="o.private_email"/>
                                </td>
                                <td>
                                    Phone No.
                                </td>
                                <td>
                                    <t t-esc="o.mobile_phone"/>
                                </td>

                            </tr>

                        </table>
                        <br/>
                        <h5>Dependent Information</h5>
                        <table style="border: 1px solid black; width:100%; padding:20px;">
                            <t t-foreach="o.getDepdentDetail()" t-as="depents">
                                <tr>
                                    <td style="padding-left: 20px;">
                                        <span>
                                            Name
                                        </span>
                                    </td>
                                    <td style="text-align:center; text-transform:capitalize; padding-left: 20px;">
                                        <t t-esc="depents['name']"/>
                                    </td>
                                    <td style="padding-left: 20px;">
                                        <span>
                                            Date Of Birth
                                        </span>
                                    </td>
                                    <td style="padding-left: 20px;">
                                        <t t-esc="depents['date_of_birth']"/>
                                    </td>

                                </tr>
                            </t>
                        </table>
                        <br/>
                        <h5>Employment details</h5>
                        <table style="border: 1px solid black; width:100%; padding:20px;">
                            <tr>
                                <td>
                                    <span>
                                        Designation
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.job_id.name"/>
                                </td>
                                <td>
                                    <span>
                                        Grade
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.contract_id.x_studio_grade"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <span>
                                        Status
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.getEmpStatus('type')"/>
                                </td>
                                <td>
                                    <span>
                                        Appointment Date
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.appointment_date"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <span>
                                        Per. File Ref.
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.x_studio_personal_file_number"/>
                                </td>
                                <td>
                                    <span>
                                        Gross Salary
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="'{:,}'.format(o.getEmpStatus('wage'))"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <span>
                                        EOBI
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.eobi_number"/>
                                </td>
                                <td>
                                    <span>
                                        Sessi
                                    </span>
                                </td>
                                <td>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <span>
                                        Department
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.department_id.name"/>
                                </td>
                                <td>
                                    <span>
                                        Work Location
                                    </span>
                                </td>
                                <td>
                                    <t t-esc="o.work_location_id.name"/>
                                </td>
                            </tr>

                        </table>
                        <br/>

                        <h5>Bank Account Details</h5>
                        <table style="border: 1px solid black; width:100%; padding:20px;">
                            <tr>
                                <td>
                                    Account Title
                                </td>
                                <td>
                                    <t t-esc="o.bank_account_id.acc_holder_name"/>
                                </td>
                                <td>
                                    Account Number
                                </td>
                                <td>
                                    <t t-esc="o.bank_account_id.acc_number"/>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    Bank Name
                                </td>
                                <td>
                                    <t t-esc="o.bank_account_id.bank_id.name"/>
                                </td>

                                <td>

                                </td>
                                <td>

                                </td>
                            </tr>
                        </table>
                        <br/>
                        <h5>Education Details</h5>
                        <table style="border: 1px solid black; width:100%; padding:20px;">
                            <td style="padding-left: 20px; text-align:center;">
                                Degree
                            </td>
                            <td style="text-align:center;">
                                Specialization
                            </td>
                            <td style="text-align:center;">
                                Percentage
                            </td>
                            <td style="text-align:center;">
                                CGPA
                            </td>
                            <td style="text-align:center;">
                                Division/Grade
                            </td>
                            <t t-foreach="o.getacademics()" t-as="line">
                                <tr>
                                    <td style="text-transform:capitalize; padding-left: 20px; text-align:center;">
                                        <t t-esc="line['degree']"/>
                                    </td>
                                    <td style="text-transform:capitalize; text-align:center;">
                                        <t t-esc="line['specialization']"/>
                                    </td>
                                    <td style="text-align:center;">
                                        <t t-esc="line['percentage']"/>
                                    </td>
                                    <td style="text-align:center;">
                                        <t t-esc="line['cgpa']"/>
                                    </td>
                                    <td style="text-align:center;">
                                        <t t-esc="line['division']"/>
                                    </td>
                                </tr>
                            </t>
                        </table>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>