<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="paperformat_sale_order_landscape" model="report.paperformat">
            <field name="name">European A1 Landscape</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">2000</field>
            <field name="page_width">2000</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">30</field>
            <field name="margin_bottom">0</field>
            <field name="margin_left">0</field>
            <field name="margin_right">0</field>
            <field name="header_line" eval="True"/>
            <field name="header_line">True</field>
            <field name="header_spacing">20</field>
            <field name="dpi">90</field>
        </record>

        <record id="report_payroll_report" model="ir.actions.report">
            <field name="name">Payroll Report PDF</field>
            <field name="model">hr.payslip.run</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">xlsx_payroll_report.payroll_report_news</field>
            <field name="report_file">xlsx_payroll_report.payroll_report_news</field>
            <field name="binding_model_id" ref="hr_payroll.model_hr_payslip_run"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="paperformat_sale_order_landscape"/>
        </record>

        <template id="payroll_report_news">
            <t t-call='web.html_container'>
                <t t-call="web.external_layout">
                    <t t-foreach="docs" t-as="o">
                        <h1 style="text-align:center;">Payroll Report</h1>
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <!--                                    <td colspan="3"><strong>Company Name:</strong></td>-->
                                    <!--                                    <td colspan="3"><strong><span t-field="o.company_id.partner_id.name"/></strong></td>-->
                                    <td colspan="3">
                                        <strong>Payslip Period:</strong>
                                    </td>
                                    <td colspan="3">
                                        <strong>
                                            <span t-field="o.date_start"/>
                                        </strong>
                                        <strong>To</strong>
                                        <strong>
                                            <span t-field="o.date_end"/>
                                        </strong>
                                    </td>
                                    <td colspan="3">
                                        <strong>Payslip Structure:</strong>
                                    </td>
                                    <td colspan="3">
                                        <strong>
                                            <span t-field="o.slip_ids.struct_id.name"/>
                                        </strong>
                                    </td>
                                </tr>
                                <!--                                <tr>-->
                                <!--                                    <td colspan="3">-->
                                <!--                                        <strong>Payslip Structure:</strong>-->
                                <!--                                    </td>-->
                                <!--                                    <td colspan="3">-->
                                <!--                                        <strong>-->
                                <!--                                            <span t-field="o.slip_ids.struct_id.name"/>-->
                                <!--                                        </strong>-->
                                <!--                                    </td>-->
                                <!--                                </tr>-->
                            </thead>
                        </table>

                        <style>

                            .border-right-bottom{
                            border-right : 1px solid black;
                            border-bottom : 1px solid black;
                            border-left : 1px solid black;
                            border-top : 1px solid black;
                            }
                            th {
                            background-color : #d3d3d3;
                            border-right : solid;
                            border-right-width : 1px;
                            border-bottom : double;
                            border-top : solid;
                            border-left : solid;
                            border-left-width : 1px;
                            border-top-width : 1px;
                            text-align : center;
                            padding : 5px;
                            width: 5px;
                            font-size: large;
                            }
                            td {
                            padding : 5px;
                            width: 5px;
                            font-size: large;
                            }
                        </style>

                        <div class="page;mw-100;">
                            <table class="table table-bordered"
                                   style="width: 100%; margin-top:10px; height:10px;font-size: 8px;">
                                <thead>
                                    <tr>
                                        <th style="width:1%">E.N.</th>
                                        <th style="width:1%">Name</th>
                                        <th style="width:1%">Dept.</th>
                                        <th style="width:1%">Desig.</th>
                                        <th style="width:1%">Loc.</th>

                                        <t t-foreach="docs" t-as="o">
                                            <t t-foreach='o.get_rules_header()' t-as='lines'>

                                                <th class="text-center">
                                                    <strong>
                                                        <t t-esc="lines"/>
                                                    </strong>
                                                </th>

                                            </t>
                                        </t>
                                    </tr>
                                </thead>

                                <tbody>
                                    <t t-foreach="docs" t-as="o">
                                        <t t-foreach='o.get_report_data()' t-as='line'>
                                            <tr>
                                                <td class="text-center">
                                                    <t t-esc="line['reg_no']"/>
                                                </td>
                                                <td class="text-center">
                                                    <strong>
                                                        <t t-esc="line['name']"/>
                                                    </strong>
                                                </td>
                                                <td class="text-center">
                                                    <strong>
                                                        <t t-esc="line['dept']"/>
                                                    </strong>
                                                </td>
                                                <td class="text-center">
                                                    <strong>
                                                        <t t-esc="line['job']"/>
                                                    </strong>
                                                </td>
                                                <td class="text-center">
                                                    <strong>
                                                        <t t-esc="line['loc']"/>
                                                    </strong>
                                                </td>
                                                <t t-foreach="line['values']" t-as='d'>
                                                    <td class="text-center">
                                                        <strong>
                                                            <t t-esc="'{:,.2f}'.format(d)"/>
                                                        </strong>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                        <tr>
                                            <td class="text-center" colspan="5">Total:</td>
                                            <t t-foreach="o.get_total()" t-as="l">
                                                <td style="text-align:right;">
                                                    <strong>
                                                        <t t-esc="'{:,.2f}'.format(l)"/>
                                                    </strong>
                                                </td>
                                            </t>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>