<?xml version="1.0" encoding="utf-8"?>

<odoo>
	<data>

		<record id="hr_workingschedules_inherited_view"
			model="ir.ui.view">
			<field name="name">Inherited view of working schedules</field>
			<field name="model">resource.calendar</field>
			<field name="inherit_id" ref="resource.resource_calendar_form" />
			<field name="arch" type="xml">

				<xpath expr="//h1" position="after">
					<group colspan="2">
						<group>
							<field name="compensatory_hours" widget="float_time"/>
							<field name="shift"/>
							<field name="missed_in_out_duration" widget="float_time"/>
						</group>
						<group>
							<field name="overtime_start" widget="float_time"/>
							<field name="exclude" string="Exclude this duration?"/>
						</group>
					</group>
				</xpath>
				<xpath expr="//page[1]"
					position="after">
					<page string="In Policy">
						<group string='In Policy'>
							<field name='in_policy_id' nolabel='1' colspan="2" class="px-3">
								<list editable='bottom'>
									<field name="sequence" widget="handle"/>
									<field name="time_from" widget="float_time"/>
									<field name="time_to" widget="float_time"/>
									<field name="status" />
									<field name="adjust_time"/>
									<field name="action" />
								</list>
							</field>
						</group>
					</page>
					<page string="Out Policy">
						<group string='Out Policy'>
							<field name='out_policy_id' nolabel='1' colspan="2" class="px-3">
								<list editable='bottom'>
									<field name="sequence" widget="handle"/>
									<field name="time_from" widget="float_time"/>
									<field name="time_to" widget="float_time"/>
									<field name="status" />
									<field name="action" />
								</list>
							</field>
						</group>
					</page>
				</xpath>
			</field>
		</record>
	</data>
</odoo>