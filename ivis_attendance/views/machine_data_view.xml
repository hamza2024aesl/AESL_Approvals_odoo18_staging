<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record model="ir.ui.view" id="machine_data_filter">
		<field name="name">machine.data filter</field>
		<field name="model">machine.data</field>
		<field name="arch" type="xml">
			<search string="Employee Name">
				<field name="employee_name"/>
				<filter string="Employee Name" name="employee_name" />
			</search>
		</field>
	</record>

	<record id="machine_data_tree" model="ir.ui.view">
		<field name="name">machine.data.tree</field>
		<field name="model">machine.data</field>
		<field name="arch" type="xml">
			<list string="Employee Machine Data" create="true" edit="true">
				<field name="machine_code" />
				<field name="employee_name" />
				<field name="employee_code" />
				<field name="date" />
				<field name="time" />
				<field name="type" />
				<field name="status" />
				<field name="shift" />
			</list>
		</field>
	</record>

	<record id="machine_data_form" model="ir.ui.view">
		<field name="name">machine.data.form</field>
		<field name="model">machine.data</field>
		<field name="arch" type="xml">
			<form string="Employee Machine Data" create="true" edit="true">
				<sheet>
					<group>
						<field name="machine_code" />
						<field name="employee_name" />
						<field name="employee_code" />
						<field name="date" />
						<field name="time" />
						<field name="type" />
						<field name="status" />
						<field name="shift" />
					</group>
				</sheet>
			</form>
		</field>
	</record>



	<record id="action_machine_data" model="ir.actions.act_window">
		<field name="name">Machine Attendances</field>
		<field name="res_model">machine.data</field>
		<!--		<field name="view_type">form</field>-->
		<field name="view_mode">list,form</field>
        <field name="search_view_id" ref="ivis_attendance.machine_data_filter"/>
	</record>

	<menuitem id="menu_ivis_machine" name="Machine Attendances"
			  parent="hr_attendance.menu_hr_attendance_root" sequence="20"
			  groups="hr_attendance.group_hr_attendance_manager" />
	<menuitem id="submenu_ivis_machine_att"
			  name="Machine Attendances" parent="menu_ivis_machine" sequence="1"
			  groups="hr_attendance.group_hr_attendance_manager"
			  action="action_machine_data" />

</odoo>
