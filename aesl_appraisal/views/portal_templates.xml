    <template id="aesl_appraisal.portal_employee_contract" name="Employee Contract Portal">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs" t-value="[
                ('My Account', '/my'),
                ('My Appraisal', '/my/appraisal')
            ]"/>

            <div class="container mt-4">
                <h3>Appraisal for 2026</h3>

                <t t-if="wage">
                    <table class="table table-bordered mt-3">
                        <tbody>
                            <h5>Dear
                                <span t-esc="contract.employee_id.name"/>,
                            </h5>
                            <tr>
                                <h5>
                                    The Management is pleased to inform you that, effective 01 January 2026,
                                    Your increment, grade, designation and revised salary will be as below.
                                </h5>
                            </tr>
                            <tr>
                                <th>Employee Code</th>
                                <td>
                                    <t t-esc="employee.identification_id"/>
                                </td>
                            </tr>

                            <tr>
                                <th>Grade</th>
                                <td>
                                    <t t-esc="grade"/>
                                </td>
                            </tr>

                            <tr>
                                <th>Job Position</th>
                                <td>
                                    <t t-esc="job_id"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Increment</th>
                                <td>
<!--                                    <t t-esc="increment"/>-->
                                    <t t-esc="'{:,}'.format(int(increment))"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Salary</th>
                                <td>
                                    <t t-esc="'{:,}'.format(int(wage))"/>
<!--                                    <t t-esc="wage"/>-->
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <h5>
                        We appreciate your continued dedication and commitment to the
                        organization.
                    </h5>

                    <br/>
                    <h5>Best Regards,</h5>
                    <p>
                        <strong>Management</strong>
                    </p>
                    <!-- PRINT BUTTON -->
                   <!-- <div class="mt-3 text-end">
                        <a t-att-href="'/my/appraisal/print'"
                           class="btn btn-primary">
                            Print Appraisal Letter
                        </a>
                    </div>-->
                </t>

                <t t-else="">
                    <div class="alert alert-warning mt-3">
                        No running contract found.
                    </div>
                </t>
            </div>
        </t>
    </template>

</odoo>