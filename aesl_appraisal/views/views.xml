<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit contract form view to add appraisal section -->
    <record id="view_contract_form_inherit" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.appraisal</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <!-- Add Appraisal Note field in contract form -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="appraisal_note"/>
            </xpath>

            <!-- Group all appraisal-related fields together -->
            <xpath expr="//sheet" position="inside">
                <group string="Appraisal Information" name="appraisal_info">
                    <group>
                        <field name="employee_id" readonly="1"/>
<!--                        <field name="x_studio_grade"/>-->
                    </group>
                    <group>
                        <field name="department_id"/>
                        <field name="job_id"/>
                    </group>
                    <group>
                        <field name="wage"/>
                        <field name="appraisal_note"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>