<odoo>
    <record id="view_employee_bonus_wizard" model="ir.ui.view">
        <field name="name">employee.bonus.wizard.form</field>
        <field name="model">employee.bonus.wizard</field>
        <field name="arch" type="xml">
            <form string="Department-wise Employee Bonus Allocation">
                <sheet>
                    <group>
                        <field name="line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="department_id" options="{'no_create': True}"/>
                                <field name="region_id" options="{'no_create': True}"/>
                                <field name="ttl_points" readonly="1"/>
                                <field name="bonus_points"/>
                            </list>
                        </field>
                    </group>
                    <footer>
                        <button name="apply_bonus" string="Apply Bonus" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_employee_bonus_wizard" model="ir.actions.act_window">
        <field name="name">Assign Bonus Points</field>
        <field name="res_model">employee.bonus.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_employee_bonus_wizard"/>
        <field name="target">new</field>
    </record>

    <menuitem name="Bonus Points" id="menu_bonus_points"
              parent="aesl_bonus_system.menu_appraisal_system_employee_bonus_root"
              groups="aesl_appraisal_system.group_hr_manager_appraisal_3,aesl_appraisal_system.group_md_appraisal_4"
              action="aesl_bonus_system.action_employee_bonus_wizard"/>

</odoo>