<?xml version="1.0" encoding="utf-8" ?>

<odoo>
    <record id="account_asset_compute_view_form" model="ir.ui.view">
        <field name="name">account.asset.compute</field>
        <field name="model">account.asset.compute</field>
        <field name="arch" type="xml">
            <form string="Post Asset">
                <group>
                    <field name="date_end" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button string="Post" name="asset_compute" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="account_asset_compute_action" model="ir.actions.act_window">
        <field name="name">Post Assets</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">account.asset.compute</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="account_asset_compute_view_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_finance_assets" name="Assets" parent="account_accountant.menu_accounting" sequence="9"/>
    <menuitem id="account_asset_compute_menu" action="account_asset_compute_action" parent="menu_finance_assets" sequence="110"/>
</odoo>