<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <record id="form_interest_distribution" model="ir.ui.view">
            <field name="name">interest.distribution.form</field>
            <field name="model">interest.distribution</field>
            <field name="arch" type="xml">
                <form string="Interest Distribution">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,distributed"/>
                        <button name="fetch_employees" string="Fetch Employees" type="object" class="oe_highlight"
                                invisible="state == 'distributed' or state != 'draft'"/>
                        <button name="distribute_profit" string="DISTRIBUTE" type="object" class="btn-danger"
                                invisible="state == 'distributed' or state != 'draft'"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date" readonly="state == 'distributed'"/>
                                <field name="amount" readonly="state == 'distributed'"/>
                            </group>
                            <group>
                                <field name="note" readonly="state == 'distributed'"/>
                            </group>
                        </group>
                        <group>
                            <field name="employee_ids" nolabel="1" readonly="1">
                                <list editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="excluded_pf_interest"/>
                                    <field name="previous_total" sum="Previous Total Sum"/>
                                    <field name="percent"/>
                                    <field name="interest" sum="Total Interest"/>
                                    <field name="extra_amount"/>
                                    <field name="current_total" sum="Current Total Sum"/>
                                </list>
                            </field>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="list_interest_distribution" model="ir.ui.view">
            <field name="name">interest.distribution.list</field>
            <field name="model">interest.distribution</field>
            <field name="arch" type="xml">
                <list string="Interest Distribution">
                    <field name="date" width="50%"/>
                    <field name="amount" width="50%"/>
                </list>
            </field>
        </record>

        <record id="action_interest_distribution" model="ir.actions.act_window">
            <field name="name">Interest Distribution</field>
            <field name="res_model">interest.distribution</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="interest_distribution_id"
                  action="action_interest_distribution"
                  name="PF Interest Distribution"
                  parent="hr.menu_human_resources_configuration"
                  sequence="30"/>
    </data>
</odoo>