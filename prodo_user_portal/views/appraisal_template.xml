<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <template id="appraisal_list_view_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'view_appraisal_page'">

            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Appraisals</h3>
                <div class="btn-group appraisal-groupby-container">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Group By
                    </button>
                    <t t-if="appraisals">
                        <t t-if="appraisals[0].state !='new'">
                            <button class="btn btn-primary" type="button" id="bulkApproveButton">Bulk Approve</button>
                        </t>
                    </t>
                    <div class="dropdown-menu p-3">
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-appraisal" type="checkbox"
                                   value="department"
                                   id="groupByDepartment"/>
                            <label class="form-check-label" for="groupByDepartment">Department</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-appraisal" type="checkbox"
                                   value="appraisal_deadline"
                                   id="groupByAppraisalDeadline"/>
                            <label class="form-check-label" for="groupByAppraisalDeadline">Appraisal Deadline
                            </label>
                        </div>
                        <!-- Bulk Approval Button -->

                    </div>
                </div>
            </div>
            <t t-if="request.session.get('my_appraisal_success')">
                <div class="alert alert-success">
                    <t t-esc="request.session.pop('my_appraisal_success')"/>
                </div>
            </t>

            <t t-call="portal.portal_table">
                <t t-if="appraisals">
                    <t t-if="appraisals[0].state!='new'">
                        <div>
                            <div class="form-check appraisal-groupby-container">
                                <input class="form-check-input" type="checkbox" id="selectAllCheckbox"/>
                                <label class="form-check-label" for="selectAllCheckbox">Select All</label>
                            </div>
                        </div>
                    </t>
                    <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th>Appraisal Deadline</th>
                            <!--                            <th>Emp. No</th>-->
                            <th>Designation</th>
                            <th>Manager</th>
                            <!--                            <th>Emp Type</th>-->
                            <th>Appointment Date</th>
                            <th>Status</th>
                            <th>Doc State</th>
                            <!--                            <th>Status</th>-->
                            <th>Gross Salary</th>
                            <!--                            <th>Recom. Increment</th>-->
                            <!--                            <th>Recom. Grade</th>-->
                            <!--                            <th>Increment (%)</th>-->
                            <th style="margin-right:5px">View</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="grouped_appraisal">
                            <t t-foreach="grouped_appraisal.items()" t-as="group">
                                <!-- Group Header -->
                                <tr class="bg-light">
                                    <td colspan="11">
                                        <button class="btn btn-link btn-sm appraisal-expand-btn"
                                                t-att-data-group-id="group[0]">
                                            <i class="fa fa-plus appraisal-expand-icon"/>
                                        </button>
                                        <strong>
                                            <t t-if="group_by == 'department'">
                                                Department:
                                                <t t-out="group[0]"/>
                                            </t>
                                            <t t-elif="group_by == 'appraisal_deadline'">
                                                Appraisal Deadline:
                                                <t t-out="group[0]"/>
                                            </t>
                                        </strong>
                                    </td>
                                </tr>
                                <t t-foreach="group[1]" t-as="appraisal">
                                    <tr t-attf-data-group-id="{{group[0]}}" class="appraisal-group-row"
                                        style="display: none;">
                                        <td>
                                            <input type="checkbox" name="selected_appraisals"
                                                   t-att-data-id="appraisal.id" class="bulk-approve-checkbox"/>
                                        </td>
                                        <td style="padding-left: 25px;">
                                            <t t-out="appraisal.employee_id.name"/>
                                        </td>

                                        <td class="text-right">
                                            <t t-out="appraisal.date_close"/>
                                        </td>
