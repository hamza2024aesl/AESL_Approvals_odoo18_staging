                                        <!--                                    </t>-->
                                        <!--                                    <t t-else="">-->
                                        <!--                                    </t>-->
                                        <!--                                </td>-->
                                        <td class="text-right">
                                            <t t-if="appraisal.appointment_date">
                                                <t t-esc="appraisal.appointment_date"/>
                                            </t>
                                            <t t-else="">
                                            </t>
                                        </td>
                                        <td>
                                            <t t-esc="dict(appraisal.fields_get(allfields=['state'])['state']['selection']).get(appraisal.state, '')"/>
                                        </td>
                                        <td>
                                            <t t-esc="appraisal.doc_state"/>
                                        </td>
                                        <td>
                                            <t t-esc="appraisal.employee_id.contract_id.wage"/>
                                        </td>
                                        <td>
                                            <t t-esc="appraisal[0].recomm_increment"/>
                                        </td>
                                        <!--                                <td>-->
                                        <!--                                    <t t-out="appraisal[0].recommend_grades"/>-->
                                        <!--                                </td>-->
                                        <!--                                <td>-->
                                        <!--                                   <t t-out="'%.2f' % appraisal[0].increase_percentage"/>-->
                                        <!--                                </td>-->
                                        <td t-if="appraisal.doc_state != 'publish'">
                                            <a t-attf-href="/my/appraisal/view/{{appraisal.id}}" title="Open Appraisal"
                                               aria-label="Open Appraisal" class="btn btn-sm btn-primary" role="button">
                                                <i class="fa fa-arrow-circle-right"/>
                                                <span class='d-none d-md-inline'>Open Appraisal</span>
                                            </a>
                                        </td>
                                        <td t-if="appraisal.doc_state == 'publish'">
                                            <a t-attf-href="/my/appraisal/download/{{appraisal.id}}"
                                               title="Print Report"
                                               aria-label="Open Appraisal" class="btn btn-sm btn-primary" role="button">
                                                <i class="fa fa-arrow-circle-right"/>
                                                <span class='d-none d-md-inline'>Print Report</span>
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </t>
                        <t t-if="not grouped_appraisal">
                            <t t-foreach="appraisals" t-as="appraisal">
                                <!--                                <tr class="text-center">-->
                                <tr class="text-left">
                                    <t t-if="appraisal.state != 'new'">
                                        <td>
                                            <input type="checkbox" name="selected_appraisals"
                                                   t-att-data-id="appraisal.id" class="bulk-approve-checkbox"/>
                                        </td>
                                    </t>
                                    <!--                                    <td style="padding-left: 25px;">-->
                                    <td>
                                        <t t-out="appraisal.employee_id.name"/>
                                    </td>

                                    <!--                                    <td class="text-right">-->
                                    <td>
                                        <t t-out="appraisal.date_close"/>
                                    </td>
                                    <!--                                    <td class="text-right">-->
                                    <!--                                -->
                                    <!--                                        <t t-else="">-->
                                    <!--                                        </t>-->
                                    <!--                                    </td>-->
                                    <!--                                <td class="text-right">-->
                                    <!--                                    <t t-if="attendance.status">-->
                                    <!--                                        <t t-esc="dict(attendance.fields_get(allfields=['status'])['status']['selection']).get(attendance.status, '')"/>-->
                                    <!--                                    </t>-->
                                    <!--                                    <t t-else="">-->
                                    <!--                                    </t>-->
                                    <!--                                </td>-->
                                    <!--                                    <td class="text-right">-->
                                    <!--                                    <td>-->
                                    <!--                                        <t t-if="appraisal.registration_number">-->
                                    <!--                                            <t t-esc="appraisal.registration_number"/>-->
                                    <!--                                        </t>-->
                                    <!--                                        <t t-else="">-->
                                    <!--                                        </t>-->
                                    <!--                                    </td>-->

                                    <!--                                    <td class="text-right">-->
                                    <td>
                                        <t t-if="appraisal.job_id">
                                            <t t-esc="appraisal.job_id.name"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <!--                                    <td class="text-right">-->
                                    <td>
                                        <t t-if="appraisal.employee_id.parent_id">
                                            <t t-esc="appraisal.employee_id.parent_id.user_id.name"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <!--                                    <td class="text-right">-->
                                    <!--                                    <td>-->
                                    <!--                                        <t t-if="appraisal.employee_id.contract_id">-->
                                    <!--                                            <t t-esc="appraisal.employee_id.contract_id.contract_type_id.code"/>-->
                                    <!--                                        </t>-->
                                    <!--                                        <t t-else="">-->
                                    <!--                                        </t>-->
                                    <!--                                    </td>-->
                                    <!--                                <td class="text-center">-->
                                    <!--                                    <t t-if="attendance.on_leave">-->
                                    <!--                                        <i class="fa fa-check"/>-->
                                    <!--                                    </t>-->
                                    <!--                                    <t t-else="">-->
                                    <!--                                    </t>-->
                                    <!--                                </td>-->
                                    <!--                                    <td class="text-right">-->
                                    <td>
                                        <t t-if="appraisal.appointment_date">
                                            <t t-esc="appraisal.appointment_date"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <td>
                                        <t t-esc="dict(appraisal.fields_get(allfields=['state'])['state']['selection']).get(appraisal.state, '')"/>
                                    </td>
                                    <td>
                                        <t t-esc="appraisal.doc_state"/>
                                    </td>
                                    <td>
                                        <t t-esc="appraisal.employee_id.contract_id.wage"/>
                                    </td>
                                    <!--                                    <td>-->
                                    <!--                                        <t t-esc="appraisal[0].recomm_increment"/>-->
                                    <!--                                    </td>-->
                                    <!--                                <td>-->
                                    <!--                                    <t t-out="appraisal[0].recommend_grades"/>-->
                                    <!--                                </td>-->
                                    <!--                                <td>-->
                                    <!--                                   <t t-out="'%.2f' % appraisal[0].increase_percentage"/>-->
                                    <!--                                </td>-->
                                    <td t-if="appraisal.doc_state != 'publish'">
                                        <a t-attf-href="/my/appraisal/view/{{appraisal.id}}" title="Open Appraisal"
                                           aria-label="Open Appraisal" class="btn btn-sm btn-primary" role="button">
                                            <i class="fa fa-arrow-circle-right"/>
                                            <span class='d-none d-md-inline'>Open Appraisal</span>
                                        </a>
                                    </td>
                                    <td t-if="appraisal.doc_state == 'publish'">
                                        <a t-attf-href="/my/appraisal/download/{{appraisal.id}}"
                                           title="Print Report"
                                           aria-label="Open Appraisal" class="btn btn-sm btn-primary" role="button">
                                            <i class="fa fa-arrow-circle-right"/>
                                            <span class='d-none d-md-inline'>Print Report</span>
                                        </a>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>

                </t>
                <t t-if="not appraisals">
                    <p class="alert alert-warning">There are currently no Appraisals.</p>
                </t>
            </t>
            <!-- Fallback message if no appraisals -->


        </t>
    </template>

    <template id="appraisal_detail_page_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'view_appraisal_detail_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>

            <!-- Header -->
            <div class="d-flex gap-2 my-3">
                <a href="/my/appraisal" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Appraisal Detail</h3>
                <!--                <t t-if="appraisal.state!='new'">-->

                <!--                </t>-->
                <button t-if="appraisal.state != 'published'"
                        class="btn btn-primary m-2 float-end"
                        id="create_revert_remarks"
                        title="Revert"
                >Revert
                </button>

                <!--                <button type="button" class="btn btn-primary save-btn">Save</button>-->
                <!--                <button type="button"-->
                <!--                        class="o_form_button_save btn btn-light border-0 px-1 py-0 lh-sm"-->
                <!--                >Save-->
                <!--                </button>-->
            </div>
            <!--            <form method="post" action="/my/form/save">-->
            <!--                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>-->
            <!--                <input type="hidden" name="appraisal_id" t-att-value="appraisal.id"/>-->
            <!--                <button type="submit" class="btn btn-primary m-2 float-end">-->
            <!--                    Save-->
            <!--                </button>-->
            <!--            </form>-->


            <form method="post" id="revert_form" action="/my/revert/appraisal" style="display: none; opacity: 1">
                <input type="hidden" name="appraisal_id" t-att-value="appraisal.id"/>
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="row o_portal_details">
                    <div>
                        <div class="row">
                            <div id="already_booked_id" style="display: none">
                                <p class="alert alert-danger">Days are already booked</p>
                            </div>
                            <div id="duration_error_id" style="display: none">
                                <p class="alert alert-warning">
                                    Date is invalid
                                </p>
                            </div>
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="name">Revert Remarks</label>
                                <input type="text" id="revert_remarks" name="revert_remarks"
                                       t-attf-class="form-control description-input" placeholder="Revert Remarks">
                                </input>
                            </div>
                        </div>
                        <div class="clearfix text-end mb-5">
                            <a id="discard_form" href="/my" class="btn btn-secondary me-2">
                                Discard
                            </a>
                            <button id="submit_revert_remarks" type="submit" class="btn btn-primary float-end">
                                Apply
                            </button>
                        </div>
                    </div>
                </div>
                <div style="border-bottom: 1px solid purple; margin-bottom: 40px"/>
            </form>

            <div class="card my-2 shadow-sm">
                <form method="post" action="/my/appraisal/view/save" class="mb-4" id="appraisal_detail">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="appraisal_id" t-att-value="appraisal.id"/>
                    <div class="card-body">

                        <!-- Header Row Title -->
                        <div class="row">
                            <div class="col-md-9">
                                <h5>
                                    <b>Appraisal Summary ( Status:
                                        <span t-out="dict(appraisal.fields_get(allfields=['state'])['state']['selection']).get(appraisal.state, '')"
                                              class="text-primary"></span>
                                        )
                                    </b>
                                </h5>
                            </div>

                            <!-- Submit button only for the CURRENT APPROVER -->
                            <div class="col-md-3">
                                <input type="hidden" id="action_type" name="action_type" value=""/>

                                <t t-if="appraisal.current_approver_id.id == uid">
                                    <button type="submit" class="btn btn-primary m-2 float-end">
                                        Submit
                                    </button>
                                    <button type="submit" onclick="document.getElementById('action_type').value='save'"
                                            class="btn btn-primary m-2 float-end">
                                        Save
                                    </button>

                                    <button type="submit"
                                            onclick="document.getElementById('action_type').value='unlink'"
                                            class="btn btn-primary m-2 float-end">
                                        Discard
                                    </button>


                                    <!--                                    <t t-if="appraisal.state!='new'">-->
                                    <!--                                      <div class="col-md-3">-->
                                    <!--                                <t t-if="appraisal.current_approver_id.id == user.id or appraisal.appraisal_employee_id == user.id">-->

                                    <!--                                    </t>-->
                                </t>
                            </div>
                            <!--                            <div class="col-md-3">-->
                            <!--                                &lt;!&ndash;                                <t t-if="appraisal.current_approver_id.id == user.id or appraisal.appraisal_employee_id == user.id">&ndash;&gt;-->

                            <!--                                &lt;!&ndash;                                </t>&ndash;&gt;-->
                            <!--                            </div>-->
                        </div>

                        <!-- Employee Summary -->
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Employee Name'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.name"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Designation'"/>
                                    <t t-set="value" t-value="appraisal.job_id.name"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Appointment Date'"/>
                                    <t t-set="value" t-value="appraisal.appointment_date"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Gross Salary'"/>
                                    <t t-set="value" t-value="appraisal.gross_salary"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Emp. No.'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.identification_id"/>
                                </t>
                            </div>

                            <div class="col-md-6">
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Manager Name'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.parent_id.user_id.name"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Emp Type'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.contract_id.contract_type_id.code"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Department'"/>
                                    <t t-set="value" t-value="appraisal.department_id.name"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Casual Leave Availed'"/>
                                    <t t-set="value" t-value="appraisal.cl_count"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Sick Leave Availed'"/>
                                    <t t-set="value" t-value="appraisal.sl_count"/>
                                </t>
                                <t t-call="prodo_user_portal.card_row_appraisal">
                                    <t t-set="label" t-value="'Earned Leave Balance'"/>
                                    <t t-set="value" t-value="appraisal.earned_leaves_balance"/>
                                </t>
                            </div>
                        </div>
                        <input type="hidden" name="appraisal_id" t-att-value="appraisal.id"/>
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <!-- Remarks Section -->
                        <div class="row">
                            <div class="col-md-8">
                                <h5>
                                    <b>Remarks:</b>
                                </h5>


                                <t t-foreach="appraisal.appraisal_remarks" t-as="remark">
                                    <t t-if="remark.create_uid.id == uid">
                                        <!-- Editable Remarks only for the CURRENT APPROVER -->
                                        <input type="text" name="remarks"
                                               t-att-value="remark.remark_text or ''"
                                               class="form-control mb-3"/>
                                    </t>

                                    <t t-else="">
                                        <!-- Static Remarks for others -->
                                        <p>
                                            <t t-esc="remark.remark_text"/>
                                        </p>
                                        <p style="line-height:0.5px;">
                                            By
                                            <b><t t-esc="remark.create_uid.name"/>:
                                            </b>
                                            <time t-field="remark.create_date"
                                                  t-options="{'format': 'EEEE d MMM yyyy'}"/>

                                        </p>
                                    </t>
                                </t>
                                <t t-set="user_appraisal_remarks"
                                   t-value="appraisal.appraisal_remarks.filtered(lambda r: r.create_uid.id == uid)"/>
                                <t t-if="appraisal.current_approver_id.id == user.id and appraisal.state != 'done' and appraisal.doc_state != 'revert' and not user_appraisal_remarks">
                                    <input type="text" name="new_remark"
                                           placeholder="Enter your remark"
                                           class="form-control mb-3"/>
                                </t>


                                <!-- Allow the current approver to add a new remark -->

                                <!-- Future Project -->
                                <h5>
                                    <b>Future Prospects:</b>
                                </h5>
                                <t t-foreach="appraisal.future_prospect_remarks" t-as="prospect">
                                    <t t-if="prospect.create_uid.id == uid">
                                        <!-- Editable Remarks only for the CURRENT APPROVER -->
                                        <input type="text" name="future_prospect_remarks"
                                               t-att-value="prospect.future_prospect_text or ''"
                                               class="form-control mb-3"/>
                                    </t>

                                    <t t-else="">
                                        <!-- Static Remarks for others -->
                                        <p>
                                            <t t-esc="prospect.future_prospect_text"/>
                                        </p>
                                        <p style="line-height:0.5px;">
                                            By
                                            <b><t t-esc="prospect.create_uid.name"/>:
                                            </b>
                                            <time t-field="prospect.create_date"
                                                  t-options="{'format': 'EEEE d MMM yyyy'}"/>

                                        </p>
                                    </t>
                                </t>
                                <t t-if="appraisal.is_first_manager and not appraisal.future_prospect_remarks.create_uid.id == uid">
                                    <input type="text" name="new_prospect"
                                           placeholder="Enter your remark"
                                           class="form-control mb-3"/>
                                </t>


                                <!--                                <input type="text" name="future_project"-->
                                <!--                                       t-att-value="appraisal.future_project or ''"-->
                                <!--                                       class="form-control mb-3"-->
                                <!--                                       t-att-disabled="'disabled' if appraisal.is_first_manager == False else None"/>-->
                            </div>

                            <!--                        &lt;!&ndash; Bonus side section remains unchanged &ndash;&gt;-->
                            <!--                        <div class="col-md-4">-->
                            <!--                            <h5><b>Bonus</b></h5>-->
                            <!--                        </div>-->
                        </div>

                        <div class="row">
                            <t t-if="appraisal.revert_remarks">
                                <div class="col-md-8">
                                    <h5>
                                        <b>Revert Remarks:</b>
                                    </h5>

                                    <p>
                                        <t t-if="appraisal.revert_remarks">
                                            <!--                                            <t t-esc="appraisal.revert_remarks"/>-->
                                            <span t-esc="appraisal.revert_remarks"
                                                  style="display: block; padding: 5px; background-color: #f5f5f5; border: 1px solid #ddd; border-radius: 4px; color: #555;"/>

                                            <br/>
                                        </t>
                                    </p>
                                </div>
                            </t>

                            <!--                        &lt;!&ndash; Bonus side section remains unchanged &ndash;&gt;-->
                            <!--                        <div class="col-md-4">-->
                            <!--                            <h5><b>Bonus</b></h5>-->
                            <!--                        </div>-->
                        </div>


                        <!-- Increment table -->
                        <h5 class="mt-4">
                            <b>Recommend Raises:</b>
                        </h5>

                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Increment</th>
                                    <th>Designation</th>
                                    <th>Grade</th>
                                    <th>Recommended By</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>

                                <!-- Existing Increment Lines -->
                                <!--                                <t t-foreach="appraisal.recomm_increment_lines_id" t-as="line">-->
                                <!--                                    <tr>-->
                                <!--                                        <td t-esc="line.increment_raise_amount"/>-->
                                <!--                                        <td t-esc="line.recomm_desigantion_id.name"/>-->
                                <!--                                        <td t-esc="line.recomm_grades"/>-->
                                <!--                                        <td t-esc="line.increment_raise_by.name"/>-->
                                <!--                                        <td t-esc="line.incremented_date"/>-->
                                <!--&lt;!&ndash;                                        <td t-esc="line.create_uid.name"/>&ndash;&gt;-->
                                <!--                                    </tr>-->
                                <!--                                </t>-->
                                <t t-foreach="appraisal.recomm_increment_lines_id" t-as="line">
                                    <t t-if="line">
                                        <tr>
                                            <!-- Increment Raise Amount -->
                                            <td>
                                                <t t-if="line.create_uid">
                                                    <t t-if="line.create_uid.id == user.id">
                                                        <input type="number" name="increment_raise_amount"
                                                               class="form-control"
                                                               t-att-value="line.increment_raise_amount"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="line.increment_raise_amount"/>
                                                    </t>
                                                </t>
                                            </td>

                                            <!-- Designation -->
                                            <td>
                                                <t t-if="line.create_uid">
                                                    <t t-if="line.create_uid.id == user.id">
                                                        <select name="recomm_desigantion_id" class="form-control">
                                                            <option value=""/>
                                                            <t t-foreach="desigantions" t-as="d">
                                                                <option t-att-value="d.id" t-esc="d.name"/>
                                                            </t>
                                                        </select>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="line.recomm_desigantion_id.name"/>
                                                    </t>
                                                </t>
                                            </td>

                                            <!-- Grade -->
                                            <td>
                                                <t t-if="line.create_uid">
                                                    <t t-if="line.create_uid.id == user.id">
                                                        <input type="text" name="recomm_grades" class="form-control"
                                                               t-att-value="line.recomm_grades"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span t-esc="line.recomm_grades"/>
                                                    </t>
                                                </t>
                                            </td>

                                            <!-- Approved By -->
                                            <td t-esc="line.increment_raise_by.name"/>

                                            <!-- Incremented Date -->
                                            <td t-esc="line.incremented_date"/>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <t t-if="appraisal.doc_state !='revert'">
                                            <tr>
                                                <!-- Increment Raise Amount -->
                                                <td>
                                                    <input type="number" name="increment_raise_amount"
                                                           class="form-control"/>
                                                </td>

                                                <!-- Designation -->
                                                <td>
                                                    <select name="recomm_desigantion_id" class="form-control">
                                                        <option value=""/>
                                                        <t t-foreach="desigantions" t-as="d">
                                                            <option t-att-value="d.id" t-esc="d.name"/>
                                                        </t>
                                                    </select>
                                                </td>

                                                <!-- Grade -->
                                                <td>
                                                    <input type="number" name="recomm_grades" class="form-control"/>
                                                </td>

                                                <!-- Approved By -->
                                                <td></td>
                                                <td></td>
                                            </tr>
                                        </t>
                                    </t>
                                    <!-- Add new increment line ONLY if current user is active approver -->

                                </t>
                                <t t-set="user_recommend"
                                   t-value="appraisal.recomm_increment_lines_id.filtered(lambda r: r.create_uid.id == uid)"/>
                                <t t-if="appraisal.current_approver_id.id == user.id and appraisal.state != 'done' and appraisal.doc_state != 'revert' and not user_recommend">
                                    <tr>
                                        <td>
                                            <input type="number" name="increment_raise_amount"
                                                   class="form-control"/>
                                        </td>
                                        <td>
                                            <select name="recomm_desigantion_id" class="form-control">
                                                <option value=""/>
                                                <t t-foreach="desigantions" t-as="d">
                                                    <option t-att-value="d.id" t-esc="d.name"/>
                                                </t>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="number" name="recomm_grades" class="form-control"/>
                                        </td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </t>


                            </tbody>
                        </table>

                    </div>
                </form>
            </div>

        </t>
    </template>
</odoo>