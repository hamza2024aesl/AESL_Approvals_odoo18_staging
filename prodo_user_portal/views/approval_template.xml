<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="travel_request_list_view_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'travel_request_list_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex align-items-center my-3 justify-content-between">
                <div class="d-flex align-items-center">
                    <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                        <i class="oi oi-chevron-left"/>
                    </a>
                    <a href="/my/travel/new" class="btn btn-primary me-3">New Request</a>
                    <h3 class="my-0">Travel Requests</h3>
                </div>
                
                <!-- Bulk Actions -->
                <div id="bulk_actions_container" class="d-none animate__animated animate__fadeIn">
                    <button id="btn_bulk_approve" class="btn btn-success me-2">
                        <i class="fa fa-check me-1"/> Bulk Approve (<span class="selected_count">0</span>)
                    </button>
                    <button id="btn_bulk_refuse" class="btn btn-danger">
                        <i class="fa fa-times me-1"/> Bulk Refuse (<span class="selected_count">0</span>)
                    </button>
                </div>
            </div>

            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th class="text-center" style="width: 40px;">
                            <input type="checkbox" id="select_all_requests" class="form-check-input"/>
                        </th>
                        <th>Description</th>
                        <th>Requester</th>
                        <th>Category</th>
                        <th>Date From</th>
                        <th>Date To</th>
                        <th>Travel Mode</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="requests" t-as="req">
                        <tr t-att-data-id="req.id">
                            <td class="text-center">
                                <t t-if="req.user_status == 'pending'">
                                    <input type="checkbox" class="request_checkbox form-check-input" t-att-value="req.id"/>
                                </t>
                                <t t-else="">
                                    <input type="checkbox" class="form-check-input" disabled="1"/>
                                </t>
                            </td>
                            <td><t t-esc="req.name"/></td>
                            <td><t t-esc="req.employee_id.name"/></td>
                            <td><t t-esc="req.category_id.name"/></td>
                            <td><t t-esc="req.date_start"/></td>
                            <td><t t-esc="req.date_end"/></td>
                            <td><t t-esc="dict(req.fields_get(['travel_mode'])['travel_mode']['selection']).get(req.travel_mode, '')"/></td>
                            <td>
                                <span t-attf-class="badge rounded-pill {{ 'bg-success' if req.request_status == 'approved' else 'bg-danger' if req.request_status == 'refused' else 'bg-warning text-dark' }}">
                                    <t t-esc="dict(req.fields_get(['request_status'])['request_status']['selection']).get(req.request_status, '')"/>
                                </span>
                            </td>
                            <td>
                                <a t-attf-href="/my/travel/view/{{req.id}}" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
            <t t-if="not requests">
                <p class="alert alert-warning">There are currently no Travel Requests.</p>
            </t>

            <!-- Inline Script for Bulk Actions -->
            <script type="text/javascript">
                document.addEventListener('DOMContentLoaded', function() {
                    const selectAll = document.getElementById('select_all_requests');
                    const checkboxes = document.querySelectorAll('.request_checkbox');
                    const bulkContainer = document.getElementById('bulk_actions_container');
                    const countSpans = document.querySelectorAll('.selected_count');
                    const btnApprove = document.getElementById('btn_bulk_approve');
                    const btnRefuse = document.getElementById('btn_bulk_refuse');

                    function updateUI() {
                        const selected = document.querySelectorAll('.request_checkbox:checked');
                        const count = selected.length;
                        
                        if (count > 0) {
                            bulkContainer.classList.remove('d-none');
                            countSpans.forEach(s => s.innerText = count);
                        } else {
                            bulkContainer.classList.add('d-none');
                        }
                    }

                    if (selectAll) {
                        selectAll.addEventListener('change', function() {
                            checkboxes.forEach(cb => {
                                if (!cb.disabled) cb.checked = selectAll.checked;
                            });
                            updateUI();
                        });
                    }

                    checkboxes.forEach(cb => {
                        cb.addEventListener('change', updateUI);
                    });

                    async function performBulkAction(action) {
                        const selectedIds = Array.from(document.querySelectorAll('.request_checkbox:checked')).map(cb => parseInt(cb.value));
                        if (selectedIds.length === 0) return;

                        if (!confirm('Are you sure you want to ' + action + ' ' + selectedIds.length + ' request(s)?')) return;

                        // Disable buttons
                        btnApprove.disabled = true;
                        btnRefuse.disabled = true;

                        try {
                            const response = await fetch('/my/travel/bulk_action', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-CSRF-Token': odoo.csrf_token,
                                },
                                body: JSON.stringify({
                                    jsonrpc: "2.0",
                                    params: {
                                        request_ids: selectedIds,
                                        action: action
                                    }
                                })
                            });
                            const result = await response.json();
                            if (result.result &amp;&amp; result.result.success) {
                                window.location.reload();
                            } else {
                                alert('Error processing requests');
                            }
                        } catch (err) {
                            console.error(err);
                            alert('An unexpected error occurred');
                        } finally {
                            btnApprove.disabled = false;
                            btnRefuse.disabled = false;
                        }
                    }

                    if (btnApprove) btnApprove.addEventListener('click', () => performBulkAction('approve'));
                    if (btnRefuse) btnRefuse.addEventListener('click', () => performBulkAction('refuse'));
                });
            </script>
        </t>
    </template>

    <template id="travel_request_form_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'travel_request_new_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my/travel" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">New Travel Request</h3>
            </div>

            <t t-if="request.session.get('travel_error')">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <t t-esc="request.session.pop('travel_error')"/>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </t>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <form action="/my/travel/save" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <!-- Employee Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Employee Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Category</label>
                                <select name="category_id" class="form-control" required="1">
                                    <t t-foreach="categories" t-as="cat">
                                        <option t-att-value="cat.id"><t t-esc="cat.name"/></option>
                                    </t>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Employee Name</label>
                                <input type="text" class="form-control" t-att-value="employee_name" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Registration No</label>
                                <input type="text" class="form-control" t-att-value="employee_identification_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Department</label>
                                <input type="text" class="form-control" t-att-value="employee_department_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Region</label>
                                <input type="text" class="form-control" t-att-value="employee_work_location_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Designation</label>
                                <input type="text" class="form-control" t-att-value="employee_job_id" readonly="1"/>
                            </div>
                        </div>

                        <!-- Period Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Period Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Date From</label>
                                <input type="datetime-local" name="date_start" class="form-control" required="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Date To</label>
                                <input type="datetime-local" name="date_end" class="form-control" required="1"/>
                            </div>
                        </div>

                        <!-- Travel Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Travel Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold d-block">Travel Mode</label>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_mode" id="mode_air" value="air" required="1"/>
                                    <label class="form-check-label" for="mode_air">Air</label>
                                </div>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_mode" id="mode_train" value="train"/>
                                    <label class="form-check-label" for="mode_train">Train</label>
                                </div>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_mode" id="mode_car" value="car"/>
                                    <label class="form-check-label" for="mode_car">Car</label>
                                </div>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_mode" id="mode_bus" value="bus"/>
                                    <label class="form-check-label" for="mode_bus">Bus</label>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="fw-bold d-block">Travel Request Type</label>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_request_type" id="type_domestic" value="domestic" required="1"/>
                                    <label class="form-check-label" for="type_domestic">Domestic</label>
                                </div>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="travel_request_type" id="type_international" value="international"/>
                                    <label class="form-check-label" for="type_international">International</label>
                                </div>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="fw-bold d-block">Tickets Required?</label>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="tickets_required" id="tickets_yes" value="yes" required="1"/>
                                    <label class="form-check-label" for="tickets_yes">Yes</label>
                                </div>
                                <div class="form-check form-check-inline mt-2">
                                    <input class="form-check-input" type="radio" name="tickets_required" id="tickets_no" value="no" checked="1"/>
                                    <label class="form-check-label" for="tickets_no">No</label>
                                </div>
                            </div>
                        </div>

                        <!-- Traveling Schedule -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <div class="table-responsive">
                                    <table class="table table-bordered text-center align-middle" style="min-width: 800px;">
                                        <thead style="background-color: #8D0000; color: white;">
                                            <tr>
                                                <th colspan="7" class="py-2">Traveling Schedule (give date &amp; time of departure / arrival)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="fw-bold text-start bg-light" style="width: 180px;">Departure From * :</td>
                                                <t t-foreach="range(1, 7)" t-as="i">
                                                    <td><input type="text" t-attf-name="schedule_departure_from_{{i}}" 
                                                               class="form-control form-control-sm border-0 bg-transparent text-center" 
                                                               t-att-required="i == 1"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival (Destination) * :</td>
                                                <t t-foreach="range(1, 7)" t-as="i">
                                                    <td><input type="text" t-attf-name="schedule_arrival_destination_{{i}}" 
                                                               class="form-control form-control-sm border-0 bg-transparent text-center" 
                                                               t-att-required="i == 1"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival Date * :</td>
                                                <t t-foreach="range(1, 7)" t-as="i">
                                                    <td><input type="date" t-attf-name="schedule_arrival_date_{{i}}" 
                                                               class="form-control form-control-sm border-0 bg-transparent text-center" 
                                                               t-att-required="i == 1"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival Time * :</td>
                                                <t t-foreach="range(1, 7)" t-as="i">
                                                    <td><input type="time" t-attf-name="schedule_arrival_time_{{i}}" 
                                                               class="form-control form-control-sm border-0 bg-transparent text-center" 
                                                               t-att-required="i == 1"/></td>
                                                </t>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Important Notes -->
                        <div class="alert alert-warning mb-4">
                            <ul class="mb-0">
                                <li>1) If travel advance is required in T.C. this requisition must reach the Finance Department at least 72 hours in advance.</li>
                                <li>2) Admin Department will normally require 3 days notice to arrange tickets.</li>
                            </ul>
                        </div>

                        <!-- Admin Remarks Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Administration Section</h5>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="fw-bold">Employee Remarks</label>
                                <textarea name="admin_remarks" class="form-control" rows="3" placeholder="Enter any additional information..."></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="/my/travel" class="btn btn-secondary">Discard</a>
                            <button type="submit" class="btn btn-primary px-4">Submit Request</button>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>
    <template id="travel_request_detail_template">
        <t t-call="portal.portal_layout" t-if="page_name == 'travel_request_detail_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my/travel" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Travel Request Detail</h3>
                <span t-attf-class="ms-3 badge rounded-pill pt-2 {{ 'bg-success' if request_rec.request_status == 'approved' else 'bg-danger' if request_rec.request_status == 'refused' else 'bg-warning text-dark' }}">
                    <t t-esc="dict(request_rec.fields_get(['request_status'])['request_status']['selection']).get(request_rec.request_status, '')"/>
                </span>
            </div>

            <t t-if="request.params.get('message') == 'approved'">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    Request Approved Successfully!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </t>
            <t t-if="request.params.get('message') == 'refused'">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    Request Refused.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </t>
            <t t-if="request.params.get('message') == 'remarks_saved'">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    Remarks saved successfully!
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </t>

            <div class="d-flex justify-content-start gap-2 mb-3" t-if="is_approver">
                <a t-attf-href="/my/travel/approve/{{request_rec.id}}" class="btn btn-success px-4">Approve</a>
                <a t-attf-href="/my/travel/refuse/{{request_rec.id}}" class="btn btn-danger px-4">Refuse</a>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-body">
                    <form action="/my/travel/update" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="request_id" t-att-value="request_rec.id"/>

                        <!-- Employee Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Employee Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Category</label>
                                <select name="category_id" class="form-control" t-att-disabled="not is_editable">
                                    <t t-foreach="categories" t-as="cat">
                                        <option t-att-value="cat.id" t-att-selected="cat.id == request_rec.category_id.id">
                                            <t t-esc="cat.name"/>
                                        </option>
                                    </t>
                                </select>
                                <t t-if="not is_editable">
                                    <input type="hidden" name="category_id" t-att-value="request_rec.category_id.id"/>
                                </t>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Employee Name</label>
                                <input type="text" class="form-control" t-att-value="employee_name" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Registration No</label>
                                <input type="text" class="form-control" t-att-value="employee_identification_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Department</label>
                                <input type="text" class="form-control" t-att-value="employee_department_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Region</label>
                                <input type="text" class="form-control" t-att-value="employee_work_location_id" readonly="1"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Designation</label>
                                <input type="text" class="form-control" t-att-value="employee_job_id" readonly="1"/>
                            </div>
                        </div>

                        <!-- Period Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Period Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Date From</label>
                                <input type="datetime-local" name="date_start" class="form-control" 
                                       t-att-value="request_rec.date_start.strftime('%Y-%m-%dT%H:%M') if request_rec.date_start else ''" 
                                       t-att-readonly="not is_editable"/>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold">Date To</label>
                                <input type="datetime-local" name="date_end" class="form-control" 
                                       t-att-value="request_rec.date_end.strftime('%Y-%m-%dT%H:%M') if request_rec.date_end else ''" 
                                       t-att-readonly="not is_editable"/>
                            </div>
                        </div>

                        <!-- Travel Section -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="border-bottom pb-2">Travel Section</h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="fw-bold d-block">Travel Mode</label>
                                <t t-foreach="request_rec.fields_get(['travel_mode'])['travel_mode']['selection']" t-as="mode">
                                    <div class="form-check form-check-inline mt-2">
                                        <input class="form-check-input" type="radio" name="travel_mode" 
                                               t-attf-id="mode_{{mode[0]}}" t-att-value="mode[0]" 
                                               t-att-checked="request_rec.travel_mode == mode[0]"
                                               t-att-disabled="not is_editable"/>
                                        <label class="form-check-label" t-attf-for="mode_{{mode[0]}}"><t t-esc="mode[1]"/></label>
                                    </div>
                                </t>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="fw-bold d-block">Travel Request Type</label>
                                <t t-foreach="request_rec.fields_get(['travel_request_type'])['travel_request_type']['selection']" t-as="type_">
                                    <div class="form-check form-check-inline mt-2">
                                        <input class="form-check-input" type="radio" name="travel_request_type" 
                                               t-attf-id="type_{{type_[0]}}" t-att-value="type_[0]" 
                                               t-att-checked="request_rec.travel_request_type == type_[0]"
                                               t-att-disabled="not is_editable"/>
                                        <label class="form-check-label" t-attf-for="type_{{type_[0]}}"><t t-esc="type_[1]"/></label>
                                    </div>
                                </t>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="fw-bold d-block">Tickets Required?</label>
                                <t t-set="tickets_selection" t-value="[('yes', 'Yes'), ('no', 'No')]"/>
                                <t t-foreach="tickets_selection" t-as="t_sel">
                                    <div class="form-check form-check-inline mt-2">
                                        <input class="form-check-input" type="radio" name="tickets_required" 
                                               t-attf-id="tickets_{{t_sel[0]}}" t-att-value="t_sel[0]" 
                                               t-att-checked="request_rec.tickets_required == t_sel[0]"
                                               t-att-disabled="not is_editable"/>
                                        <label class="form-check-label" t-attf-for="tickets_{{t_sel[0]}}"><t t-esc="t_sel[1]"/></label>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <!-- Traveling Schedule -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <div class="table-responsive">
                                    <t t-set="schedule_lines" t-value="request_rec.travel_schedule_ids"/>
                                    <table class="table table-bordered text-center align-middle" style="min-width: 800px;">
                                        <thead style="background-color: #8D0000; color: white;">
                                            <tr>
                                                <th colspan="7" class="py-2">Traveling Schedule (give date &amp; time of departure / arrival)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td class="fw-bold text-start bg-light" style="width: 180px;">Departure From * :</td>
                                                <t t-foreach="range(0, 6)" t-as="idx">
                                                    <t t-set="line" t-value="schedule_lines[idx] if len(schedule_lines) &gt; idx else False"/>
                                                    <td><input type="text" t-attf-name="schedule_departure_from_{{idx+1}}" 
                                                               t-att-value="line.departure_from if line else ''"
                                                               class="form-control form-control-sm border-0 bg-transparent text-center"
                                                               t-att-readonly="not is_editable"
                                                               t-att-required="is_editable and idx == 0"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival (Destination) * :</td>
                                                <t t-foreach="range(0, 6)" t-as="idx">
                                                    <t t-set="line" t-value="schedule_lines[idx] if len(schedule_lines) &gt; idx else False"/>
                                                    <td><input type="text" t-attf-name="schedule_arrival_destination_{{idx+1}}" 
                                                               t-att-value="line.arrival_destination if line else ''"
                                                               class="form-control form-control-sm border-0 bg-transparent text-center"
                                                               t-att-readonly="not is_editable"
                                                               t-att-required="is_editable and idx == 0"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival Date * :</td>
                                                <t t-foreach="range(0, 6)" t-as="idx">
                                                    <t t-set="line" t-value="schedule_lines[idx] if len(schedule_lines) &gt; idx else False"/>
                                                    <td><input type="date" t-attf-name="schedule_arrival_date_{{idx+1}}" 
                                                               t-att-value="line.arrival_date if line else ''"
                                                               class="form-control form-control-sm border-0 bg-transparent text-center"
                                                               t-att-readonly="not is_editable"
                                                               t-att-required="is_editable and idx == 0"/></td>
                                                </t>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold text-start bg-light">Arrival Time * :</td>
                                                <t t-foreach="range(0, 6)" t-as="idx">
                                                    <t t-set="line" t-value="schedule_lines[idx] if len(schedule_lines) &gt; idx else False"/>
                                                    <td><input type="time" t-attf-name="schedule_arrival_time_{{idx+1}}" 
                                                               t-att-value="line.arrival_time if line else ''"
                                                               class="form-control form-control-sm border-0 bg-transparent text-center"
                                                               t-att-readonly="not is_editable"
                                                               t-att-required="is_editable and idx == 0"/></td>
                                                </t>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Important Notes -->
                        <div class="alert alert-warning mb-4">
                            <ul class="mb-0">
                                <li>1) If travel advance is required in T.C. this requisition must reach the Finance Department at least 72 hours in advance.</li>
                                <li>2) Admin Department will normally require 3 days notice to arrange tickets.</li>
                            </ul>
                        </div>


                        <div class="d-flex justify-content-end gap-2 mt-4" t-if="is_editable">
                            <a href="/my/travel" class="btn btn-secondary">Discard</a>
                            <button type="submit" class="btn btn-primary px-4">Update &amp; Submit</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Administration Section — alag card, Finance&Admin ke liye editable, baaki ke liye readonly -->
            <div class="card shadow-sm mt-3">
                <div class="card-header fw-bold">Administration Section</div>
                <div class="card-body">
                    <label class="fw-bold mb-2">Admin Remarks</label>
                    <t t-if="is_finance_admin">
                        <form t-attf-action="/my/travel/save_remarks/{{request_rec.id}}" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <textarea name="admin_remarks" class="form-control" rows="3"
                                      placeholder="Enter administration remarks..."><t t-esc="request_rec.admin_remarks"/></textarea>
                            <div class="mt-3 d-flex justify-content-end">
                                <button type="submit" class="btn btn-primary px-4">Save Remarks</button>
                            </div>
                        </form>
                    </t>
                    <t t-else="">
                        <textarea class="form-control" rows="3" readonly="1"><t t-esc="request_rec.admin_remarks or ''"/></textarea>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>

