<odoo>
    <record id="view_deduction_adjustment_form" model="ir.ui.view">
        <field name="name">deduction.adjustment.form</field>
        <field name="model">deduction.adjustment</field>
        <field name="arch" type="xml">
            <form string="Deduction Adjustment">
                <group>
                    <field name="employee_name"/>
                    <field name="emp_no"/>
                    <field name="date"/>
                    <field name="other_deduction"/>
                    <field name="meal_deduction"/>
                </group>
            </form>
        </field>
    </record>

    <record id="view_deduction_adjustment_list" model="ir.ui.view">
        <field name="name">deduction.adjustment.list</field>
        <field name="model">deduction.adjustment</field>
        <field name="arch" type="xml">
            <list string="Deduction Adjustment">
                    <field name="employee_name"/>
                    <field name="emp_no"/>
                    <field name="date"/>
                    <field name="other_deduction"/>
                    <field name="meal_deduction"/>
            </list>
        </field>
    </record>

    <record id="action_deduction_adjustment" model="ir.actions.act_window">
        <field name="name">Deduction Adjustment</field>
        <field name="res_model">deduction.adjustment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_deduction_adjustment" name="Deduction Adjustment Data"
              parent="hr_work_entry_contract_enterprise.menu_hr_payroll_root"
              action="action_deduction_adjustment"/>

    <menuitem id="menu_deduction_adjustment_root" name="Deduction Adjustment"
              sequence="2"/>

    <menuitem id="menu_deduction_adjustment_sub" name="Deduction Adjustment Data"
              parent="menu_deduction_adjustment_root" action="action_deduction_adjustment"/>

    <menuitem id="menu_payroll_deduction_adjustment_p" name="Process Deductions"
              parent="aesl_deduction_adjustment.menu_deduction_adjustment_root"
              sequence="100"/>

    <menuitem id="menu_process_deductions_p" name="Process Deductions"
              parent="menu_payroll_deduction_adjustment_p"
              action="get_process_deductions" sequence="10"/>

</odoo>
