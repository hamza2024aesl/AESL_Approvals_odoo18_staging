<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <template id="reset_password_template" inherit_id="portal.side_content">
        <xpath expr="//a[contains(@href, '/my/account')]" position="attributes">
            <attribute name="class">d-none</attribute>
        </xpath>
        <xpath expr="//a[@href='/my/account']" position="after">
            <br/>
            <a role="button" href="#" data-bs-toggle="modal" data-bs-target="#reset_password_modal"><i class="fa fa-key"></i> Reset Password</a>

            <div class="modal fade" id="reset_password_modal" tabindex="-1" aria-labelledby="reset_password_modal_title" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="reset_password_modal_title">Reset Password</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="reset_password_form" method="post">
                                <div class="row o_portal_details">
                                    <div>
                                        <div class="row">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="current_password">
                                                    Current Password
                                                </label>
                                                <input
                                                    type="password"
                                                    id="current_password_id"
                                                    name="current_password"
                                                    t-attf-class="form-control description-input"
                                                    placeholder="Current Password"
                                                >
                                                </input>
                                            </div>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="new_password">
                                                    New Password
                                                </label>
                                                <input
                                                    type="password" id="new_password_id"
                                                    name="new_password"
                                                    t-attf-class="form-control description-input"
                                                    placeholder="New Password"
                                                >
                                                </input>
                                            </div>
                                            <div t-attf-class="mb-3 col-xl-12">
                                                <label class="col-form-label" for="confirm_password">
                                                    Confirm Password
                                                </label>
                                                <input
                                                    type="password" id="confirm_password_id"
                                                    name="confirm_password"
                                                    t-attf-class="form-control description-input"
                                                    placeholder="Confirm Password"
                                                >
                                                </input>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <button type="submit"
                                    t-attf-form="reset_password_form" value="Update"
                                    class="btn btn-primary">
                                Reset
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>