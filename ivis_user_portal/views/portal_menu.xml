                    <t t-set="text">Click here</t>
                    <t t-set="url" t-value="'#'"/>
                    <t t-set="config_card" t-value="True"/>
                </t> -->
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-attendance-64.png'"/>
                    <t t-set="title">Attendances</t>
                    <t t-set="text">Manage your Attendances</t>
                    <t t-set="url" t-value="'/my/attendance'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-leave-64.png'"/>
                    <t t-set="title">Leaves</t>
                    <t t-set="text">Manage your Leaves</t>
                    <t t-set="url" t-value="'/my/leaves'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-payment-64.png'"/>
                    <t t-set="title">Payslips</t>
                    <t t-set="text">Manage your Payslips</t>
                    <t t-set="url" t-value="'/my/payslips'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-assets-64.png'"/>
                    <t t-set="title">Loans</t>
                    <t t-set="text">Manage your Loans</t>
                    <t t-set="url" t-value="'/my/loans'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                 <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-performance-64.png'"/>
                    <t t-set="title">Appraisal</t>
                    <t t-set="text">Manage your Appraisal</t>
                    <t t-set="url" t-value="'/my/appraisal'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-employee-64.png'"/>
                    <t t-set="title">My Profile</t>
                    <t t-set="text">Manage your Profile</t>
                    <t t-set="url" t-value="'/my/profile'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>
    <template id="portal_breadcrumbs" inherit_id="portal.portal_breadcrumbs">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'attendance_list_view'" class="breadcrumb-item">Attendances</li>
            <li t-elif="page_name == 'leave_list_view'" class="breadcrumb-item">Leaves &amp; Allocations</li>
            <!--            <li t-elif="page_name == 'profile_form_view'" class="breadcrumb-item">Profile</li>-->
