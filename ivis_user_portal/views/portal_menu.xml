<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <template id="portal_my_home_attendance" name="Show Attendances" inherit_id="portal.portal_my_home"
              customize_show="True">
        <xpath expr="//div[hasclass('o_portal_my_home')]" position="after">
            <div id="loading-screen" class="hidden">
                <div id="loading-icon"></div>
            </div>
        </xpath>
        <xpath expr="//div[@id='portal_common_category']" position="after">

            <div class="o_portal_category row g-2 mt-3" id="portal_custom_category">
                <!-- <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/ivis_user_portal/static/description/icons/icons8-sign-in-64.png'"/>
