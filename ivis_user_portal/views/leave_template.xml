<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <!--    <template id="portal_breadcrumbs" inherit_id="portal.portal_breadcrumbs">-->
    <!--        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">-->
    <!--            <li t-if="page_name == 'leave_list_view'" class="breadcrumb-item">Leaves</li>-->
    <!--        </xpath>-->
    <!--    </template>-->

    <template id="leave_list_view_portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1" style="margin-right:auto">Leaves</h3>
                <div class="d-flex align-items-center ms-3">
                    <!--                    <div t-if="is_manager"-->
                    <!--                         class="form-check form-switch form-switch-lg me-3 leave-sub-switch-container">-->
                    <!--                        <label class="form-check-label" for="subOrdinatesSwitch">Sub-Ordinates</label>-->
                    <!--                        <div class="form-check form-switch form-switch-lg">-->
                    <!--                            <input-->
                    <!--                                    class="form-check-input"-->
                    <!--                                    type="checkbox"-->
                    <!--                                    id="leave-sub-ordinates"-->
                    <!--                            />-->
                    <!--                        </div>-->
                    <!--                    </div>-->
                    <div class="btn-group ms-auto leave-groupby-container">
                        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Group By
                        </button>
                        <div class="dropdown-menu p-3">
                            <div class="form-check">
                                <input class="form-check-input group-by-checkbox-leaves" type="checkbox" value="month"
                                       id="groupByMonth"/>
                                <label class="form-check-label" for="groupByMonth">Month</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input group-by-checkbox-leaves" type="checkbox" value="year"
                                       id="groupByYear"/>
                                <label class="form-check-label" for="groupByYear">Year</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input group-by-checkbox-leaves" type="checkbox" value="type"
                                       id="groupByType"/>
                                <label class="form-check-label" for="groupByType">Type</label>
                            </div>
                            <div t-if="is_manager and subordinate" class="form-check">
                                <input class="form-check-input group-by-checkbox-leaves" type="checkbox"
                                       value="employee"
                                       id="groupByEmp"/>
                                <label class="form-check-label" for="groupByEmp">Employee</label>
                            </div>
                        </div>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                    <t t-if="request.env.user.employee_id.company_id.allow_portal_leaves_management">
                        <a t-if="request.env.user.employee_id.child_ids"
                           href="/my/leaves/manage"
                           class="btn btn-primary"
                           id="manage_leaves"
                           title="Manage Leaves"
                           style="margin-left: auto;
                                   border: none;
                                   border-radius: 0.25rem;
                                   padding: 0px 10px 0px 10px;
                                   display: inline-flex;
                                   justify-content: center;
                                   align-items: center;
                                   position: relative;"
                        >
                            <t t-if="manage_leaves_count">
                                <span class="notification-bubble">
                                    <t t-if="manage_leaves_count > 9">9</t>
                                    <t t-else="" t-esc="manage_leaves_count"/>
                                </span>
                            </t>
                            Manage
                        </a>
                    </t>
                    <button
                            class="btn-primary"
                            id="create_leave"
                            title="Create Leave"
                            style=" border: none;
                                border-radius: 0.25rem; 
                                padding: 0px 10px 0px 10px"
                    >
                        Apply
                    </button>
                </t>
            </div>
            <br/>
            <form method="post" id="leave_form" action="/my/leaves/apply" style="display: none; opacity: 1">
                <div class="row o_portal_details">
                    <div>
                        <div class="row">
                            <div id="already_booked_id" style="display: none">
                                <p class="alert alert-danger">Days are already booked</p>
                            </div>
                            <div id="duration_error_id" style="display: none">
                                <p class="alert alert-warning">
                                    Date is invalid
                                </p>
                            </div>
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="timeoff">Time Off Type</label>
                                <select id="time_off_type" name="timeoff" class="form-select">
                                    <t t-foreach="leaves_types" t-as="leave">
                                        <option t-att-value="leave.id">
                                            <t t-out="leave.display_name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="name">Description</label>
                                <input type="text" id="desc_id" name="desc"
                                       t-attf-class="form-control description-input" placeholder="Description">
                                </input>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="date">From</label>
                                <input type="date" id="date_from_id" name="date_from"
                                       class="form-control compute-duration" placeholder="From"/>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="date">To</label>
                                <input type="date" id="date_to_id" name="date_to" class="form-control compute-duration"
                                       placeholder="To"/>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="date_from_period_id">Period</label>
                                <select id="date_from_period_id" name="date_from_period" class="form-select">
                                    <option value="am">Morning</option>
                                    <option value="pm">Afternoon</option>
                                </select>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="duration">Duration</label>
                                <input type="number" id="duration_id" name="duration" class="form-control"
                                       placeholder="0"
                                       readonly="1"/>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="half_day">Half Day</label>
                                <div class="form-check form-switch form-switch-lg">
                                    <input
                                            type="checkbox"
                                            id="half_day"
                                            name="half_day"
                                            class="form-check-input"
                                            style="width:3em;height:1.5em"
                                    />
                                </div>
                            </div>
                        </div>
                        <div class="clearfix text-end mb-5">
                            <a id="discard_form" href="/my" class="btn btn-secondary me-2">
                                Discard
                            </a>
                            <button id="submit_leave_id" type="submit" class="btn btn-primary float-end" disabled="0">
                                Apply
                            </button>
                        </div>
                    </div>
                </div>
                <div style="border-bottom: 1px solid purple; margin-bottom: 40px"/>
            </form>
            <t t-if="not leaves">
                <p class="alert alert-warning">There are currently no leaves.</p>
            </t>
            <t t-call="ivis_user_portal.leaves_table"/>
        </t>
    </template>

    <template id="leaves_manage_portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my/leaves" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1 me-auto">Manage Leaves</h3>
                <div class="btn-group ms-auto leave-groupby-container">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Group By
                    </button>
                    <div class="dropdown-menu p-3">
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-leaves-manage" type="checkbox"
                                   value="month"
                                   id="groupByMonth"/>
                            <label class="form-check-label" for="groupByMonth">Month</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-leaves-manage" type="checkbox" value="year"
                                   id="groupByYear"/>
                            <label class="form-check-label" for="groupByYear">Year</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-leaves-manage" type="checkbox" value="type"
                                   id="groupByType"/>
                            <label class="form-check-label" for="groupByType">Type</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-leaves-manage" type="checkbox"
                                   value="subordinate"
                                   id="groupBySubordinate"/>
                            <label class="form-check-label" for="groupBySubordinate">Subordinate</label>
                        </div>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                </t>
            </div>
            <br/>
            <t t-if="not leaves">
                <p class="alert alert-warning">There are currently no leaves for you to manage.</p>
            </t>
            <t t-call="ivis_user_portal.leaves_table">
                <t t-if="request.httprequest.path == '/my/leaves/manage'">
                    <t t-set="approval_button" t-value="1"/>
                </t>
            </t>
        </t>
    </template>

    <template id="leaves_table">
        <t t-if="error_message">
            <div class="alert alert-danger" role="alert">
                <t t-esc="error_message"/>
            </div>
        </t>
        <t t-call="portal.portal_table">
            <t t-if="leaves">
                <thead>
                    <tr class="active">
                        <th>Name</th>
                        <th>Time Off Type</th>
                        <th>Description</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Duration</th>
                        <th class="text-right">Status</th>
                        <th class="text-right"/>
                        <t t-if="approval_button">
                            <th class="text-right"/>
                        </t>
                    </tr>
                </thead>
                <tbody>
                    <t t-if="grouped_leaves">
                        <t t-foreach="grouped_leaves.items()" t-as="group">
                            <tr class="bg-light">
                                <td colspan="11">
                                    <button class="btn btn-link btn-sm leave-expand-btn" t-att-data-group-id="group[0]">
                                        <i class="fa fa-plus leave-expand-icon"/>
                                    </button>
                                    <strong>
                                        <t t-if="group_by == 'month'">
                                            Month:
                                            <t t-out="group[0]"/>
                                            (<t t-out="len(group[1])"/>)
                                        </t>
                                        <t t-elif="group_by == 'year'">
                                            Year:
                                            <t t-out="group[0]"/>
                                            (<t t-out="len(group[1])"/>)
                                        </t>
                                        <t t-elif="group_by == 'type'">
                                            <t t-out="group[0]"/>
                                            (<t t-out="len(group[1])"/>)
                                        </t>
                                        <t t-elif="group_by == 'subordinate'">
                                            <t t-out="group[0]"/>
                                            (<t t-out="len(group[1])"/>)
                                        </t>
                                    </strong>
                                </td>
                            </tr>
                            <t t-foreach="group[1]" t-as="leave">
                                <tr t-attf-data-group-id="{{group[0]}}" class="leave-group-row" style="display: none;">
                                    <td style="padding-left: 25px;">
                                        <button class="btn btn-link btn-sm row-expand-btn"
                                                t-att-data-leave-id="leave.id">
                                            <i class="fa fa-plus row-expand-icon"/>
                                        </button>
                                        <img t-if="leave.employee_id.image_1920"
                                             t-att-src="image_data_uri(leave.employee_id.image_1920)"
                                             class="rounded img-fluid mx-2"
                                             style="width: 24px;" alt="Profile"/>
                                        <img t-else=""
                                             src="/hr/static/src/img/default_image.png"
                                             class="rounded img-fluid mx-2"
                                             style="width: 24px;" alt="Default Avatar"/>
                                        <t t-out="leave.employee_id.name"/>
                                    </td>
                                    <td>
                                        <t t-out="leave.holiday_status_id.name"/>
                                    </td>
                                    <td>
                                        <t t-out="leave.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="leave.request_date_from.strftime(date_format)"/>
                                    </td>
                                    <td>
                                        <t t-esc="leave.request_date_to.strftime(date_format)"/>
                                    </td>
                                    <td>
                                        <t t-out="leave.duration_display"/>
                                    </td>
                                    <td class="text-right leave-states">
                                        <t>
                                            <span t-if="leave.state == 'validate'"
                                                  class="badge rounded-pill text-bg-success">
                                                <i class="fa fa-fw fa-check" aria-label="Approved" title="Approved"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Approved</span>
                                            </span>
                                            <span t-if="leave.state == 'validate1'"
                                                  class="badge rounded-pill text-bg-warning">
                                                <i class="fa fa-fw fa-clock-o" aria-label="Second Approval"
                                                   title="Second Approval"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Second Approval</span>
                                            </span>
                                            <span t-if="leave.state == 'confirm'"
                                                  class="badge rounded-pill text-bg-warning">
                                                <i class="fa fa-fw fa-clock-o" aria-label="To Approve"
                                                   title="To Approve"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">To Approve</span>
                                            </span>
                                            <span t-if="leave.state == 'draft'" class="badge rounded-pill text-bg-info">
                                                <i class="fa fa-fw fa-arrow-circle-right" aria-label="To Submit"
                                                   title="To Submit"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">To Submit</span>
                                            </span>
                                            <span t-if="leave.state == 'refuse'"
                                                  class="badge rounded-pill text-bg-light">
                                                <i class="fa fa-fw fa-remove" aria-label="Refused" title="Refused"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Refused</span>
                                            </span>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="(leave.request_date_from > date_today and leave.state != 'refuse') or request.httprequest.path == '/my/leaves/manage'">
                                            <button t-attf-id="{{leave.id}}" class="btn-close cancel-leave"
                                                    style="background-color: transparent; opacity: 1; filter: invert(12%) sepia(100%) saturate(7500%) hue-rotate(0deg);">
                                                <i class="fa"/>
                                            </button>
                                        </t>
                                        <t t-else="">

                                        </t>
                                    </td>
                                    <t t-if="approval_button">
                                        <td class="text-center">
                                            <button t-attf-id="{{leave.id}}" class="btn-approve approve-leave"
                                                    style="background-color: transparent; opacity: 1;"/>
                                        </td>
                                    </t>
                                </tr>
                                <t t-set="colspan" t-value="approval_button and 9 or 8"/>
                                <tr t-attf-id="details-row-{{leave.id}}" class="details-row" style="display: none;">
                                    <td style="padding-left: 100px;" t-att-colspan="colspan">
                                        <div class="px-2 py-1">
                                            <table class="table table-sm table-borderless align-middle mb-0">
                                                <thead class="text-muted small">
                                                    <tr>
                                                        <th>Leave Type</th>
                                                        <th>Entitled</th>
                                                        <th>Availed</th>
                                                        <th>Balance</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="small">
                                                    <t t-set="leave_lines" t-value="leave_lines_map.get(leave.id, [])"/>
                                                    <t t-foreach="leave_lines" t-as="line">
                                                        <tr>
                                                            <td>
                                                                <t t-out="line['leave_type']"/>
                                                            </td>
                                                            <td>
                                                                <t t-out="line['available_leave']"/>
                                                            </td>
                                                            <td>
                                                                <t t-out="line['availed_leave']"/>
                                                            </td>
                                                            <td>
                                                                <t t-out="line['balance_leave']"/>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </t>

                    <t t-foreach="leaves" t-as="leave" t-if="leaves and not grouped_leaves">
                        <tr>
                            <td>
                                <button class="btn btn-link btn-sm row-expand-btn" t-att-data-leave-id="leave.id">
                                    <i class="fa fa-plus row-expand-icon"/>
                                </button>
                                <img t-if="leave.employee_id.image_1920"
                                     t-att-src="image_data_uri(leave.employee_id.image_1920)"
                                     class="rounded img-fluid mx-2"
                                     style="width: 24px;" alt="Profile"/>
                                <img t-else=""
                                     src="/hr/static/src/img/default_image.png"
                                     class="rounded img-fluid mx-2"
                                     style="width: 24px;" alt="Default Avatar"/>
                                <t t-out="leave.employee_id.name"/>
                            </td>
                            <td>
                                <t t-out="leave.holiday_status_id.name"/>
                            </td>
                            <td>
                                <t t-out="leave.name"/>
                            </td>
                            <td>
                                <t t-esc="leave.request_date_from.strftime(date_format)"/>
                            </td>
                            <td>
                                <t t-esc="leave.request_date_to.strftime(date_format)"/>
                            </td>
                            <td>
                                <t t-out="leave.duration_display"/>
                            </td>
                            <td class="text-right leave-states">
                                <t>
                                    <span t-if="leave.state == 'validate'" class="badge rounded-pill text-bg-success">
                                        <i class="fa fa-fw fa-check" aria-label="Approved" title="Approved" role="img"/>
                                        <span class="d-none d-md-inline">Approved</span>
                                    </span>
                                    <span t-if="leave.state == 'validate1'" class="badge rounded-pill text-bg-warning">
                                        <i class="fa fa-fw fa-clock-o" aria-label="Second Approval"
                                           title="Second Approval"
                                           role="img"/>
                                        <span class="d-none d-md-inline">Second Approval</span>
                                    </span>
                                    <span t-if="leave.state == 'confirm'" class="badge rounded-pill text-bg-warning">
                                        <i class="fa fa-fw fa-clock-o" aria-label="To Approve" title="To Approve"
                                           role="img"/>
                                        <span class="d-none d-md-inline">To Approve</span>
                                    </span>
                                    <span t-if="leave.state == 'draft'" class="badge rounded-pill text-bg-info">
                                        <i class="fa fa-fw fa-arrow-circle-right" aria-label="To Submit"
                                           title="To Submit"
                                           role="img"/>
                                        <span class="d-none d-md-inline">To Submit</span>
                                    </span>
                                    <span t-if="leave.state == 'refuse'" class="badge rounded-pill text-bg-light">
                                        <i class="fa fa-fw fa-remove" aria-label="Refused" title="Refused" role="img"/>
                                        <span class="d-none d-md-inline">Refused</span>
                                    </span>
                                </t>
                            </td>
                            <td class="text-right">
                                <t t-if="(leave.request_date_from > date_today and leave.state != 'refuse') or request.httprequest.path == '/my/leaves/manage'">
                                    <button t-attf-id="{{leave.id}}" class="btn-close cancel-leave"
                                            style="background-color: transparent; opacity: 1; filter: invert(12%) sepia(100%) saturate(7500%) hue-rotate(0deg);">
                                        <i class="fa"/>
                                    </button>
                                </t>
                                <t t-else="">

                                </t>
                            </td>
                            <t t-if="approval_button">
                                <td class="text-center">
                                    <button t-attf-id="{{leave.id}}" class="btn-approve approve-leave"
                                            style="background-color: transparent; opacity: 1;"/>
                                </td>
                            </t>
                        </tr>
                        <t t-set="colspan" t-value="approval_button and 9 or 8"/>
                        <tr t-attf-id="details-row-{{leave.id}}" class="details-row" style="display: none;">
                            <td style="padding-left: 75px;" t-att-colspan="colspan">
                                <div class="px-2 py-1">
                                    <table class="table table-sm table-borderless align-middle mb-0">
                                        <thead class="text-muted small">
                                            <tr>
                                                <th>Leave Type</th>
                                                <th>Entitled</th>
                                                <th>Availed</th>
                                                <th>Balance</th>
                                            </tr>
                                        </thead>
                                        <tbody class="small">
                                            <t t-set="leave_lines" t-value="leave_lines_map.get(leave.id, [])"/>
                                            <t t-foreach="leave_lines" t-as="line">
                                                <tr>
                                                    <td>
                                                        <t t-out="line['leave_type']"/>
                                                    </td>
                                                    <td>
                                                        <t t-out="line['available_leave']"/>
                                                    </td>
                                                    <td>
                                                        <t t-out="line['availed_leave']"/>
                                                    </td>
                                                    <td>
                                                        <t t-out="line['balance_leave']"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>
</odoo>