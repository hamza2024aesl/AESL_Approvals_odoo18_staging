<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <template id="appraisal_list_view_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'view_appraisal_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Appraisals</h3>
                <div class="btn-group ms-auto appraisals-subordinates-container">
                    <div t-if="is_manager" class="form-check form-switch form-switch-lg me-3">
                        <input class="form-check-input" type="checkbox" id="appraisals-sub-ordinates"/>
                        <label class="form-check-label" for="subOrdinatesSwitch">Sub-Ordinates</label>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                </t>
            </div>
            <br/>
            <t t-if="not appraisals">
                <p class="alert alert-warning">There are currently no Appraisals.</p>
            </t>
            <t t-call="portal.portal_table">
                <t t-if="appraisals">
                    <thead>
                        <tr class="active text-center">
                            <th>Name</th>
                            <th>Appraisal Deadline</th>
                            <th>Emp. No</th>
                            <th>Designation</th>
                            <th>Manager</th>
                            <th>Emp Type</th>
                            <th>Appointment Date</th>
                            <th>Doc Status</th>
                            <th>Status</th>
                            <th>Gross Salary</th>
                            <th>Recom. Increment</th>
                            <th>Recom. Grade</th>
                            <th>Increment (%)</th>
                            <th>View</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="appraisals" t-as="appraisal">
                            <tr class="text-center">
                                <td>
                                    <span t-out="appraisal.employee_id.name"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.date_close"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.registration_number"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.job_id.name"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.employee_id.parent_id.user_id.name"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.employee_id.contract_id.contract_type_id.code"/>
                                </td>
                                <td>
                                    <span t-out="appraisal.appointment_date"/>
                                </td>
                                <td>
                                    <t t-out="dict(appraisal.fields_get(allfields=['doc_state'])['doc_state']['selection']).get(appraisal.doc_state, '')"/>
                                </td>
                                <td>
                                    <t t-out="dict(appraisal.fields_get(allfields=['state'])['state']['selection']).get(appraisal.state, '')"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.gross_salary"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.recommend_raise_amount"/>
                                </td>
                                <td>
                                    <t t-out="appraisal.recommend_grades"/>
                                </td>
                                <td>
                                   <t t-out="'%.2f' % appraisal.increase_percentage"/>
                                </td>
                                <td>
                                    <a t-attf-href="/my/appraisal/view/{{appraisal.id}}" title="Open Appraisal"
                                       aria-label="Open Appraisal" class="btn btn-sm btn-primary" role="button">
                                        <i class="fa fa-arrow-circle-right"/>
                                        <span class='d-none d-md-inline'>Open Appraisal</span>
                                    </a>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </t>
    </template>

    <template id="appraisal_detail_page_portal">
        <t t-call="portal.portal_layout" t-if="page_name == 'view_appraisal_detail_page'">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my/appraisal" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Appraisal Detail</h3>
            </div>
            <br/>

            <div class="card my-2 shadow-sm">
                <form method="post" action="/my/appraisal/view/save" class="mb-4">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-9">
                                <h5>
                                    <b>Appraisal Summary ( Status: <span t-out="dict(appraisal.fields_get(allfields=['state'])['state']['selection']).get(appraisal.state, '')" class="text-primary"></span> )</b>
                                </h5>
                            </div>
                            <div class="col-md-3">
                                <t t-if="appraisal.state in ['new', 'pending', 'pending2', 'pending3', 'pending4'] and appraisal.employee_id.user_id.id != user.id">
                                    <button type="submit" class="btn btn-primary mt-2 float-end">Submit</button>
                                </t>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-md-6">
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Appraisal Batch'"/>
                                    <t t-set="value"
                                       t-value="appraisal.appraisal_run_ids and ', '.join(appraisal.appraisal_run_ids.mapped('name'))"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Employee Name'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.name"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Grade'"/>
                                    <t t-set="value" t-value="appraisal.grade"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Designation'"/>
                                    <t t-set="value" t-value="appraisal.job_id.name"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Appointment Date'"/>
                                    <t t-set="value" t-value="appraisal.appointment_date"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Gross Salary'"/>
                                    <t t-set="value" t-value="appraisal.gross_salary"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Emp. No.'"/>
                                    <t t-set="value" t-value="appraisal.registration_number"/>
                                </t>
                            </div>

                            <div class="col-md-6">
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Manager Name'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.parent_id.user_id.name"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Emp Type'"/>
                                    <t t-set="value" t-value="appraisal.employee_id.contract_id.contract_type_id.code"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Location'"/>
                                    <t t-set="value" t-value="appraisal.location"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Department'"/>
                                    <t t-set="value" t-value="appraisal.department_id.name"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Casual Leave Availed'"/>
                                    <t t-set="value" t-value="appraisal.cl_count"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Sick Leave Availed'"/>
                                    <t t-set="value" t-value="appraisal.sl_count"/>
                                </t>
                                <t t-call="ivis_user_portal.card_row">
                                    <t t-set="label" t-value="'Earned Leave Balance'"/>
                                    <t t-set="value" t-value="appraisal.earned_leaves_balance"/>
                                </t>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8">
                                <input type="hidden" name="appraisal_id" t-att-value="appraisal.id"/>
                                 <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <h5>
                                    <b>Remarks:</b>
                                    (Work Independently, Analytic, Troubleshooting, Motivation, Technical)
                                </h5>
                                <p>
                                    <t t-if="appraisal.remarks">
                                        <t t-esc="appraisal.remarks"/>
                                        <br/>
                                    </t>
                                    <t t-if="appraisal.remarks_2">
                                        <t t-esc="appraisal.remarks_2"/>
                                        <br/>
                                    </t>
                                    <t t-if="appraisal.remarks_3">
                                        <t t-esc="appraisal.remarks_3"/>
                                        <br/>
                                    </t>
                                    <t t-if="appraisal.remarks_4">
                                        <t t-esc="appraisal.remarks_4"/>
                                        <br/>
                                    </t>
                                    <t t-if="appraisal.remarks_5">
                                        <t t-esc="appraisal.remarks_5"/>
                                        <br/>
                                    </t>
                                </p>
                                <div class="form-group mb-3">
                                    <t t-if="appraisal.state == 'new'">
                                        <input type="text" name="remarks" t-att-value="appraisal.remarks or ''"
                                               class="form-control"/>
                                    </t>
                                    <t t-elif="appraisal.state == 'pending'">
                                        <input type="text" name="remarks_2" t-att-value="appraisal.remarks_2 or ''"
                                               class="form-control"/>
                                    </t>
                                    <t t-elif="appraisal.state == 'pending2'">
                                        <input type="text" name="remarks_3" t-att-value="appraisal.remarks_3 or ''"
                                               class="form-control"/>
                                    </t>
                                    <t t-elif="appraisal.state == 'pending4'">
                                        <input type="text" name="remarks_4" t-att-value="appraisal.remarks_4 or ''"
                                               class="form-control"/>
                                    </t>
                                    <t t-elif="appraisal.state == 'pending3'">
                                        <input type="text" name="remarks_5" t-att-value="appraisal.remarks_5 or ''"
                                               class="form-control"/>
                                    </t>
                                </div>

                                <h5>
                                    <b>Future Prospects:</b>
                                </h5>
                                <div class="form-group mb-3">
                                    <input type="text" name="future_project"
                                           t-att-value="appraisal.future_project or ''"
                                           class="form-control"
                                           t-att-disabled="'disabled' if appraisal.state not in ['new', 'pending3'] else None"/>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <h5>
                                    <b>Bonus</b>
                                </h5>
                                <div class="row">
                                    <div class="col-md-6 mb-2">
                                        <label>Total Points</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="number" name="total_points"
                                               t-att-value="appraisal.total_points or '0'" class="form-control"/>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>Given Points</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="number" name="given_points"
                                               t-att-value="appraisal.given_points or '0'" class="form-control"/>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>Leave Points</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="number" name="leave_points"
                                               t-att-value="appraisal.leave_points or '0'" class="form-control"/>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>Availed Points</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="number" name="availed_points"
                                               t-att-value="appraisal.availed_points or '0'" class="form-control"/>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>Bonus Points</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="number" name="bonus_amount"
                                               t-att-value="appraisal.bonus_amount or '0'" class="form-control"/>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <label>Date Effective</label>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <input type="date" name="date_effective"
                                               t-att-value="appraisal.date_effective or ''" class="form-control"/>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <h5 class="mt-4">
                            <b>Recommend Raises:</b>
                        </h5>

                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th style="width: 30%">Increment</th>
                                    <th style="width: 30%">Designation</th>
                                    <th style="width: 10%">Grade</th>
                                    <th style="width: 15%">Recommended By</th>
                                    <th style="width: 15%">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="appraisal.recomm_increment_lines_id" t-as="line">
                                    <tr>
                                        <td t-esc="line.increment_raise_amount"/>
                                        <td t-esc="line.recomm_desigantion_id.name"/>
                                        <td t-esc="line.recomm_grades"/>
                                        <td t-esc="line.increment_raise_by.name"/>
                                        <td t-esc="line.incremented_date"/>
                                    </tr>
                                </t>
                                <t t-if="appraisal.state != 'draft' and not any(line.increment_raise_by.id == user.id for line in appraisal.recomm_increment_lines_id)">
                                    <tr>
                                        <td>
                                            <input type="number" name="increment_raise_amount" class="form-control"
                                                   step="1.00" t-att-value="0.00"/>
                                        </td>
                                        <td>
                                            <select id="recomm_desigantion_id" class="form-control"
                                                    name="recomm_desigantion_id">
                                                <option t-att-value=""/>
                                                <t t-foreach="desigantions" t-as="desigantion">
                                                    <option t-att-value="desigantion.id" t-esc="desigantion.name"/>
                                                </t>
                                            </select>
                                        </td>
                                        <td>
                                            <input type="number" name="recomm_grades" t-att-value="0"
                                                   class="form-control"/>
                                        </td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </form>
            </div>
        </t>
    </template>

</odoo>