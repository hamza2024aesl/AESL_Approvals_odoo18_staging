    <template id="work_information_template">
        <div id="work-card" class="card-body collapse-content active">
            <p class="mb-4">
                <span class="text-primary font-italic me-1">Work Information</span>
            </p>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Employee Code'"/>
                <t t-set="value" t-value="profile.identification_id"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Biometric Device ID'"/>
                <t t-set="value" t-value="profile.device_id"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Mobile'"/>
                <t t-set="value" t-value="profile.mobile_phone"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Phone'"/>
                <t t-set="value" t-value="profile.work_phone"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Email'"/>
                <t t-set="value" t-value="profile.work_email"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Company'"/>
                <t t-set="value" t-value="profile.company_id.name"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Department'"/>
                <t t-set="value" t-value="profile.department_id.name"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Manager'"/>
                <t t-set="value" t-value="profile.parent_id.name"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Address'"/>
                <t t-set="value" t-value="profile.address_id.name"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Location'"/>
                <t t-set="value" t-value="profile.work_location_id.name"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Work Hours'"/>
                <t t-set="value" t-value="profile.resource_calendar_id.name"/>
                <t t-set="no_hr" t-value="1"/>
            </t>
        </div>
    </template>

    <template id="organizational_chart_template">
        <div id="org-chart-card" class="card-body collapse-content active" style="display:none;">
            <p class="mb-4">
                <span class="text-primary font-italic me-1">Organizational Chart</span>
            </p>
            <div>
                <div class="o_org_chart_container pb-3">
                    <t t-if="parent_chain_ids">
                        <t t-foreach="parent_chain_ids" t-as="current_manager">
                            <t t-set="current_manager" t-value="profile.get_obj_from_id(current_manager)"/>
                            <div class="org_level">
                                <div class="org_box">
                                    <div class="avatar">
                                        <img
                                            t-if="current_manager.image_1920"
                                            t-att-src="image_data_uri(current_manager.image_1920)"
                                            class="img-fluid"
                                            alt="Manager"
                                        />
                                        <img
                                            t-else=""
                                            src="/hr/static/src/img/default_image.png"
                                            class="img-fluid"
                                            alt="Default Avatar"
                                        />
                                    </div>
                                    <div class="name" t-esc="current_manager.name"/>
                                    <div class="position" t-esc="current_manager.job_id.name"/>
                                </div>
                                <div class="org_connector down"/>
                            </div>
                        </t>
                    </t>
                    <!-- Current Employee -->
                    <div class="org_level">
                        <div class="org_box self">
                            <div class="avatar">
                                <img
                                    t-if="profile.image_1920"
                                    t-att-src="image_data_uri(profile.image_1920)"
                                    class="img-fluid"
                                    alt="Employee"
                                />
                                <img
                                    t-else=""
                                    src="/hr/static/src/img/default_image.png"
                                    class="img-fluid"
                                    alt="Default Avatar"
                                />
                            </div>
                            <div class="name" t-esc="profile.name"/>
                            <div class="position" t-esc="profile.job_id.name"/>
                        </div>
                        <t t-if="profile.child_ids">
                            <div class="org_connector down"/>
                        </t>
                    </div>
                    <!-- Subordinates Level -->
                    <t t-if="profile.child_ids">
                        <div id="subordinates"
                             t-attf-class="org_level #{len(profile.child_ids) > 1 and 'has-multiple' or ''}">
                            <t t-foreach="profile.child_ids" t-as="child">
                                <div class="org_box">
                                    <div class="avatar">
                                        <img
                                            t-if="child.image_1920"
                                            t-att-src="image_data_uri(child.image_1920)"
                                            class="img-fluid"
                                            alt="Subordinate"
                                        />
                                        <img
                                            t-else=""
                                            src="/hr/static/src/img/default_image.png"
                                            class="img-fluid"
                                            alt="Default Avatar"
                                        />
                                    </div>
                                    <div class="name" t-esc="child.name"/>
                                    <div class="position" t-esc="child.job_id.name"/>
                                </div>
                            </t>
                        </div>
                    </t>
                    <!-- No hierarchy message -->
                    <t t-if="not profile.parent_id and not profile.child_ids">
                        <div class="alert alert-info text-center" role="alert">
                            <p class="mb-0">No organizational hierarchy found.</p>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </template>

    <template id="pf_information_template">
        <div id="pf-card" class="card-body collapse-content active" style="display:none;">
            <p class="mb-4">
                <span class="text-primary font-italic me-1">Provident Fund</span>
            </p>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Apply Provident Fund'"/>
                <t t-set="value" t-value="'Applied' if profile.apply_provident_fund else 'Not Applied'"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Exclude Interest'"/>
                <t t-set="value" t-value="'Excluded' if profile.exclude_pf_interest else 'Not Excluded'"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Employee Contribution'"/>
                <t t-set="value" t-value="profile.employee_contribution"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Employer Contribution'"/>
                <t t-set="value" t-value="profile.employer_contribution"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Interest'"/>
                <t t-set="value" t-value="profile.interest"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Total'"/>
                <t t-set="value" t-value="profile.total"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Opening Employee Contribution'"/>
                <t t-set="value" t-value="profile.pf_employee"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Opening Employer Contribution'"/>
                <t t-set="value" t-value="profile.pf_employer"/>
            </t>
            <t t-call="ivis_user_portal.card_row">
                <t t-set="label" t-value="'Opening Interest'"/>
                <t t-set="value" t-value="profile.interest"/>
            </t>
        </div>
    </template>


    <!-- Macros -->

    <template id="card_row" name="Field Row">
        <div class="row">
            <div class="col-sm-3">
                <p class="mb-0">
                    <t t-esc="label"/>
                </p>
            </div>
            <div class="col-sm-9">
                <p class="text-muted mb-0">
                    <t t-esc="value"/>
                </p>
            </div>
        </div>
        <t t-if="not no_hr">
            <hr/>
        </t>
    </template>
</odoo>