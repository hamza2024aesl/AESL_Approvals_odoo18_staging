<?xml version="1.0" encoding="UTF-8" ?>

<odoo>

    <!--    <template id="portal_breadcrumbs" inherit_id="portal.portal_breadcrumbs">-->
    <!--        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">-->
    <!--            <li t-if="page_name == 'leave_list_view'" class="breadcrumb-item">Leaves</li>-->
    <!--        </xpath>-->
    <!--    </template>-->

    <template id="loan_list_view_portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1">Loans</h3>
                <div class="btn-group ms-auto loan-groupby-container">
                    <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Group By
                    </button>
                    <div class="dropdown-menu p-3">
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-loan" type="checkbox" value="month" id="groupByMonth"/>
                            <label class="form-check-label" for="groupByMonth">Month</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input group-by-checkbox-loan" type="checkbox" value="year" id="groupByYear"/>
                            <label class="form-check-label" for="groupByYear">Year</label>
                        </div>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                    <button class="btn-primary" id="create_loan"
                            title="Check In"
                            style="margin-left: auto; border: none; border-radius: 0.25rem; padding: 0px 10px 0px 10px">
                        Apply
                    </button>
                </t>
            </div>
            <br/>
            <!--            <div class="col-lg-8">-->
            <form method="post" id="loan_form" style="display: none; opacity: 1">
                <div class="row o_portal_details">
                    <div>
                        <div class="row">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="app-date">Applied Date</label>
                                <input type="text" id="app_date_id" name="app-date" t-attf-class="form-control"
                                       readonly="1" t-att-value="date_today"/>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="loan-type">Loan Type</label>
                                <select id="loan_type" name="loan-type" class="form-select loan-input">
                                    <!--                                    <option>YOU</option>-->
                                    <!--                                    <option>ME</option>-->
                                    <t t-foreach="loan_types" t-as="loan">
                                        <option t-att-value="loan.id">
                                            <t t-out="loan.display_name"/>
                                        </option>
                                    </t>
                                </select>
                            </div>
                            <div t-attf-class="mb-3 col-xl-6">
                                <label class="col-form-label" for="date">Amount - PKR</label>
                                <input type="number" id="req_amt_id" name="requested-amount"
                                       class="form-control loan-input"/>
                            </div>
                        </div>
                        <div class="clearfix text-end mb-5">
                            <a id="discard_form" href="/my" class="btn btn-secondary me-2">
                                Discard
                            </a>
                            <button id="submit_loan_id" type="submit" class="btn btn-primary float-end" disabled="0">
                                Apply
                            </button>
                        </div>
                    </div>
                </div>
                <div style="border-bottom: 1px solid purple; margin-bottom: 40px"/>
            </form>
            <t t-if="not loans">
                <p class="alert alert-warning">There are currently no loans.</p>
            </t>
            <t t-call="portal.portal_table">
                <t t-if="loans">
                    <thead>
                        <tr class="h3">
                            <th colspan="8" class="text-center">Loan History</th>
                        </tr>
                        <tr class="header-separator">
                            <th colspan="2"></th>
                        </tr>
                        <tr class="active">
                            <th>Number</th>
                            <th>Applied Date</th>
                            <th>Approved Date</th>
                            <th>Loan Type</th>
                            <th class="text-right">Requested Amount</th>
                            <th class="text-right">Approved Amount</th>
                            <th class="text-center">Rate</th>
                            <th class="text-right">Total Loan</th>
                            <th class="text-right">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="grouped_loans.items()" t-as="group" t-if="grouped_loans">
                            <tr class="bg-light">
                                <td colspan="11">
                                    <button class="btn btn-link btn-sm loan-expand-btn" t-att-data-group-id="group[0]">
                                        <i class="fa fa-plus loan-expand-icon"/>
                                    </button>
                                    <strong>
                                        <t t-if="group_by == 'month'">
                                            Month:
                                            <t t-out="group[0]"/>
                                        </t>
                                        <t t-elif="group_by == 'year'">
                                            Year:
                                            <t t-out="group[0]"/>
                                        </t>
                                    </strong>
                                </td>
                            </tr>
                            <t t-foreach="group[1]" t-as="loan">
                                <tr t-attf-data-group-id="{{group[0]}}" class="loan-group-row" style="display: none;">
                                    <td style="padding-left: 25px;">
                                        <span t-if="loan.name" t-out="loan.name"/>
                                        <span t-else="" style="color:rgb(23, 162, 184); font-style:italic">Waiting
                                        </span>
                                    </td>
                                    <td>
                                        <t t-out="loan.date_applied"/>
                                    </td>
                                    <td>
                                        <span t-if="loan.date_approved" t-out="loan.date_approved"/>
                                        <span t-else="" style="color:rgb(23, 162, 184); font-style:italic">Waiting
                                        </span>
                                    </td>
                                    <td>
                                        <t t-out="loan.loan_type.name"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-if="loan.principal_amount == 0" t-out="loan.principal_amount"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                              style="color:red"/>
                                        <span t-else="" t-out="loan.principal_amount"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                    </td>
                                    <td class="text-right">
                                        <span t-if="loan.actual_principal_amount == 0"
                                              t-out="loan.actual_principal_amount"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                              style="color:red"/>
                                        <span t-else="" t-out="loan.actual_principal_amount"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                    </td>
                                    <td class="text-center">
                                        <span t-out="loan.int_rate"/>
                                    </td>
                                    <td class="text-right">
                                        <span t-if="loan.final_total == 0" t-out="loan.final_total"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                              style="color:red"/>
                                        <span t-else="" t-out="loan.final_total"
                                              t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                    </td>
                                    <td class="text-right">
                                        <t>
                                            <span t-if="loan.state == 'draft'"
                                                  class="badge rounded-pill text-bg-info">
                                                <i class="fa fa-fw fa-clock-o" aria-label="Waiting" title="Waiting"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Waiting</span>
                                            </span>
                                            <span t-if="loan.state == 'applied'"
                                                  class="badge rounded-pill text-bg-warning">
                                                <i class="fa fa-fw fa-clock-o" aria-label="Applied" title="Applied"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Applied</span>
                                            </span>
                                            <span t-if="loan.state == 'manager_approved'"
                                                  class="badge rounded-pill text-bg-success">
                                                <i class="fa fa-fw fa-check" aria-label="Manager Approved"
                                                   title="Manager Approved" role="img"/>
                                                <span class="d-none d-md-inline">Manager Approved</span>
                                            </span>
                                            <span t-if="loan.state == 'hr_approved'"
                                                  class="badge rounded-pill text-bg-success">
                                                <i class="fa fa-fw fa-check" aria-label="HR Approved"
                                                   title="HR Approved"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">HR Approved</span>
                                            </span>
                                            <span t-if="loan.state == 'final_approved'"
                                                  class="badge rounded-pill text-bg-success">
                                                <i class="fa fa-fw fa-check" aria-label="Final Approved"
                                                   title="Final Approved"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Final Approved</span>
                                            </span>
                                            <span t-if="loan.state == 'paid'"
                                                  class="badge rounded-pill text-bg-primary">
                                                <i class="fa fa-fw fa-check" aria-label="Paid" title="Paid" role="img"/>
                                                <span class="d-none d-md-inline">Paid</span>
                                            </span>
                                            <span t-if="loan.state == 'paid'"
                                                  class="badge rounded-pill text-bg-warning">
                                                <i class="fa fa-fw fa-clock-o" aria-label="Paid" title="Paid"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Paid</span>
                                            </span>
                                            <span t-if="loan.state == 'disburse'"
                                                  class="badge rounded-pill text-bg-warning">
                                                <i class="fa fa-fw fa-clock-o" aria-label="Disbursed" title="Disbursed"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Disbursed</span>
                                            </span>
                                            <span t-if="loan.state == 'rejected'"
                                                  class="badge rounded-pill text-bg-danger">
                                                <i class="fa fa-fw fa-remove" aria-label="Rejected" title="Rejected"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Rejected</span>
                                            </span>
                                            <span t-if="loan.state == 'cancel'"
                                                  class="badge rounded-pill text-bg-secondary">
                                                <i class="fa fa-fw fa-remove" aria-label="Cancelled" title="Cancelled"
                                                   role="img"/>
                                                <span class="d-none d-md-inline">Cancelled</span>
                                            </span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </t>
                        <t t-foreach="loans" t-as="loan" t-if="loans and not grouped_loans">
                            <tr>
                                <td>
                                    <span t-if="loan.name" t-out="loan.name"/>
                                    <span t-else="" style="color:rgb(23, 162, 184); font-style:italic">Waiting</span>
                                </td>
                                <td>
                                    <t t-out="loan.date_applied"/>
                                </td>
                                <td>
                                    <span t-if="loan.date_approved" t-out="loan.date_approved"/>
                                    <span t-else="" style="color:rgb(23, 162, 184); font-style:italic">Waiting</span>
                                </td>
                                <td>
                                    <t t-out="loan.loan_type.name"/>
                                </td>
                                <td class="text-right">
                                    <span t-if="loan.principal_amount == 0" t-out="loan.principal_amount"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                          style="color:red"/>
                                    <span t-else="" t-out="loan.principal_amount"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                </td>
                                <td class="text-right">
                                    <span t-if="loan.actual_principal_amount == 0" t-out="loan.actual_principal_amount"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                          style="color:red"/>
                                    <span t-else="" t-out="loan.actual_principal_amount"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                </td>
                                <td class="text-center">
                                    <span t-out="loan.int_rate"/>
                                </td>
                                <td class="text-right">
                                    <span t-if="loan.final_total == 0" t-out="loan.final_total"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'
                                          style="color:red"/>
                                    <span t-else="" t-out="loan.final_total"
                                          t-options='{"widget": "monetary", "display_currency": loan.currency_id}'/>
                                </td>
                                <td class="text-right">
                                    <t>
                                        <span t-if="loan.state == 'draft'"
                                              class="badge rounded-pill text-bg-info">
                                            <i class="fa fa-fw fa-clock-o" aria-label="Waiting" title="Waiting"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Waiting</span>
                                        </span>
                                        <span t-if="loan.state == 'applied'"
                                              class="badge rounded-pill text-bg-warning">
                                            <i class="fa fa-fw fa-clock-o" aria-label="Applied" title="Applied"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Applied</span>
                                        </span>
                                        <span t-if="loan.state == 'manager_approved'"
                                              class="badge rounded-pill text-bg-success">
                                            <i class="fa fa-fw fa-check" aria-label="Manager Approved"
                                               title="Manager Approved" role="img"/>
                                            <span class="d-none d-md-inline">Manager Approved</span>
                                        </span>
                                        <span t-if="loan.state == 'hr_approved'"
                                              class="badge rounded-pill text-bg-success">
                                            <i class="fa fa-fw fa-check" aria-label="HR Approved" title="HR Approved"
                                               role="img"/>
                                            <span class="d-none d-md-inline">HR Approved</span>
                                        </span>
                                        <span t-if="loan.state == 'final_approved'"
                                              class="badge rounded-pill text-bg-success">
                                            <i class="fa fa-fw fa-check" aria-label="Final Approved"
                                               title="Final Approved"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Final Approved</span>
                                        </span>
                                        <span t-if="loan.state == 'paid'"
                                              class="badge rounded-pill text-bg-primary">
                                            <i class="fa fa-fw fa-check" aria-label="Paid" title="Paid" role="img"/>
                                            <span class="d-none d-md-inline">Paid</span>
                                        </span>
                                        <span t-if="loan.state == 'paid'"
                                              class="badge rounded-pill text-bg-warning">
                                            <i class="fa fa-fw fa-clock-o" aria-label="Paid" title="Paid" role="img"/>
                                            <span class="d-none d-md-inline">Paid</span>
                                        </span>
                                        <span t-if="loan.state == 'disburse'"
                                              class="badge rounded-pill text-bg-warning">
                                            <i class="fa fa-fw fa-clock-o" aria-label="Disbursed" title="Disbursed"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Disbursed</span>
                                        </span>
                                        <span t-if="loan.state == 'rejected'"
                                              class="badge rounded-pill text-bg-danger">
                                            <i class="fa fa-fw fa-remove" aria-label="Rejected" title="Rejected"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Rejected</span>
                                        </span>
                                        <span t-if="loan.state == 'cancel'"
                                              class="badge rounded-pill text-bg-secondary">
                                            <i class="fa fa-fw fa-remove" aria-label="Cancelled" title="Cancelled"
                                               role="img"/>
                                            <span class="d-none d-md-inline">Cancelled</span>
                                        </span>
                                        <!-- <span t-else="" t-out="loan.state"/> -->
                                    </t>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </t>
            </t>
        </t>
    </template>
</odoo>