<odoo>
    <record id="view_config_settings_form_inherit" model="ir.ui.view">
        <field name="name">view.config.settings.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block/setting[@id='allow_import']" position="after">
                <setting id="allow_portal_attendance" help="Allows Portal user to mark attendance.">
                    <field name="allow_portal_attendance"/>
                </setting>
                <setting id="allow_pin_change" help="Allow Portal user to change pin">
                    <field name="allow_pin_change"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>