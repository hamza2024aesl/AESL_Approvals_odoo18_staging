<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <template id="employee_list_view_portal">
        <t t-call="portal.portal_layout">
            <t t-set="no_breadcrumbs" t-value="1"/>
            <div id="loading-screen" class="hidden">
                <div id="loading-icon"/>
            </div>
            <div class="d-flex gap-2 my-3">
                <a href="/my" title="Go Back" class="btn btn-light px-2 mx-2">
                    <i class="oi oi-chevron-left"/>
                </a>
                <h3 class="my-0 mt-1 me-auto">Attendances</h3>

                <div class="d-flex align-items-center ms-3">
                    <div class="form-check form-switch form-switch-lg me-3">
                        <input class="form-check-input"
                               type="checkbox"
                               id="attendance-show-lwp"
                               t-att-checked="'checked' if show_lwp else None"/>
                        <label class="form-check-label" for="attendance-show-lwp">Show LWP</label>
                    </div>
                    <div t-if="is_manager" class="form-check form-switch form-switch-lg me-3">
                        <input class="form-check-input" type="checkbox" id="attendance-sub-ordinates"/>
                        <label class="form-check-label" for="subOrdinatesSwitch">Sub-Ordinates</label>
                    </div>
                    <div class="btn-group attendance-groupby-container">
                        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Group By
                        </button>
                        <div class="dropdown-menu p-3">
                            <div class="form-check">
                                <input class="form-check-input group-by-checkbox-attendances" type="checkbox"
                                       value="month"
                                       id="groupByMonth"/>
                                <label class="form-check-label" for="groupByMonth">Month</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input group-by-checkbox-attendances" type="checkbox"
                                       value="year"
                                       id="groupByYear"/>
                                <label class="form-check-label" for="groupByYear">Year</label>
                            </div>
                            <div t-if="is_manager and subordinate" class="form-check">
                                <input class="form-check-input group-by-checkbox-attendances" type="checkbox"
                                       value="employee"
                                       id="groupByEmp"/>
                                <label class="form-check-label" for="groupByEmp">Employee</label>
                            </div>
                        </div>
                    </div>
                </div>
                <t t-call="portal.portal_searchbar">
                    <t t-set="title">&#8203;</t>
                    <t t-if="request.env.user.employee_id.company_id.allow_portal_attendance">
                        <button id="check_inout_portal"
                                class="o_hr_attendance_sign_in_out_icon btn btn-secondary btn-fill-success"
                                title="Check In"
                                style="margin-left:auto; padding: 0px 10px 0px 10px;">
                            <i class="fa fa-sign-in me-1"/>
                            Check In/Out
                        </button>
                    </t>
                </t>
            </div>
            <!-- Grouped Attendance List -->
            <t t-if="not attendances">
                <p class="alert alert-warning">There are currently no attendances.</p>
            </t>

            <t t-call="portal.portal_table">
                <t t-if="attendances">
                    <thead>
                        <tr class="active">
                            <th>Name</th>
                            <th class="text-right">Check In</th>
                            <th class="text-right">Check Out</th>
                            <!--                            <th class="text-right">Status</th>-->
                            <th class="text-right">Status</th>
                            <th class="text-right">In Status</th>
                            <th class="text-right">Out Status</th>
                            <th class="text-right">Attendance Status</th>
                            <!--                            <th class="text-right">On Leave</th>-->
                            <th class="text-right">Process</th>
                        </tr>
                    </thead>
                </t>
                <tbody>
                    <t t-if="grouped_attendances">
                        <t t-foreach="grouped_attendances.items()" t-as="group">
                            <!-- Group Header -->
                            <tr class="bg-light">
                                <td colspan="11">
                                    <button class="btn btn-link btn-sm attendance-expand-btn"
                                            t-att-data-group-id="group[0]">
                                        <i class="fa fa-plus attendance-expand-icon"/>
                                    </button>
                                    <strong>
                                        <t t-if="group_by == 'month'">
                                            Month:
                                            <t t-out="group[0]"/>
                                        </t>
                                        <t t-elif="group_by == 'year'">
                                            Year:
                                            <t t-out="group[0]"/>
                                        </t>
                                        <t t-elif="group_by == 'employee'">
                                            <t t-out="group[0]"/>
                                        </t>
                                    </strong>
                                </td>
                            </tr>
                            <t t-foreach="group[1]" t-as="attendance">
                                <tr t-attf-data-group-id="{{group[0]}}" class="attendance-group-row"
                                    style="display: none;">
                                    <td style="padding-left: 25px;">
                                        <img
                                                t-if="attendance.employee_id.image_1920"
                                                t-att-src="image_data_uri(attendance.employee_id.image_1920)"
                                                class="rounded img-fluid mx-2"
                                                style="width: 24px;"
                                                alt="Profile"
                                        />
                                        <img
                                                t-else=""
                                                src="/hr/static/src/img/default_image.png"
                                                class="rounded img-fluid mx-2"
                                                style="width: 24px;"
                                                alt="Default Avatar"
                                        />
                                        <t t-out="attendance.employee_id.name"/>
                                    </td>

                                    <td class="text-right">
                                        <t t-out="attendance.check_in.astimezone(timezone).strftime(date_format)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="attendance.check_out">
                                            <t t-out="attendance.check_out.astimezone(timezone).strftime(date_format)"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <!--                                <td class="text-right">-->
                                    <!--                                    <t t-if="attendance.status">-->
                                    <!--                                        <t t-esc="dict(attendance.fields_get(allfields=['status'])['status']['selection']).get(attendance.status, '')"/>-->
                                    <!--                                    </t>-->
                                    <!--                                    <t t-else="">-->
                                    <!--                                    </t>-->
                                    <!--                                </td>-->
                                    <td class="text-right">
                                        <t t-if="attendance.status2">
                                            <t t-esc="dict(attendance.fields_get(allfields=['status2'])['status2']['selection']).get(attendance.status2, '')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>

                                    <td class="text-right">
                                        <t t-if="attendance.in_status">
                                            <t t-esc="dict(attendance.fields_get(allfields=['in_status'])['in_status']['selection']).get(attendance.in_status, '')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="attendance.out_status">
                                            <t t-esc="dict(attendance.fields_get(allfields=['out_status'])['out_status']['selection']).get(attendance.out_status, '')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="attendance.attendance_status">
                                            <t t-esc="dict(attendance.fields_get(allfields=['attendance_status'])['attendance_status']['selection']).get(attendance.attendance_status, '')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>
                                    <!--                                <td class="text-center">-->
                                    <!--                                    <t t-if="attendance.on_leave">-->
                                    <!--                                        <i class="fa fa-check"/>-->
                                    <!--                                    </t>-->
                                    <!--                                    <t t-else="">-->
                                    <!--                                    </t>-->
                                    <!--                                </td>-->
                                    <td class="text-right">
                                        <t t-if="attendance.state">
                                            <t t-esc="dict(attendance.fields_get(allfields=['state'])['state']['selection']).get(attendance.state, '')"/>
                                        </t>
                                        <t t-else="">
                                        </t>
                                    </td>

                                    <td class="text-right">
