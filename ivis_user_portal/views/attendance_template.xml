                                        <!--                                        <i class="fa fa-arrow-circle-right"/>-->
                                        <!--                                        <span class='d-none d-md-inline'>Change Request</span>-->
                                        <!--                                        <span class='d-none d-md-inline'>Change Request</span>-->
                                        <!--                                    </a>-->
                                        <t t-if="attendance.check_in and attendance.check_out and attendance.state == 'done' and request.env.user.employee_id.company_id.allow_change_request">
                                            <a href="#" id="modal_a"
                                               title="Change Request"
                                               aria-label="Change Request"
                                               class="btn btn-sm btn-primary"
                                               t-att-class="'btn btn-sm btn-primary ' + ('disabled' if attendance.request_created else '')"
                                               role="button"
                                               data-bs-toggle="modal"
                                               t-attf-data-bs-target="#change_request_popup{{attendance.id}}">
                                                <i class="fa fa-arrow-circle-right"/>
                                                <span class='d-none d-md-inline'>Change Request</span>
                                            </a>
                                        </t>
                                    </td>
                                </tr>
                                <div class="modal fade" t-attf-id="change_request_popup{{attendance.id}}" role="dialog"
