                                                                           placeholder="From"
                                                                           t-att-value="attendance.check_in.astimezone(timezone).strftime(date_format)"/>
                                                                </div>
                                                                <div t-attf-class="mb-3 col-xl-6">
                                                                    <label class="col-form-label" for="date">To</label>
                                                                    <input type="datetime-local"
                                                                           t-attf-id="new_check_out_id{{attendance.id}}"
                                                                           name="new_check_out"
                                                                           class="form-control monitor-datetime new_check_out_id"
                                                                           placeholder="To"
                                                                           t-att-value="(attendance.check_out and attendance.check_out.astimezone(timezone).strftime(date_format)) or ''"/>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </form>
                                            </div>
                                            <div class="modal-footer">
                                                <button t-attf-id="request_submit_id{{attendance.id}}" type="submit"
                                                        t-attf-form="change_request_form{{attendance.id}}"
                                                        value="Update"
                                                        class="btn btn-primary" disabled="1">
