                                                                </div>
                                                                <div t-attf-class="mb-3 col-xl-6">
                                                                    <label class="col-form-label" for="date">From
                                                                    </label>
                                                                    <input type="datetime-local"
                                                                           t-attf-id="new_check_in_id{{attendance.id}}"
                                                                           name="new_check_in"
