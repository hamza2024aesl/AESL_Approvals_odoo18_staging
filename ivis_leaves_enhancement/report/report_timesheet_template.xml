<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <template id="leaves_enh_external_layout">
            <t t-if="o and 'company_id' in o">
                <t t-set="company" t-value="o.company_id"/>
            </t>
            <t t-if="not o or not 'company_id' in o">
                <t t-set="company" t-value="res_company"/>
            </t>
            <t t-call="ivis_leaves_enhancement.report_header"/>
            <t t-raw="0"/>
            <div class="footer"/>
        </template>

        <template id="report_header">
            <div class="header">
                <style>
                    table.bg-gray {
                    background: #C8C8C8;
                    }

                    td.black {color:
                    #000000;}
                </style>
                <table style="width:100%;" class="bg-gray">
                    <tr>
                        <td width="100%" class="black">
                            <span style="position: relative;left: 350px;">
                                <strong>Monthly Time Sheet</strong>
                            </span>
                        </td>
                    </tr>
                </table>
                <div class="row">
                    <img t-if="res_company.logo"
                         t-att-src="'data:image/png;base64,%s' %res_company.logo"
                         style="max-height: 45px;position: relative;left: 10px;"/>
                    <strong>
                        <span style="position: relative;left: 280px;"
                              t-esc="company.name"></span>
                    </strong>
                    <strong>
                        <center>
                            <span style="position:relative;left:-20px;" t-esc="period"/>
                        </center>
                    </strong>
                </div>
                <table>
                    <tr>
                        <td>
                            <strong>
                                <span>Print Date:</span>
                            </strong>
                        </td>
                        <td>
                            <span style="padding-left:20px;"
                                  t-esc="datetime.datetime.now().strftime('%a')+', '+str(datetime.datetime.now().strftime('%d-%m-%Y'))"/>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <strong>
                                <span>Print Time:</span>
                            </strong>
                        </td>
                        <td>
                            <span style="padding-left:20px;" t-esc="datetime.datetime.now().strftime('%H:%M:%S')"/>
                        </td>
                    </tr>
                    <tr>
                        <td></td>
                        <td>
                            <span style="position: relative;left: 760px;font-size:15px;">
                                Page:
                                <span class="page"/>
                                &#47;
                                <span class="topage"/>
                            </span>
                        </td>
                    </tr>
                </table>
                <!--<span style="position: relative;left: 760px;">Print Date:</span>-->
                <!--<span t-esc="datetime.datetime.now().strftime('%a')+', '+str(datetime.datetime.now().date())"/>-->
                <!--<br/>-->
                <!--<span style="position: relative;left: 760px;">Print Time:</span>-->
                <!--<span t-esc="datetime.datetime.now().strftime('%H:%M:%S')"/>-->
                <!--<br/>-->
                <!--<span style="position: relative;left: 760px;font-size:15px;">-->
                <!--Page:-->
                <!--<span class="page"/>-->
                <!--&#47;-->
                <!--<span class="topage"/>-->
                <!--</span>-->
            </div>
        </template>

        <template id="report_emp_time_sheet">
            <t t-call='report.html_container'>
                <t t-call="ivis_leaves_enhancement.leaves_enh_external_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="page">
                            <div class="row">
                                <div class="col-xs-3">
                                    <img t-if="o.image"
                                         t-att-src="'data:image/png;base64,%s' %o.image"
                                         style="max-height: 80px;"/>
                                </div>
                                <div class="col-xs-5" style="position: relative;left: -140px;">
                                    <table>
                                        <tr>
                                            <td style="padding-bottom:4px;">
                                                <strong>Employee No:</strong>
                                            </td>
                                            <td>
                                                <span style="padding-left:5px;" t-esc="o.employee_code"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding-bottom:4px;">
                                                <strong>Name:</strong>
                                            </td>
                                            <td>
                                                <span style="padding-left:5px;" t-esc="o.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding-bottom:4px;">
                                                <strong>Designation:</strong>
                                            </td>
                                            <td>
                                                <span style="padding-left:5px;" t-esc="o.job_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding-bottom:4px;">
                                                <strong>Department:</strong>
                                            </td>
                                            <td>
                                                <span style="padding-left:5px;" t-esc="o.department_id.name"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="padding-bottom:4px;">
                                                <strong>Type:</strong>
                                            </td>
                                            <td>
                                                <t t-if="employee_type != None">
                                                    <span style="padding-left:5px;"
                                                          t-esc="employee_type['emp_type'].capitalize()"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td>
                                                <strong>Joining Date:</strong>
                                            </td>
                                            <td>
                                                <t t-if="employee_type != None">
                                                    <span style="padding-left:5px;"
                                                          t-esc="datetime.datetime.strptime(employee_type['date_start'],'%Y-%m-%d').strftime('%d-%m-%Y')"/>
                                                </t>
                                            </td>
                                        </tr>
                                    </table>

                                    <!--<strong>Employee No:&#160;&#160;</strong>-->
                                    <!--<span t-esc="o.employee_code"></span>-->
                                    <!--<br/>-->
                                    <!--<strong>Name:&#160;&#160;&#160;&#160;</strong>-->
                                    <!--<span t-esc="o.name"></span>-->
                                    <!--<br/>-->
                                    <!--<strong>Designation:&#160;&#160;&#160;</strong>-->
                                    <!--<span t-esc="o.job_id.name"></span>-->
                                    <!--<br/>-->
                                    <!--<strong>Department:&#160;&#160;&#160;</strong>-->
                                    <!--<span t-esc="o.department_id.name"></span>-->
                                    <!--<br/>-->
                                    <!--<strong>Type:&#160;&#160;</strong>-->
                                    <!--<span t-esc="employee_type"></span>-->
                                    <!--<br/>-->
                                    <!--<strong>Joining Date:&#160;&#160;</strong>-->
                                    <!--<span>Test</span>-->
                                </div>
                                <style>
                                    p.dotted {border-style: dotted;
                                    border-width: 2px;
                                    }
                                </style>
                                <div class="col-xs-4">
                                    <p class="dotted">LEGEND Time ~ Manual Time Set By Time Office</p>
                                </div>
                            </div>

                            <!-- <div class="row"> <div class="col-xs-3"> </div> <div class="col-xs-5">
                                </div> <div class="col-xs-4" style="border-style: dotted;border-width: 2px;">
                                <span>Test1</span> <br/> <span>Test2</span> <br/> <span>Test3</span> <br/>
                                <span>Test1</span> <br/> <span>Test2</span> <br/> <span>Test3</span> <br/>
                                </div> </div> -->
                            <br/>
                            <div class="row">
                                <div class="col-xs-8">
                                    <table class="table table-condensed" width="80%"
                                           style="border-style: dotted;border-width: 2px;">
                                        <thead>
                                            <tr style="border-style: dotted;border-width: 2px;">
                                                <td>Leave Typ</td>
                                                <td>Entitled</td>
                                                <td>Availed in Month</td>
                                                <td>Availed in Year</td>
                                                <td>Balance</td>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="leaves" t-as="l">
                                                <tr>
                                                    <td width="30%">
                                                        <span t-esc="l['leave_type']"/>
                                                    </td>
                                                    <td width="30%">
                                                        <span t-esc="l['total']"/>
                                                    </td>
                                                    <td width="30%">
                                                        <span t-esc="l['avail_in_month']"/>
                                                    </td>
                                                    <td width="30%">
                                                        <span t-esc="l['avail_in_year']"/>
                                                    </td>
                                                    <td width="30%">
                                                        <span t-esc="l['remaining']"/>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>

                                    <!--                                    <table style="border-style: dotted;border-width: 2px;"-->
                                    <!--                                           width="70px">-->
                                    <!--                                        <thead style="border-style: dotted;border-width: 2px;">-->
                                    <!--                                            <tr style="border-style: dotted;border-width: 2px;">-->
                                    <!--                                                <th width="30%">Leave Typ</th>-->
                                    <!--                                                <th width="30%">Entitled</th>-->
                                    <!--                                                <th width="30%">Availed in Month</th>-->
                                    <!--                                                <th width="30%">Availed in Year</th>-->
                                    <!--                                                <th width="30%">Balance</th>-->
                                    <!--                                            </tr>-->
                                    <!--                                        </thead>-->
                                    <!--                                        <tbody>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="30%">Casual Leave</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="30%">Sick Leave</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="30%">Annual Leave</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="30%">Outdoor Duty</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="35%">Leave Without Pay</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="30%">Special Leave</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                            <br/>-->
                                    <!--                                            <tr>-->
                                    <!--                                                <td width="35%">Social Security Leave</td>-->
                                    <!--                                            </tr>-->
                                    <!--                                        </tbody>-->
                                    <!--                                    </table>-->
                                </div>

                                <div class="col-xs-4"
                                     style="border-style: dotted;border-width: 2px;" width="30%">
                                    <tbody>
                                        <tr>
                                            <th>Total Days in Month:</th>
                                            <th>
                                                <span t-esc="total_days"/>
                                            </th>
                                        </tr>
                                        <div style="border-top:1px solid black;"></div>
                                        <br/>
                                        <tr>
                                            <th>Physical Presents:</th>
                                            <th>
                                                <span t-esc="present_days"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Off Days:</th>
                                            <th>
                                                <span t-esc="off_days"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Holidays:</th>
                                            <th>
                                                <span t-esc="no_of_holiday"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Leave Days:</th>
                                            <th>
                                                <span t-esc="no_of_leave"/>
                                            </th>
                                            <!--<th></th>-->
                                        </tr>
                                        <div style="border-top:1px solid black;"></div>
                                        <br/>
                                        <tr>
                                            <th>On Time Arrivals:</th>
                                            <th>
                                                <span t-esc="on_time_days"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Late Arrivals:</th>
                                            <th>
                                                <span t-esc="late_coming_days"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Early Departure:</th>
                                            <th>
                                                <span t-esc="early_departure_days"/>
                                            </th>
                                        </tr>
                                        <div style="border-top:1px solid black;"></div>
                                        <br/>
                                        <tr>
                                            <th>Total Presents:</th>
                                            <th>
                                                <span t-esc="present_days+no_of_leave"/>
                                            </th>
                                        </tr>
                                        <br/>
                                        <tr>
                                            <th>Absents / LWOP:</th>
                                            <th>
                                                <span t-esc="absent_days"/>
                                            </th>
                                        </tr>
                                    </tbody>
                                </div>

                            </div>

                            <hr style="border-style: dashed; border-width: 2px; padding:0px; margin-top:5px;"></hr>
                            <t t-set="total_work_hours" t-value="0"/>
                            <t t-set="total_overtime_hours" t-value="0"/>

                            <style>
                                .border-left-top-bottom {
                                border-left:1px solid black;
                                border-top:1px solid black;
                                border-bottom:1px solid black;
                                }
                                .border-top-bottom{
                                border-top:1px solid black;
                                border-bottom:1px solid black;
                                }
                                .border-top-right-bottom {
                                border-top:1px solid black;
                                border-right:1px solid black;
                                border-bottom:1px solid black;
                                }
                                .padding{
                                padding:5px;
                                }
                            </style>

                            <table width="100%">
                                <thead>
                                    <tr>
                                        <td style="font-size:12px;" class="border-left-top-bottom padding">
                                            <strong>Dated</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Sch. Code</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Sch.Start</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Sch.End</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Time In</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Time Out</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Work(Hrs)</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Overtime(Hrs)</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Late In(Hrs)</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-bottom padding">
                                            <strong>Early Out(Hrs)</strong>
                                        </td>
                                        <td style="font-size:12px;" class="border-top-right-bottom padding">
                                            <strong>Remarks</strong>
                                        </td>
                                    </tr>

                                </thead>
                                <tbody>
                                    <t t-foreach="timesheets" t-as="t">
                                        <tr>
                                            <td style="width:10%" class="padding">
                                                <span t-esc="t['dated']"/>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="t['schedules']['name']"/>
                                                </t>
                                                <t t-if="not t['schedules']">
                                                    <span>OFF</span>
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="datetime.datetime.strptime(str(t['schedules']['hour_from']),'%H.%M').strftime('%H:%M')"/>
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="datetime.datetime.strptime(str(t['schedules']['hour_to']),'%H.%M').strftime('%H:%M')"/>
                                                </t>
                                            </td>
                                            <td style="width:15%;" class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="t['time_in']"/>
                                                </t>
                                            </td>
                                            <td style="width:15%;" class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="t['time_out']"/>
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="'%s:%s' % (str(t['work']).split('.')[0], int(float(str('%.2f' % t['work']).split('.')[1])/100*60))"/>
                                                    <t t-set="total_work_hours" t-value="total_work_hours+t['work']"/>
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="'%s:%s' % (str(t['overtime']).split('.')[0], int(float(str('%.2f' % t['overtime']).split('.')[1])/100*60))"/>
                                                    <t t-set="total_overtime_hours"
                                                       t-value="total_overtime_hours+t['overtime']"/>
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="'%s:%s' % (str(t['late_in']).split('.')[0], int(float(str('%.2f' % t['late_in']).split('.')[1])/100*60))"/>
                                                    <!--<span t-esc="t['late_in']"/>-->
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="'%s:%s' % (str(t['early_out']).split('.')[0], int(float(str('%.2f' % t['early_out']).split('.')[1])/100*60))"/>
                                                    <!--<span t-esc="t['early_out']"/>-->
                                                </t>
                                            </td>
                                            <td class="padding">
                                                <t t-if="t['schedules']">
                                                    <span t-esc="t['remarks'].capitalize()"/>
                                                </t>
                                                <t t-if="not t['schedules']">
                                                    <span>Off Day</span>
                                                </t>
                                            </td>
                                        </tr>
                                    </t>
                                    <!--<hr/>-->
                                    <tr>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td style="padding-top:15px;">Total</td>
                                        <td style="padding-top:15px;">
                                            <!--<span t-esc="str(total_work_hours).split('.')[0]+':'+str(float('0.'+str(total_work_hours).split('.')[-1])*60).split('.')[0]"/>-->
                                            <span t-esc="'%s:%s' % (str(total_work_hours).split('.')[0], int(float(str('%.2f' % total_work_hours).split('.')[1])/100*60))"/>
                                            <!--<span t-esc="datetime.datetime.strptime(str(total_work_hours),'%H.%M').strftime('%H:%M')"/>-->
                                        </td>
                                        <td style="padding-top:15px;">
                                            <!--<span t-esc="total_overtime_hours"/>-->
                                            <span t-esc="'%s:%s' % (str(total_overtime_hours).split('.')[0], int(float(str('%.2f' % total_overtime_hours).split('.')[1])/100*60))"/>
                                        </td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="row" style="margin-top:45px;">
                                <div class="col-xs-1">
                                </div>
                                <div class="col-xs-4">
                                    <hr style="border-top: 1px solid black; margin-bottom:0px;"/>
                                    <span style="font-weight:bold;margin-top:-15%;">
                                        <center>Prepared By:</center>
                                    </span>
                                </div>
                                <div class="col-xs-2">
                                </div>
                                <div class="col-xs-4">
                                    <hr style="border-top: 1px solid black; margin-bottom:0px;"/>
                                    <span style="font-weight:bold;margin-top:-15%;">
                                        <center>Manager HR:
                                        </center>
                                    </span>
                                </div>
                                <div class="col-xs-1">
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>