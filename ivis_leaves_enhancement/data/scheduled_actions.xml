<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record forcecreate="True" id="ir_cron_leaves" model="ir.cron">
            <field name="name">Leaves Lapse Scheduler</field>
            <field name="model_id" ref="model_hr_leave"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="state">code</field>
            <field name="code">model.leaves_lapse()</field>
        </record>

        <record forcecreate="True" id="ir_cron_employee_type" model="ir.cron">
            <field name="name">Employee Type scheduler</field>
            <field name="model_id" ref="model_hr_contract"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="state">code</field>
            <field name="code">model.update_employee_type()</field>
        </record>

        <record forcecreate="True" id="ir_cron_scheduler_leaves" model="ir.cron">
            <field name="name">Leaves scheduler</field>
            <field name="model_id" ref="model_hr_contract"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="state">code</field>
            <field name="code">model.leaves_scheduler()</field>
        </record>
    </data>
</odoo>