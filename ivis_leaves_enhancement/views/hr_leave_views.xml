<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record id="timeoff_inherit" model="ir.ui.view">
            <field name="name">Time Off Form</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <!--                    <field name="remaining_leaves" string="Leaves Balance"/>-->
                </xpath>
                <xpath expr="//field[@name='number_of_days']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//header//button[@name='action_reset_confirm']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="hr_holidays.menu_open_department_leave_approvez" model="ir.actions.act_window" forcecreate="true">
            <field name="name">Department Leaves</field>
            <field name="res_model">hr.leave</field>
            <field name="view_mode">list,form,calendar</field>
            <field name="context">{'search_default_department':1, 'search_default_approve':1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click here to create a new leave request.
                </p>
            </field>
            <field name="domain">
                ['|',('employee_id.parent_id.user_id','=',uid),('employee_id.user_id','=',uid),('type','=','remove')]
            </field>
            <field name="search_view_id" ref="hr_holidays.view_hr_holidays_filter"/>
        </record>

        <record id="open_department_holidays_allocation_approve" model="ir.actions.act_window">
            <field name="name">Department Leaves Allocation</field>
            <field name="res_model">hr.leave</field>
            <field name="view_mode">list,form,calendar</field>
            <field name="context">{'default_type':'add', 'search_default_department':1, 'search_default_approve':1}
            </field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click here to create a new leave allocation.
                </p>
            </field>
            <field name="domain">
                ['|',('employee_id.parent_id.user_id','=',uid),('employee_id.user_id','=',uid),('type','=','add')]
            </field>
            <field name="search_view_id" ref="hr_holidays.view_hr_holidays_filter"/>
        </record>

        <record id="hr_leave_view_form_manager_checkin_checkout" model="ir.ui.view">
            <field name="name">hr.leave.view.form.manager.checkin.checkout</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/div[2]/div[1]/group[not(@name)][1]/field[@name='name']" position="after">
                    <field name="check_in" invisible="not request_unit_half"/>
                    <field name="check_out" invisible="not request_unit_half"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>